<Application x:Class="MedicalApp.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:viewmodels="clr-namespace:MedicalApp.ViewModels"
             xmlns:views="clr-namespace:MedicalApp.Views">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Styles/Theme.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- DataTemplates to route ViewModel to View automatically in ContentControl -->
            <DataTemplate DataType="{x:Type viewmodels:HomeViewModel}">
                <views:HomeView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type viewmodels:PatientRegistrationViewModel}">
                <views:PatientRegistrationView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type viewmodels:ClinicalExamViewModel}">
                <views:ClinicalExamView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type viewmodels:EchoUploadViewModel}">
                <views:EchoUploadView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type viewmodels:PrintSettingsViewModel}">
                <views:PrintSettingsView/>
            </DataTemplate>
        </ResourceDictionary>
    </Application.Resources>
</Application>
