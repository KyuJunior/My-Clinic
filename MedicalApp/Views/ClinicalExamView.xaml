                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock Text="{Binding}" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="{StaticResource TextColor}"/>
