                                                                        Command="{Binding DataContext.RemoveDrugCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}"/>
                                                                 <!-- Name -->
                                                                 <TextBlock Grid.Column="1" Text="{Binding Name}" Foreground="{DynamicResource TextColor}" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" TextWrapping="Wrap" Margin="0,0,10,0"/>

                                                                 <!-- Dose -->
                                                                 <TextBox Grid.Column="2" Foreground="{DynamicResource TextColor}" Style="{StaticResource MaterialDesignOutlinedTextBox}" materialDesign:TextFieldAssist.TextFieldCornerRadius="4" Text="{Binding Dose, UpdateSourceTrigger=PropertyChanged}" Height="40" Padding="10,8" Margin="0,0,5,0" VerticalContentAlignment="Center"/>

                                                                 <!-- Type Dropdown -->
                                                                 <ComboBox Foreground="{DynamicResource TextColor}" Grid.Column="3" Style="{StaticResource MaterialDesignOutlinedComboBox}" materialDesign:TextFieldAssist.TextFieldCornerRadius="4" Height="40" Padding="10,8" Margin="0,0,5,0" SelectedValue="{Binding Type}" SelectedValuePath="Content" VerticalContentAlignment="Center" Background="{DynamicResource CardBackgroundColor}">
                                                                     <ComboBox.ItemContainerStyle>
                                                                         <Style TargetType="ComboBoxItem" BasedOn="{StaticResource {x:Type ComboBoxItem}}">
                                                                             <Setter Property="Padding" Value="10,6"/>
                                                                         </Style>
                                                                     </ComboBox.ItemContainerStyle>
                                                                     <ComboBoxItem Content="Select..."/>
