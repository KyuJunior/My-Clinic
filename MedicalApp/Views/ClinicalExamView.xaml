<UserControl x:Class="MedicalApp.Views.ClinicalExamView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:converters="clr-namespace:MedicalApp.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="1000"
             Background="Transparent">
    <UserControl.Resources>
        <converters:NullToBoolConverter x:Key="NullToBoolConverter"/>
        <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
    </UserControl.Resources>
    
    <Grid Margin="10,15,10,10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Back Navigation Header -->
            <RowDefinition Height="Auto"/> <!-- Top Panel: Standalone Patient Lookup -->
            <RowDefinition Height="*"/>    <!-- Main Workspace -->
        </Grid.RowDefinitions>

        <!-- Back Button Header -->
        <Button Grid.Row="0" HorizontalAlignment="Left" Margin="0,0,0,15"
                Style="{StaticResource NavButton}" Padding="12,7" 
                Tag="&#xE72B;" Content="Back to Dashboard"
                Command="{Binding DataContext.NavigateToHomeCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>

        <!-- Top Panel: Standalone Patient Lookup -->
        <Border Grid.Row="1" Style="{StaticResource CardBorder}" Margin="0,0,0,15" Padding="15,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="240"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Select Patient:" VerticalAlignment="Center" FontWeight="SemiBold" FontSize="13" Foreground="{StaticResource SubtextColor}" Margin="0,0,10,0"/>
                
                <TextBox Grid.Column="1" Style="{StaticResource ModernTextBox}" Text="{Binding SearchTerm, UpdateSourceTrigger=PropertyChanged}" Tag="Search patient by name/phone..." VerticalContentAlignment="Center" Margin="0,0,10,0"/>
                
                <Button Grid.Column="2" Style="{StaticResource ModernButton}" Content="Search" Command="{Binding SearchPatientsCommand}" Margin="0,0,15,0" Padding="15,6"/>
                
                <ComboBox Grid.Column="3" ItemsSource="{Binding Patients}" SelectedItem="{Binding SelectedPatientLookup}" DisplayMemberPath="Name" SelectedValuePath="PatientId" Height="36" VerticalContentAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Main Workspace (Waitlist Queue + Form + History) -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/> <!-- Waitlist Queue Sidebar -->
                <ColumnDefinition Width="420"/> <!-- Visit Input Form -->
                <ColumnDefinition Width="*"/>   <!-- Timeline of Previous Visits -->
            </Grid.ColumnDefinitions>

            <!-- Column 0: Active Waitlist Queue -->
            <Border Grid.Column="0" Style="{StaticResource CardBorder}" Margin="0,0,15,0" VerticalAlignment="Stretch">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,15">
                        <TextBlock Text="Today's Waitlist" Style="{StaticResource Header2}"/>
                        <TextBlock Text="Live queue updates from registration." Style="{StaticResource Subheading}"/>
                    </StackPanel>

                    <ListBox Grid.Row="1" ItemsSource="{Binding ActiveQueue}" BorderThickness="0" Background="Transparent" HorizontalContentAlignment="Stretch" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{StaticResource BorderColor}" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,0,0,10" Background="White">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Column="0" Grid.Row="0" Text="{Binding PatientName}" FontSize="13" FontWeight="Bold" Foreground="{StaticResource TextColor}" TextTrimming="CharacterEllipsis"/>
                                        
                                        <!-- Status Badge -->
                                        <Border Grid.Column="0" Grid.Row="1" HorizontalAlignment="Left" CornerRadius="4" Padding="6,2" Margin="0,5,0,0">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="Pending">
                                                            <Setter Property="Background" Value="#F1F5F9"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="InExam">
                                                            <Setter Property="Background" Value="#FFE4E6"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="InEcho">
                                                            <Setter Property="Background" Value="#E0F2FE"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock FontSize="10" FontWeight="SemiBold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Status}" Value="Pending">
                                                                <Setter Property="Text" Value="Waiting"/>
                                                                <Setter Property="Foreground" Value="#64748B"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="InExam">
                                                                <Setter Property="Text" Value="In Exam"/>
                                                                <Setter Property="Foreground" Value="#E11D48"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="InEcho">
                                                                <Setter Property="Text" Value="In Echo"/>
                                                                <Setter Property="Foreground" Value="#0284C7"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>

                                        <!-- Start Action Button -->
                                        <Button Grid.Column="1" Grid.Row="0" Grid.RowSpan="2" Style="{StaticResource ModernButton}" Content="Start" VerticalAlignment="Center" Padding="10,4" FontSize="11"
                                                Command="{Binding DataContext.StartSessionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- Column 1: Current Examination Entry -->
            <Border Grid.Column="1" Style="{StaticResource CardBorder}" Margin="0,0,15,0" VerticalAlignment="Stretch">
                <Grid>
                    <!-- Form stack panel (visible when patient is selected) -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Visibility="{Binding CurrentPatient, Converter={StaticResource NullToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="New Visit Examination" Style="{StaticResource Header2}"/>
                            <TextBlock Text="Log examination findings and plan for the active patient." Style="{StaticResource Subheading}" Margin="0,0,0,20"/>

                            <!-- Active Patient Details -->
                            <Border Background="#F8FAFC" BorderBrush="{StaticResource BorderColor}" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,0,0,15">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding CurrentPatient.Name}" FontWeight="Bold" FontSize="14" Foreground="{StaticResource PrimaryColor}"/>
                                        <TextBlock Text="{Binding CurrentPatient.Phone}" FontSize="12" Foreground="{StaticResource SubtextColor}"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" VerticalAlignment="Center" FontWeight="SemiBold" FontSize="12" Foreground="{StaticResource TextColor}">
                                        <Run Text="{Binding CurrentPatient.Age}"/> <Run Text="yrs,"/> <Run Text="{Binding CurrentPatient.Gender}"/>
                                    </TextBlock>
                                </Grid>
                            </Border>

                            <!-- Chief Complaint -->
                            <TextBlock Text="Chief Complaint" Style="{StaticResource Subheading}"/>
                            <TextBox Style="{StaticResource ModernTextBox}" Text="{Binding ChiefComplaint, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,15"/>

                            <!-- History of Present Illness -->
                            <TextBlock Text="History of Present Illness (HPI)" Style="{StaticResource Subheading}"/>
                            <TextBox Style="{StaticResource ModernTextBox}" Text="{Binding HistoryOfPresentIllness, UpdateSourceTrigger=PropertyChanged}" Height="80" AcceptsReturn="True" TextWrapping="Wrap" Margin="0,0,0,15"/>

                            <!-- Physical Examination -->
                            <TextBlock Text="Physical Examination Findings" Style="{StaticResource Subheading}"/>
                            <TextBox Style="{StaticResource ModernTextBox}" Text="{Binding PhysicalExamination, UpdateSourceTrigger=PropertyChanged}" Height="80" AcceptsReturn="True" TextWrapping="Wrap" Margin="0,0,0,15"/>

                            <!-- Diagnosis -->
                            <TextBlock Text="Diagnosis" Style="{StaticResource Subheading}"/>
                            <TextBox Style="{StaticResource ModernTextBox}" Text="{Binding Diagnosis, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,15"/>

                            <!-- Treatment Plan -->
                            <TextBlock Text="Treatment Plan / Doctor Notes" Style="{StaticResource Subheading}"/>
                            <TextBox Style="{StaticResource ModernTextBox}" Text="{Binding TreatmentPlan, UpdateSourceTrigger=PropertyChanged}" Height="60" AcceptsReturn="True" TextWrapping="Wrap" Margin="0,0,0,15"/>

                            <!-- Rx Medication Autocomplete Builder -->
                            <TextBlock Text="Medication Prescription (Rx)" Style="{StaticResource Subheading}"/>
                            
                            <!-- Search & Add Grid -->
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <TextBox x:Name="DrugInput" Style="{StaticResource ModernTextBox}" 
                                         Text="{Binding DrugSearchText, UpdateSourceTrigger=PropertyChanged}" 
                                         Tag="Search or type drug name... (e.g. Aspirin)"/>

                                <Button Grid.Column="1" Style="{StaticResource ModernButton}" Content="Add" 
                                        Command="{Binding AddDrugCommand}" Margin="10,0,0,0" Padding="15,6"/>

                                <!-- Autocomplete Suggestions Popup -->
                                <Popup IsOpen="{Binding IsDrugSuggestionsOpen, Mode=TwoWay}" PlacementTarget="{Binding ElementName=DrugInput}" Placement="Bottom" StaysOpen="False" AllowsTransparency="True" PopupAnimation="Slide">
                                    <Border Background="White" BorderBrush="{StaticResource BorderColor}" BorderThickness="1.5" CornerRadius="8" Width="300" MaxHeight="200" Padding="5">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="10" Color="Black" Opacity="0.15" ShadowDepth="3"/>
                                        </Border.Effect>
                                        <ListBox ItemsSource="{Binding DrugSuggestions}" BorderThickness="0" Background="Transparent" HorizontalContentAlignment="Stretch">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Button Style="{StaticResource NavButton}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Padding="8,6" Content="{Binding}"
                                                            Command="{Binding DataContext.SelectSuggestedDrugCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}"/>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </Border>
                                </Popup>
                            </Grid>

                            <!-- Prescribed Drugs List -->
                            <ItemsControl ItemsSource="{Binding PrescribedDrugs}" Margin="0,0,0,15">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#F1F5F9" CornerRadius="4" Padding="8,4" Margin="0,0,0,5">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding}" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="{StaticResource TextColor}"/>
                                                <Button Grid.Column="1" Style="{StaticResource NavButton}" Width="24" Height="24" Tag="&#xE711;" ToolTip="Remove medication" Padding="0" Foreground="#EF4444"
                                                        Command="{Binding DataContext.RemoveDrugCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Action Buttons -->
                            <StackPanel Margin="0,5,0,0">
                                <!-- End Exam Session Actions -->
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0" Style="{StaticResource ModernButton}" Content="Complete Visit" Command="{Binding CompleteSessionDoneCommand}" Height="40" Margin="0,0,5,0"/>
                                    <Button Grid.Column="1" Style="{StaticResource ModernButton}" Content="Send to Echo Waitlist" Command="{Binding CompleteSessionToEchoCommand}" Background="#0284C7" BorderBrush="#0284C7" Height="40" Margin="5,0,0,0"/>
                                </Grid>

                                <!-- Print Actions -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0" Style="{StaticResource ModernButton}" Content="Print Rx (A5)" Command="{Binding PrintActiveRxCommand}" Background="#10B981" BorderBrush="#10B981" Height="40" Margin="0,0,5,0"/>
                                    <Button Grid.Column="1" Style="{StaticResource ModernButton}" Content="Print Summary (A4)" Command="{Binding PrintActiveVisitReportCommand}" Background="#6366F1" BorderBrush="#6366F1" Height="40" Margin="5,0,0,0"/>
                                </Grid>
                            </StackPanel>

                            <!-- Status Message -->
                            <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource PrimaryColor}" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,15,0,0" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Placeholder (visible when no patient is selected) -->
                    <Border Visibility="{Binding CurrentPatient, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=Inverse}" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="20">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="No Active Exam Session" FontSize="16" FontWeight="Bold" Foreground="{StaticResource SubtextColor}" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                            <TextBlock Text="Select a patient from the waitlist on the left to start a clinical examination session." FontSize="12" Foreground="{StaticResource SubtextColor}" TextAlignment="Center" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- Column 2: Historical Visits Timeline -->
            <Border Grid.Column="2" Style="{StaticResource CardBorder}" Margin="15,0,0,0" VerticalAlignment="Stretch">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Visit History Timeline" Style="{StaticResource Header2}"/>

                    <!-- Timeline ListBox -->
                    <ListBox Grid.Row="1" ItemsSource="{Binding VisitHistory}" BorderThickness="0" Background="Transparent" HorizontalContentAlignment="Stretch" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,0,1.5" Padding="0,15" Margin="0,0,0,5">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <!-- Date and Diagnosis Header -->
                                        <Grid Grid.Row="0" Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            
                                            <TextBlock Grid.Column="0" Text="{Binding Diagnosis, TargetNullValue='Undiagnosed Visit'}" FontSize="15" FontWeight="Bold" Foreground="{StaticResource PrimaryColor}"/>
                                            <TextBlock Grid.Column="1" Text="{Binding VisitDate, StringFormat=\{0:dd/MM/yyyy HH:mm\}}" FontSize="12" Foreground="{StaticResource SubtextColor}" FontWeight="SemiBold"/>
                                        </Grid>

                                        <!-- Chief Complaint -->
                                        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,4">
                                            <TextBlock Text="Chief Complaint: " FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextColor}"/>
                                            <TextBlock Text="{Binding ChiefComplaint}" FontSize="13" Foreground="{StaticResource TextColor}" TextWrapping="Wrap"/>
                                        </StackPanel>

                                        <!-- Physical Exam / Present Illness Details -->
                                        <Grid Grid.Row="2" Margin="0,0,0,6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            
                                            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                                <TextBlock Text="HPI" FontSize="11" FontWeight="Bold" Foreground="{StaticResource SubtextColor}"/>
                                                <TextBlock Text="{Binding HistoryOfPresentIllness}" FontSize="12" Foreground="{StaticResource TextColor}" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                                <TextBlock Text="Physical Exam" FontSize="11" FontWeight="Bold" Foreground="{StaticResource SubtextColor}"/>
                                                <TextBlock Text="{Binding PhysicalExamination}" FontSize="12" Foreground="{StaticResource TextColor}" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </Grid>

                                        <!-- Treatment Plan & Rx -->
                                        <Border Grid.Row="3" Background="#F1F5F9" Padding="12,8" CornerRadius="6" Margin="0,6,0,0">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="Treatment Plan" FontSize="11" FontWeight="Bold" Foreground="{StaticResource PrimaryColor}"/>
                                                    <TextBlock Text="{Binding TreatmentPlan}" FontSize="12" Foreground="{StaticResource TextColor}" TextWrapping="Wrap" Margin="0,2,0,5"/>
                                                    
                                                    <TextBlock Text="Rx (Prescription)" FontSize="11" FontWeight="Bold" Foreground="{StaticResource PrimaryColor}" Margin="0,5,0,0" Visibility="{Binding Prescription, Converter={StaticResource NullToVisibilityConverter}}"/>
                                                    <TextBlock Text="{Binding Prescription}" FontSize="12" Foreground="{StaticResource TextColor}" TextWrapping="Wrap" Margin="0,2,0,0" FontWeight="SemiBold" Visibility="{Binding Prescription, Converter={StaticResource NullToVisibilityConverter}}"/>
                                                </StackPanel>

                                                <!-- Print Buttons for past visits -->
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0">
                                                    <Button Style="{StaticResource NavButton}" Padding="8,4" Tag="&#xE716;" ToolTip="Print Visit Summary Report (A4)" Width="32" Height="32" Margin="0,0,0,6"
                                                            Command="{Binding DataContext.PrintVisitReportCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}"/>
                                                    <Button Style="{StaticResource NavButton}" Padding="8,4" Tag="&#xE716;" ToolTip="Print Prescription Pad (A5)" Width="32" Height="32"
                                                            Command="{Binding DataContext.PrintVisitRxCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}"
                                                            Visibility="{Binding Prescription, Converter={StaticResource NullToVisibilityConverter}}"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
