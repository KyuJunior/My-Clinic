<UserControl x:Class="MedicalApp.Views.ClinicalExamView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:converters="clr-namespace:MedicalApp.Converters"
             xmlns:views="clr-namespace:MedicalApp.Views"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1100"
             Background="Transparent"
             PreviewMouseLeftButtonDown="PatientList_PreviewMouseLeftButtonDown"
             PreviewMouseMove="PatientList_PreviewMouseMove"
             PreviewMouseLeftButtonUp="PatientList_PreviewMouseLeftButtonUp">
    
    <UserControl.Resources>
        <views:BindingProxy x:Key="Proxy" Data="{Binding}"/>
        <converters:NullToBoolConverter x:Key="NullToBoolConverter"/>
        <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
        <converters:InverseBooleanConverter x:Key="InverseBooleanConverter"/>
        <converters:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter"/>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <Style x:Key="SidebarTabRadioButton" TargetType="RadioButton" BasedOn="{StaticResource {x:Type RadioButton}}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="PillBorder" CornerRadius="16" Background="Transparent" SnapsToDevicePixels="True" Padding="8,4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center">
                                <ContentPresenter.Resources>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="FontSize" Value="11"/>
                                    </Style>
                                </ContentPresenter.Resources>
                            </ContentPresenter>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="PillBorder" Property="Background" Value="White"/>
                                <Setter TargetName="PillBorder" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect ShadowDepth="1" BlurRadius="3" Color="#CBD5E1" Opacity="0.5"/>
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="Foreground" Value="{StaticResource PrimaryColor}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="False">
                                <Setter Property="Foreground" Value="{StaticResource SubtextColor}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TabSelectorButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0,5"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource SubtextColor}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="Transparent" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource PrimaryColor}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="QueueListBoxStyle" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="4"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <materialDesign:DialogHost Identifier="ExamDialogHost" IsOpen="{Binding IsDialogOpen}" CloseOnClickAway="True">
        <materialDesign:DialogHost.DialogContent>
            <Grid>
                <!-- Custom modal template selection dialog -->
                <Border Background="White" CornerRadius="12" Padding="20" Width="360" BorderBrush="#E2E8F0" BorderThickness="1"
                        Visibility="{Binding IsTemplateDialog, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="12"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="15"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <TextBlock Grid.Row="0" Text="{Binding DialogHeader}" FontSize="15" FontWeight="Bold" Foreground="{StaticResource PrimaryColor}"/>
                        
                        <ScrollViewer Grid.Row="2" MaxHeight="250" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding DialogTemplateItems}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Style="{StaticResource MaterialDesignFlatButton}" 
                                                HorizontalContentAlignment="Left"
                                                Margin="0,4" Padding="12,6" Height="Auto"
                                                Command="{Binding DataContext.InsertTemplateTextCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                BorderThickness="1" BorderBrush="{DynamicResource BorderColor}"
                                                Background="{DynamicResource CardBackgroundColor}">
                                            <TextBlock Text="{Binding}" TextWrapping="Wrap" FontSize="11" Foreground="{DynamicResource TextColor}"/>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <!-- Tab Content: Patient Summary Dashboard -->
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Style="{StaticResource MaterialDesignScrollViewer}"
                                      Visibility="{Binding IsSummaryTabActive, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Grid Margin="5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Column 0: Overview & Vitals -->
                                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                    <!-- Patient Overview Card -->
                                    <Border Style="{StaticResource CardBorder}" Margin="0,0,0,12" Padding="15">
                                        <StackPanel>
                                            <Grid Margin="0,0,0,10">
                                                <TextBlock Text="Patient Overview" Style="{StaticResource Subheading}" VerticalAlignment="Center"/>
                                                <Button Style="{StaticResource LinkButton}" Content="Edit Profile" FontSize="11" Foreground="{StaticResource PrimaryColor}" HorizontalAlignment="Right" VerticalAlignment="Center"
                                                        Command="{Binding SelectConsultationTabCommand}"/>
                                            </Grid>
                                            
                                            <StackPanel Margin="0,5,0,0">
                                                <TextBlock Text="Current Status" FontSize="10" Foreground="{StaticResource SubtextColor}" Margin="0,0,0,2"/>
                                                <Border Background="#E6F4EA" CornerRadius="4" Padding="6,2" HorizontalAlignment="Left" Margin="0,0,0,8">
                                                    <TextBlock Text="Active" FontSize="11" FontWeight="Bold" Foreground="#137333"/>
                                                </Border>

                                                <TextBlock Text="Address" FontSize="10" Foreground="{StaticResource SubtextColor}" Margin="0,0,0,2"/>
                                                <TextBlock Text="{Binding CurrentPatient.Address, TargetNullValue='No address logged'}" FontSize="12" Foreground="{StaticResource TextColor}" Margin="0,0,0,8" TextWrapping="Wrap"/>

                                                <TextBlock Text="Profession / Job" FontSize="10" Foreground="{StaticResource SubtextColor}" Margin="0,0,0,2"/>
                                                <TextBlock Text="{Binding CurrentPatient.Job, TargetNullValue='No job logged'}" FontSize="12" Foreground="{StaticResource TextColor}" Margin="0,0,0,8"/>

                                                <TextBlock Text="Governorate" FontSize="10" Foreground="{StaticResource SubtextColor}" Margin="0,0,0,2"/>
                                                <TextBlock Text="{Binding CurrentPatient.Governorate, TargetNullValue='No governorate logged'}" FontSize="12" Foreground="{StaticResource TextColor}" Margin="0,0,0,8"/>

                                                <TextBlock Text="Marital Status" FontSize="10" Foreground="{StaticResource SubtextColor}" Margin="0,0,0,2"/>
                                                <TextBlock Text="{Binding CurrentPatient.MaritalStatus, TargetNullValue='No details logged'}" FontSize="12" Foreground="{StaticResource TextColor}" Margin="0,0,0,8"/>

                                                <TextBlock Text="Blood Group" FontSize="10" Foreground="{StaticResource SubtextColor}" Margin="0,0,0,2"/>
                                                <TextBlock Text="{Binding CurrentPatient.BloodGroup, TargetNullValue='Unknown'}" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource PrimaryColor}"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>

                                    <!-- Recent Vitals Card -->
                                    <Border Style="{StaticResource CardBorder}" Margin="0,0,0,12" Padding="15">
                                        <StackPanel>
                                            <Grid Margin="0,0,0,10">
                                                <TextBlock Text="Recent Vitals" Style="{StaticResource Subheading}" VerticalAlignment="Center"/>
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                                    <!-- sparkline trend polyline -->
                                                    <Canvas Width="70" Height="24" Margin="0,0,10,0">
                                                        <Polyline Points="{Binding VitalsTrendPoints}" Stroke="{StaticResource PrimaryColor}" StrokeThickness="1.5"/>
                                                    </Canvas>
                                                    <Button Style="{StaticResource LinkButton}" Content="Trend" FontSize="11" Foreground="{StaticResource PrimaryColor}"
                                                            Command="{Binding SelectConsultationTabCommand}"/>
                                                </StackPanel>
                                            </Grid>

                                            <!-- Vitals Grid -->
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- BP -->
                                                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,5,8">
                                                    <TextBlock Text="BP" FontSize="10" Foreground="{StaticResource SubtextColor}"/>
                                                    <TextBlock FontSize="13" FontWeight="Bold" Foreground="{StaticResource TextColor}">
                                                        <Run Text="{Binding VitalSBP, TargetNullValue='--'}"/><Run Text="/"/><Run Text="{Binding VitalDBP, TargetNullValue='--'}"/>
                                                        <Run Text=" mmHg" FontSize="10" FontWeight="Normal" Foreground="{StaticResource SubtextColor}"/>
                                                    </TextBlock>
                                                </StackPanel>

                                                <!-- Pulse -->
                                                <StackPanel Grid.Row="0" Grid.Column="1" Margin="5,0,0,8">
                                                    <TextBlock Text="Pulse" FontSize="10" Foreground="{StaticResource SubtextColor}"/>
                                                    <TextBlock FontSize="13" FontWeight="Bold" Foreground="{StaticResource TextColor}">
                                                        <Run Text="{Binding VitalHR, TargetNullValue='--'}"/><Run Text=" bpm" FontSize="10" FontWeight="Normal" Foreground="{StaticResource SubtextColor}"/>
                                                    </TextBlock>
                                                </StackPanel>

                                                <!-- Temp -->
                                                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,5,8">
                                                    <TextBlock Text="Temp" FontSize="10" Foreground="{StaticResource SubtextColor}"/>
                                                    <TextBlock FontSize="13" FontWeight="Bold" Foreground="{StaticResource TextColor}">
                                                        <Run Text="{Binding VitalTemp, TargetNullValue='--'}"/><Run Text=" °C" FontSize="10" FontWeight="Normal" Foreground="{StaticResource SubtextColor}"/>
                                                    </TextBlock>
                                                </StackPanel>

                                                <!-- SPO2 -->
                                                <StackPanel Grid.Row="1" Grid.Column="1" Margin="5,0,0,8">
                                                    <TextBlock Text="SPO2" FontSize="10" Foreground="{StaticResource SubtextColor}"/>
                                                    <TextBlock FontSize="13" FontWeight="Bold" Foreground="{StaticResource TextColor}">
                                                        <Run Text="{Binding VitalSPO2, TargetNullValue='--'}"/><Run Text=" %" FontSize="10" FontWeight="Normal" Foreground="{StaticResource SubtextColor}"/>
                                                    </TextBlock>
                                                </StackPanel>

                                                <!-- Weight -->
                                                <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,5,0">
                                                    <TextBlock Text="Weight" FontSize="10" Foreground="{StaticResource SubtextColor}"/>
                                                    <TextBlock FontSize="13" FontWeight="Bold" Foreground="{StaticResource TextColor}">
                                                        <Run Text="{Binding CurrentPatient.Weight, TargetNullValue='--'}"/><Run Text=" kg" FontSize="10" FontWeight="Normal" Foreground="{StaticResource SubtextColor}"/>
                                                    </TextBlock>
                                                </StackPanel>

                                                <!-- Height -->
                                                <StackPanel Grid.Row="2" Grid.Column="1" Margin="5,0,0,0">
                                                    <TextBlock Text="Height" FontSize="10" Foreground="{StaticResource SubtextColor}"/>
                                                    <TextBlock FontSize="13" FontWeight="Bold" Foreground="{StaticResource TextColor}">
                                                        <Run Text="{Binding CurrentPatient.Height, TargetNullValue='--'}"/><Run Text=" cm" FontSize="10" FontWeight="Normal" Foreground="{StaticResource SubtextColor}"/>
                                                    </TextBlock>
                                                </StackPanel>
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>

                                <!-- Column 1: History & Visits -->
                                <StackPanel Grid.Column="1" Margin="5,0,5,0">
                                    <!-- Medical History Card -->
                                    <Border Style="{StaticResource CardBorder}" Margin="0,0,0,12" Padding="15">
                                        <StackPanel>
                                            <Grid Margin="0,0,0,10">
                                                <TextBlock Text="Medical History" Style="{StaticResource Subheading}" VerticalAlignment="Center"/>
                                                <Button Style="{StaticResource LinkButton}" Content="Add Note" FontSize="11" Foreground="{StaticResource PrimaryColor}" HorizontalAlignment="Right" VerticalAlignment="Center"
                                                        Command="{Binding SelectConsultationTabCommand}"/>
                                            </Grid>

                                            <!-- Diagnoses Chips List -->
                                            <TextBlock Text="Diagnoses" FontSize="10" Foreground="{StaticResource SubtextColor}" Margin="0,0,0,4"/>
                                            <ItemsControl ItemsSource="{Binding HistoryDiagnoses}" Margin="0,0,0,10">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel Orientation="Horizontal"/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Background="#E0F2FE" CornerRadius="4" Padding="8,3" Margin="0,0,6,6">
                                                            <TextBlock Text="{Binding}" FontSize="11" FontWeight="SemiBold" Foreground="#0369A1"/>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            
                                            <!-- Allergies -->
                                            <TextBlock Text="Allergies" FontSize="10" Foreground="{StaticResource SubtextColor}" Margin="0,0,0,4"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                                                                                 <Border Background="{DynamicResource WarningBadgeBackground}" CornerRadius="4" Padding="8,3">
                                                     <TextBlock Text="{Binding CurrentPatient.Allergy, TargetNullValue='No allergies logged'}" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource WarningBadgeText}"/>
                                                 </Border>
                                            </StackPanel>

                                            <!-- Surgeries / Notes -->
                                            <TextBlock Text="General Profile Notes" FontSize="10" Foreground="{StaticResource SubtextColor}" Margin="0,0,0,2"/>
                                            <TextBlock Text="{Binding CurrentPatient.Notes, TargetNullValue='No historical profile notes logged.'}" FontSize="11" Foreground="{StaticResource TextColor}" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Recent Visits Card -->
                                    <Border Style="{StaticResource CardBorder}" Margin="0,0,0,12" Padding="15">
                                        <StackPanel>
                                            <Grid Margin="0,0,0,10">
                                                <TextBlock Text="Recent Visits" Style="{StaticResource Subheading}" VerticalAlignment="Center"/>
                                                <Button Style="{StaticResource LinkButton}" Content="Start Visit" FontSize="11" Foreground="{StaticResource PrimaryColor}" HorizontalAlignment="Right" VerticalAlignment="Center"
                                                        Command="{Binding SelectConsultationTabCommand}"/>
                                            </Grid>

                                            <!-- Visits list -->
                                            <ItemsControl ItemsSource="{Binding RecentVisitsList}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,0,1" Padding="0,8" Margin="0,0,0,4">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock Grid.Column="0" Text="{Binding VisitDate, StringFormat=\{0:MMM dd\, yyyy\}}" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource SubtextColor}" Width="75" VerticalAlignment="Center"/>
                                                                <TextBlock Grid.Column="1" Text="{Binding Diagnosis, TargetNullValue='Checkup/No Dx'}" FontSize="12" Foreground="{StaticResource TextColor}" VerticalAlignment="Center" TextWrapping="Wrap"/>
                                                                <TextBlock Grid.Column="2" Text="&#xE76C;" FontFamily="Segoe MDL2 Assets" FontSize="10" Foreground="{StaticResource SubtextColor}" VerticalAlignment="Center" Margin="5,0,0,0"/>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>

                                <!-- Column 2: Medications & Appointments -->
                                <StackPanel Grid.Column="2" Margin="10,0,0,0">
                                    <!-- Current Medications Card -->
                                    <Border Style="{StaticResource CardBorder}" Margin="0,0,0,12" Padding="15">
                                        <StackPanel>
                                            <Grid Margin="0,0,0,10">
                                                <TextBlock Text="Current Medications" Style="{StaticResource Subheading}" VerticalAlignment="Center"/>
                                                <Button Style="{StaticResource LinkButton}" Content="+ Add Note" FontSize="11" Foreground="{StaticResource PrimaryColor}" HorizontalAlignment="Right" VerticalAlignment="Center"
                                                        Command="{Binding SelectConsultationTabCommand}"/>
                                            </Grid>

                                            <!-- Medications table/list -->
                                            <Grid Margin="0,0,0,6" Visibility="{Binding HasPrescribedDrugs, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="Name" FontSize="11" FontWeight="Bold" Foreground="{StaticResource SubtextColor}"/>
                                                <TextBlock Grid.Column="1" Text="Dosage" FontSize="11" FontWeight="Bold" Foreground="{StaticResource SubtextColor}" Width="70" TextAlignment="Right" Margin="0,0,10,0"/>
                                                <TextBlock Grid.Column="2" Text="Status" FontSize="11" FontWeight="Bold" Foreground="{StaticResource SubtextColor}" Width="50" TextAlignment="Right"/>
                                            </Grid>
                                            <Border Height="1" Background="{StaticResource BorderColor}" Margin="0,0,0,6" Visibility="{Binding HasPrescribedDrugs, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                                            <ItemsControl ItemsSource="{Binding PrescribedDrugs}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Margin="0,4">
                                                                                                                         <Grid.ColumnDefinitions>
                                                                 <ColumnDefinition Width="*"/>
                                                                 <ColumnDefinition Width="Auto"/>
                                                                 <ColumnDefinition Width="Auto"/>
                                                             </Grid.ColumnDefinitions>
                                                            <TextBlock Grid.Column="0" Text="{Binding Name}" FontSize="12" Foreground="{StaticResource TextColor}" VerticalAlignment="Center" TextWrapping="Wrap"/>
                                                            <TextBlock Grid.Column="1" Text="{Binding Dose}" FontSize="12" Foreground="{StaticResource TextColor}" Width="70" TextAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                                                                                         <Border Grid.Column="2" Background="{DynamicResource SuccessBadgeBackground}" CornerRadius="4" Padding="6,2" VerticalAlignment="Center" HorizontalAlignment="Right" Width="50">
                                                                 <TextBlock Text="Active" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource SuccessBadgeText}" HorizontalAlignment="Center"/>
                                                             </Border>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            
                                            <!-- Empty state message -->
                                            <TextBlock Text="No medications prescribed in the current session." FontSize="11" Foreground="{StaticResource SubtextColor}" HorizontalAlignment="Center" Margin="0,15,0,0" TextAlignment="Center" TextWrapping="Wrap"
                                                       Visibility="{Binding HasNoPrescribedDrugs, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Upcoming Appointments Card -->
                                    <Border Style="{StaticResource CardBorder}" Margin="0,0,0,12" Padding="15">
                                        <StackPanel>
                                            <Grid Margin="0,0,0,10">
                                                <TextBlock Text="Upcoming Appointments" Style="{StaticResource Subheading}" VerticalAlignment="Center"/>
                                                <Button Style="{StaticResource LinkButton}" Content="Start Visit" FontSize="11" Foreground="{StaticResource PrimaryColor}" HorizontalAlignment="Right" VerticalAlignment="Center"
                                                        Command="{Binding SelectConsultationTabCommand}"/>
                                            </Grid>

                                            <!-- Appointment Info -->
                                            <StackPanel Orientation="Horizontal" Margin="0,5,0,0"
                                                        Visibility="{Binding ReturnDate, Converter={StaticResource NullToVisibilityConverter}}">
                                                                                                 <Border Width="40" Height="40" CornerRadius="8" Background="{DynamicResource SuccessBadgeBackground}" VerticalAlignment="Center" Margin="0,0,12,0">
                                                     <TextBlock Text="&#xE787;" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="{DynamicResource SuccessBadgeText}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                 </Border>
                                                <StackPanel VerticalAlignment="Center">
                                                    <TextBlock Text="Next Return Date" FontSize="11" Foreground="{StaticResource SubtextColor}" Margin="0,0,0,2"/>
                                                    <TextBlock Text="{Binding ReturnDate, StringFormat=\{0:dd/MM/yyyy\}}" FontSize="13" FontWeight="Bold" Foreground="{StaticResource TextColor}"/>
                                                </StackPanel>
                                            </StackPanel>

                                            <!-- No upcoming appointment -->
                                            <TextBlock Text="No upcoming return visit scheduled. You can set a return date in the Consultation tab." FontSize="11" Foreground="{StaticResource SubtextColor}" TextWrapping="Wrap"
                                                       Visibility="{Binding ReturnDate, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=inverse}"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </ScrollViewer>                        
                        <Button Grid.Row="4" Content="Cancel" Style="{StaticResource MaterialDesignOutlinedButton}" Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}" HorizontalAlignment="Right" Height="32" Padding="15,0" FontSize="11"/>
                    </Grid>
                </Border>

                <!-- Section Settings Switch Panel -->
                <Border Background="White" CornerRadius="12" Padding="20" Width="440" BorderBrush="#E2E8F0" BorderThickness="1"
                        Visibility="{Binding IsTemplateDialog, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="15"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Header -->
                        <TextBlock Grid.Row="0" Text="{Binding ActiveSettingsTitle}" FontSize="18" FontWeight="Bold" Foreground="{StaticResource PrimaryColor}"/>
                        <Separator Grid.Row="2" Margin="0,0,0,10" Background="#F1F5F9"/>

                        <!-- Switches Panel -->
                        <ScrollViewer Grid.Row="3" MaxHeight="320" VerticalScrollBarVisibility="Auto">
                            <Grid>
                                <!-- Obstetrics settings -->
                                <Grid Visibility="{Binding IsObstetricsSettingsActive, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Row 0 -->
                                    <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Margin="5,8">
                                        <ToggleButton Style="{StaticResource MaterialDesignSwitchToggleButton}" IsChecked="{Binding ObShowObstetricsInfo}" Width="38" Height="20" Margin="0,0,8,0"/>
                                        <TextBlock Text="Show Obstetrics Info" FontSize="11" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                    </StackPanel>
                                    <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Margin="5,8">
                                        <ToggleButton Style="{StaticResource MaterialDesignSwitchToggleButton}" IsChecked="{Binding ObShowLMP}" Width="38" Height="20" Margin="0,0,8,0"/>
                                        <TextBlock Text="Last Menstrual Period" FontSize="11" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                    </StackPanel>

                                    <!-- Row 1 -->
                                    <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal" Margin="5,8">
                                        <ToggleButton Style="{StaticResource MaterialDesignSwitchToggleButton}" IsChecked="{Binding ObShowLastUltrasound}" Width="38" Height="20" Margin="0,0,8,0"/>
                                        <TextBlock Text="Last Ultrasound" FontSize="11" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                    </StackPanel>
                                    <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="5,8">
                                        <ToggleButton Style="{StaticResource MaterialDesignSwitchToggleButton}" IsChecked="{Binding ObShowGravidity}" Width="38" Height="20" Margin="0,0,8,0"/>
                                        <TextBlock Text="Gravidity" FontSize="11" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                    </StackPanel>

                                    <!-- Row 2 -->
                                    <StackPanel Grid.Row="2" Grid.Column="0" Orientation="Horizontal" Margin="5,8">
                                        <ToggleButton Style="{StaticResource MaterialDesignSwitchToggleButton}" IsChecked="{Binding ObShowEDD}" Width="38" Height="20" Margin="0,0,8,0"/>
                                        <TextBlock Text="EDD" FontSize="11" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                    </StackPanel>
                                    <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Margin="5,8">
                                        <ToggleButton Style="{StaticResource MaterialDesignSwitchToggleButton}" IsChecked="{Binding ObShowParity}" Width="38" Height="20" Margin="0,0,8,0"/>
                                        <TextBlock Text="Parity" FontSize="11" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                    </StackPanel>

                                    <!-- Row 3 -->
                                    <StackPanel Grid.Row="3" Grid.Column="0" Orientation="Horizontal" Margin="5,8">
                                        <ToggleButton Style="{StaticResource MaterialDesignSwitchToggleButton}" IsChecked="{Binding ObShowGestationalAge}" Width="38" Height="20" Margin="0,0,8,0"/>
                                        <TextBlock Text="Gestational Age" FontSize="11" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                    </StackPanel>
                                    <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal" Margin="5,8">
