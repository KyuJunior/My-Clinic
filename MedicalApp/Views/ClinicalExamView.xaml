                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- Group 2: Reports -->
                            <Border BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Background="#F8FAFC" Padding="12" Margin="0,0,0,12">
                                <StackPanel>
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Reports" FontWeight="Bold" Foreground="#0091FF" FontSize="12" VerticalAlignment="Center"/>
                                        <ToggleButton Grid.Column="1" IsChecked="{Binding ShowReportsSection}" Style="{StaticResource MaterialDesignSwitchToggleButton}"/>
                                    </Grid>
                                    
                                    <StackPanel Visibility="{Binding ShowReportsSection, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <Border BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Background="White" Padding="12">
                                            <StackPanel HorizontalAlignment="Center">
                                                <TextBlock Text="Reports" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,6" HorizontalAlignment="Center"/>
                                                <Button Background="#0091FF" Foreground="White" Width="40" Height="28" Padding="0" BorderThickness="0"
                                                        materialDesign:ButtonAssist.CornerRadius="6" Command="{Binding OpenSectionSettingsCommand}" CommandParameter="Reports">
                                                    <TextBlock Text="&#xF168;" FontFamily="Segoe MDL2 Assets" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Button>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- Group 3: Dentist -->
                            <Border BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Background="#F8FAFC" Padding="12" Margin="0,0,0,12">
                                <StackPanel>
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Dentist" FontWeight="Bold" Foreground="#0091FF" FontSize="12" VerticalAlignment="Center"/>
                                        <ToggleButton Grid.Column="1" IsChecked="{Binding ShowDentistSection}" Style="{StaticResource MaterialDesignSwitchToggleButton}"/>
                                    </Grid>
                                    
                                    <StackPanel Visibility="{Binding ShowDentistSection, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <Border BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Background="White" Padding="12">
                                            <StackPanel HorizontalAlignment="Center">
                                                <TextBlock Text="Dentist" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,6" HorizontalAlignment="Center"/>
                                                <Button Background="#0091FF" Foreground="White" Width="40" Height="28" Padding="0" BorderThickness="0"
                                                        materialDesign:ButtonAssist.CornerRadius="6" Command="{Binding OpenSectionSettingsCommand}" CommandParameter="Dentist">
                                                    <TextBlock Text="&#xF168;" FontFamily="Segoe MDL2 Assets" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Button>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- Group 4: Vital Signs -->
                            <Border BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Background="#F8FAFC" Padding="12" Margin="0,0,0,12">
                                <StackPanel>
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Vital Signs" FontWeight="Bold" Foreground="#0091FF" FontSize="12" VerticalAlignment="Center"/>
                                        <ToggleButton Grid.Column="1" IsChecked="{Binding ShowVitalsSection}" Style="{StaticResource MaterialDesignSwitchToggleButton}"/>
                                    </Grid>
                                    
                                    <StackPanel Visibility="{Binding ShowVitalsSection, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <Border BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Background="White" Padding="12">
                                            <StackPanel HorizontalAlignment="Center">
                                                <TextBlock Text="Vital Signs" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,6" HorizontalAlignment="Center"/>
                                                <Button Background="#0091FF" Foreground="White" Width="40" Height="28" Padding="0" BorderThickness="0"
                                                        materialDesign:ButtonAssist.CornerRadius="6" Command="{Binding OpenSectionSettingsCommand}" CommandParameter="Vital Signs">
                                                    <TextBlock Text="&#xF168;" FontFamily="Segoe MDL2 Assets" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Button>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- Group 5: System Review -->
                            <Border BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Background="#F8FAFC" Padding="12" Margin="0,0,0,12">
                                <StackPanel>
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="System Review" FontWeight="Bold" Foreground="#0091FF" FontSize="12" VerticalAlignment="Center"/>
                                        <ToggleButton Grid.Column="1" IsChecked="{Binding ShowSystemReviewSection}" Style="{StaticResource MaterialDesignSwitchToggleButton}"/>
                                    </Grid>
                                    
                                    <StackPanel Visibility="{Binding ShowSystemReviewSection, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <Border BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Background="White" Padding="12">
                                            <StackPanel HorizontalAlignment="Center">
                                                <TextBlock Text="System Review" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,6" HorizontalAlignment="Center"/>
                                                <Button Background="#0091FF" Foreground="White" Width="40" Height="28" Padding="0" BorderThickness="0"
                                                        materialDesign:ButtonAssist.CornerRadius="6" Command="{Binding OpenSectionSettingsCommand}" CommandParameter="System Review">
                                                    <TextBlock Text="&#xF168;" FontFamily="Segoe MDL2 Assets" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Button>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- Group 6: Examination -->
                            <Border BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Background="#F8FAFC" Padding="12" Margin="0,0,0,12">
                                <StackPanel>
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Examination" FontWeight="Bold" Foreground="#0091FF" FontSize="12" VerticalAlignment="Center"/>
                                        <ToggleButton Grid.Column="1" IsChecked="{Binding ShowExaminationSection}" Style="{StaticResource MaterialDesignSwitchToggleButton}"/>
                                    </Grid>
                                    
                                    <StackPanel Visibility="{Binding ShowExaminationSection, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <Border BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Background="White" Padding="12">
                                            <StackPanel HorizontalAlignment="Center">
                                                <TextBlock Text="Examination" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,6" HorizontalAlignment="Center"/>
                                                <Button Background="#0091FF" Foreground="White" Width="40" Height="28" Padding="0" BorderThickness="0"
                                                        materialDesign:ButtonAssist.CornerRadius="6" Command="{Binding OpenSectionSettingsCommand}" CommandParameter="Examination">
                                                    <TextBlock Text="&#xF168;" FontFamily="Segoe MDL2 Assets" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Button>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- Group 7: Labs Section -->
                            <Border BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Background="#F8FAFC" Padding="12" Margin="0,0,0,12">
                                <StackPanel>
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Labs Section" FontWeight="Bold" Foreground="#0091FF" FontSize="12" VerticalAlignment="Center"/>
                                        <ToggleButton Grid.Column="1" IsChecked="{Binding ShowLabsSection}" Style="{StaticResource MaterialDesignSwitchToggleButton}"/>
                                    </Grid>
                                    
                                    <StackPanel Visibility="{Binding ShowLabsSection, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <Border BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Background="White" Padding="12">
                                            <StackPanel HorizontalAlignment="Center">
                                                <TextBlock Text="Labs Section" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,6" HorizontalAlignment="Center"/>
                                                <Button Background="#0091FF" Foreground="White" Width="40" Height="28" Padding="0" BorderThickness="0"
                                                        materialDesign:ButtonAssist.CornerRadius="6" Command="{Binding OpenSectionSettingsCommand}" CommandParameter="Labs Section">
                                                    <TextBlock Text="&#xF168;" FontFamily="Segoe MDL2 Assets" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Button>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- Group 8: Diagnosis -->
                            <Border BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Background="#F8FAFC" Padding="12" Margin="0,0,0,12">
                                <StackPanel>
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Diagnosis" FontWeight="Bold" Foreground="#0091FF" FontSize="12" VerticalAlignment="Center"/>
                                        <ToggleButton Grid.Column="1" IsChecked="{Binding ShowDiagnosis}" Style="{StaticResource MaterialDesignSwitchToggleButton}"/>
                                    </Grid>
                                    
                                    <StackPanel Visibility="{Binding ShowDiagnosis, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <Border BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Background="White" Padding="12">
                                            <StackPanel HorizontalAlignment="Center">
                                                <TextBlock Text="Diagnosis" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,6" HorizontalAlignment="Center"/>
                                                <Button Background="#0091FF" Foreground="White" Width="40" Height="28" Padding="0" BorderThickness="0"
                                                        materialDesign:ButtonAssist.CornerRadius="6" Command="{Binding OpenSectionSettingsCommand}" CommandParameter="Diagnosis">
                                                    <TextBlock Text="&#xF168;" FontFamily="Segoe MDL2 Assets" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Button>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- Group 9: Medications -->
                            <Border BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Background="#F8FAFC" Padding="12">
                                <StackPanel>
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Medications (Rx)" FontWeight="Bold" Foreground="#0091FF" FontSize="12" VerticalAlignment="Center"/>
                                        <ToggleButton Grid.Column="1" IsChecked="{Binding ShowDrugs}" Style="{StaticResource MaterialDesignSwitchToggleButton}"/>
                                    </Grid>
                                    
                                    <StackPanel Visibility="{Binding ShowDrugs, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <Border BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Background="White" Padding="12">
                                            <StackPanel HorizontalAlignment="Center">
                                                <TextBlock Text="Medications (Rx)" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,6" HorizontalAlignment="Center"/>
                                                <Button Background="#0091FF" Foreground="White" Width="40" Height="28" Padding="0" BorderThickness="0"
                                                        materialDesign:ButtonAssist.CornerRadius="6" Command="{Binding OpenSectionSettingsCommand}" CommandParameter="Medications (Rx)">
                                                    <TextBlock Text="&#xF168;" FontFamily="Segoe MDL2 Assets" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Button>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Grid>
        </Border>

            <!-- Column 1: Active Examination Form (Gear toggleable sections) -->
            <Border Grid.Column="1" Style="{StaticResource CardBorder}" Margin="0,0,15,0" VerticalAlignment="Stretch">
                <Grid>
                    <!-- Form layout (visible when patient is selected) -->
                    <Grid Visibility="{Binding CurrentPatient, Converter={StaticResource NullToVisibilityConverter}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/> <!-- Title Header + Gear -->
                            <RowDefinition Height="*"/>    <!-- Scrollable Cards content -->
                            <RowDefinition Height="Auto"/> <!-- Bottom Actions panel -->
                            <RowDefinition Height="Auto"/> <!-- Status Messages -->
                        </Grid.RowDefinitions>
                        <!-- Header Grid containing Patient Summary Card & Tabs -->
                        <StackPanel Grid.Row="0" Margin="5,5,5,15">
                            <!-- Patient Summary Header Card -->
                            <Border Style="{StaticResource CardBorder}" Padding="20,15" Margin="0,0,0,15">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/> <!-- Photo -->
                                        <ColumnDefinition Width="*"/>    <!-- Name, DOB, Age -->
                                        <ColumnDefinition Width="Auto"/> <!-- Gender, Contact -->
                                        <ColumnDefinition Width="Auto"/> <!-- Actions -->
                                    </Grid.ColumnDefinitions>

                                                                         <!-- Patient Photo/Avatar -->
                                     <Border Grid.Column="0" Width="54" Height="54" CornerRadius="27" Background="{DynamicResource InfoBadgeBackground}" VerticalAlignment="Center" Margin="0,0,15,0">
                                        <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="24" Foreground="{StaticResource PrimaryColor}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>

                                    <!-- Patient Name, DOB, Age -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding CurrentPatient.Name}" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextColor}"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                            <TextBlock Text="{Binding CurrentPatient.PatientId, StringFormat='#PAT{0:0000}'}" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource SubtextColor}"/>
                                            <TextBlock Text="  |  " FontSize="12" Foreground="{StaticResource SubtextColor}"/>
                                            <TextBlock Text="DOB: " FontSize="12" Foreground="{StaticResource SubtextColor}"/>
                                            <TextBlock Text="{Binding CurrentPatient.BirthDate, StringFormat=\{0:dd/MM/yyyy\}, TargetNullValue='N/A'}" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource SubtextColor}"/>
                                            <TextBlock Text="  ( " FontSize="12" Foreground="{StaticResource SubtextColor}"/>
                                            <TextBlock Text="Age " FontSize="12" Foreground="{StaticResource SubtextColor}"/>
                                            <TextBlock Text="{Binding CurrentPatient.Age}" FontSize="12" FontWeight="Bold" Foreground="{StaticResource PrimaryColor}"/>
                                            <TextBlock Text=" )" FontSize="12" Foreground="{StaticResource SubtextColor}"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Gender & Contact -->
                                    <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="0,0,30,0">
                                        <Grid Margin="0,0,0,4">
                                            <TextBlock Text="Gender: " FontSize="12" Foreground="{StaticResource SubtextColor}"/>
                                            <TextBlock Text="{Binding CurrentPatient.Gender}" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextColor}" Margin="60,0,0,0"/>
                                        </Grid>
                                        <Grid>
                                            <TextBlock Text="Contact: " FontSize="12" Foreground="{StaticResource SubtextColor}"/>
                                            <TextBlock Text="{Binding CurrentPatient.Phone}" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextColor}" Margin="60,0,0,0"/>
                                        </Grid>
                                    </StackPanel>

                                    <!-- Action Buttons -->
                                    <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                                        <Button Style="{StaticResource SecondaryButton}" Content="Schedule Visit" Margin="0,0,10,0" Padding="15,6" Height="34" Command="{Binding SelectConsultationTabCommand}"/>
                                        <Button Style="{StaticResource ModernButton}" Content="+ Add Note" Padding="15,6" Height="34" Command="{Binding SelectConsultationTabCommand}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Tab Bar & Settings Gear -->
                            <Grid Margin="0,0,0,5">
                                <StackPanel Orientation="Horizontal">
                                                                         <!-- Summary Tab -->
                                     <Grid Margin="0,0,25,0">
                                         <Button Content="Summary" Command="{Binding SelectSummaryTabCommand}">
                                             <Button.Style>
                                                 <Style TargetType="Button" BasedOn="{StaticResource TabSelectorButton}">
                                                     <Style.Triggers>
                                                         <DataTrigger Binding="{Binding IsSummaryTabActive}" Value="True">
                                                             <Setter Property="Foreground" Value="{StaticResource PrimaryColor}"/>
                                                             <Setter Property="FontWeight" Value="Bold"/>
                                                         </DataTrigger>
                                                     </Style.Triggers>
                                                 </Style>
                                             </Button.Style>
                                         </Button>
                                         <!-- Blue Underline -->
                                         <Border Height="3" Background="{StaticResource PrimaryColor}" VerticalAlignment="Bottom" Margin="0,28,0,0"
                                                 Visibility="{Binding IsSummaryTabActive, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                     </Grid>
 
                                     <!-- Consultation Tab -->
                                     <Grid>
                                         <Button Content="Consultation / Exam" Command="{Binding SelectConsultationTabCommand}">
                                             <Button.Style>
                                                 <Style TargetType="Button" BasedOn="{StaticResource TabSelectorButton}">
                                                     <Style.Triggers>
                                                         <DataTrigger Binding="{Binding IsSummaryTabActive}" Value="False">
                                                             <Setter Property="Foreground" Value="{StaticResource PrimaryColor}"/>
                                                             <Setter Property="FontWeight" Value="Bold"/>
                                                         </DataTrigger>
                                                     </Style.Triggers>
                                                 </Style>
                                             </Button.Style>
                                         </Button>
                                        <!-- Blue Underline -->
                                        <Border Height="3" Background="{StaticResource PrimaryColor}" VerticalAlignment="Bottom" Margin="0,28,0,0"
                                                Visibility="{Binding IsSummaryTabActive, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>
                                    </Grid>
                                </StackPanel>
                                
                                <!-- Toggle visibility settings gear -->
                                <Button HorizontalAlignment="Right" VerticalAlignment="Center" Width="36" Height="36" Padding="0" Tag="&#xE713;" ToolTip="Toggle Sidebar Sections Panel"
                                        Style="{StaticResource NavButton}" Command="{Binding ToggleSectionsTabCommand}"/>
                            </Grid>
                        </StackPanel>
                        <!-- Scrollable Cards content -->
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Style="{StaticResource MaterialDesignScrollViewer}">
                            <Grid Margin="5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.2*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <!-- Column 0: Clinical Notes & Diagnosis -->
                                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                    <!-- Chief Complaint & HPI Card -->
                                    <Border Style="{StaticResource CardBorder}" Margin="0,0,0,12" Visibility="{Binding ShowComplaint, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <StackPanel>
                                            <!-- Chief Complaint -->
                                            <StackPanel Margin="0,0,0,10" Visibility="{Binding CompShowChiefComplaint, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                <TextBlock Text="Chief Complaint" Style="{StaticResource Subheading}" Margin="0,0,0,5"/>
                                                <Grid>
                                                    <TextBox Style="{StaticResource MaterialDesignOutlinedTextBox}" materialDesign:TextFieldAssist.TextFieldCornerRadius="8" materialDesign:HintAssist.Hint="Type details here..." Text="{Binding ChiefComplaint, UpdateSourceTrigger=PropertyChanged}" Height="60" AcceptsReturn="True" TextWrapping="Wrap" Padding="10,8,30,8" VerticalContentAlignment="Top"/>
                                                    <Button Style="{StaticResource IconButton}" Tag="&#xE720;" ToolTip="Simulate voice input" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,8,8,0" Width="24" Height="24" Padding="0" FontSize="14" Foreground="{StaticResource SubtextColor}"
                                                            Command="{Binding SimulateVoiceInputCommand}" CommandParameter="Complaint"/>
                                                </Grid>
                                            </StackPanel>
 
                                            <!-- History of Present Illness (HPI) -->
                                            <StackPanel Visibility="{Binding CompShowHPI, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                <TextBlock Text="History of Present Illness (HPI)" Style="{StaticResource Subheading}" Margin="0,0,0,5"/>
                                                <Grid>
                                                    <TextBox Style="{StaticResource MaterialDesignOutlinedTextBox}" materialDesign:TextFieldAssist.TextFieldCornerRadius="8" materialDesign:HintAssist.Hint="Type details here..." Text="{Binding HistoryOfPresentIllness, UpdateSourceTrigger=PropertyChanged}" Height="60" AcceptsReturn="True" TextWrapping="Wrap" Padding="10,8,30,8" VerticalContentAlignment="Top"/>
                                                    <Button Style="{StaticResource IconButton}" Tag="&#xE720;" ToolTip="Simulate voice input" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,8,8,0" Width="24" Height="24" Padding="0" FontSize="14" Foreground="{StaticResource SubtextColor}"
                                                            Command="{Binding SimulateVoiceInputCommand}" CommandParameter="HPI"/>
                                                </Grid>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
 
                                    <!-- Physical Examination & Notes Card -->
                                    <Border Style="{StaticResource CardBorder}" Margin="0,0,0,12" Visibility="{Binding ShowPhysicalExam, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <StackPanel>
                                            <!-- Physical Examination -->
                                            <StackPanel Margin="0,0,0,10" Visibility="{Binding ExamShowGeneral, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                <TextBlock Text="Physical Examination Findings" Style="{StaticResource Subheading}" Margin="0,0,0,5"/>
                                                <Grid>
                                                    <TextBox Style="{StaticResource MaterialDesignOutlinedTextBox}" materialDesign:TextFieldAssist.TextFieldCornerRadius="8" materialDesign:HintAssist.Hint="Type details here..." Text="{Binding PhysicalExamination, UpdateSourceTrigger=PropertyChanged}" Height="60" AcceptsReturn="True" TextWrapping="Wrap" Padding="10,8,30,8" VerticalContentAlignment="Top"/>
                                                    <Button Style="{StaticResource IconButton}" Tag="&#xE720;" ToolTip="Simulate voice input" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,8,8,0" Width="24" Height="24" Padding="0" FontSize="14" Foreground="{StaticResource SubtextColor}"
                                                            Command="{Binding SimulateVoiceInputCommand}" CommandParameter="Exam"/>
                                                </Grid>
                                            </StackPanel>
 
                                            <!-- Treatment Plan -->
                                            <StackPanel Visibility="{Binding CompShowTreatmentPlan, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                <TextBlock Text="Treatment Plan / Notes" Style="{StaticResource Subheading}" Margin="0,0,0,5"/>
                                                <Grid>
                                                    <TextBox Style="{StaticResource MaterialDesignOutlinedTextBox}" materialDesign:TextFieldAssist.TextFieldCornerRadius="8" materialDesign:HintAssist.Hint="Type details here..." Text="{Binding TreatmentPlan, UpdateSourceTrigger=PropertyChanged}" Height="60" AcceptsReturn="True" TextWrapping="Wrap" Padding="10,8,30,8" VerticalContentAlignment="Top"/>
                                                    <Button Style="{StaticResource IconButton}" Tag="&#xE720;" ToolTip="Simulate voice input" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,8,8,0" Width="24" Height="24" Padding="0" FontSize="14" Foreground="{StaticResource SubtextColor}"
                                                            Command="{Binding SimulateVoiceInputCommand}" CommandParameter="Plan"/>
                                                </Grid>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
 
                                    <!-- Nutritional Card -->
                                    <Border Style="{StaticResource CardBorder}" Margin="0,0,0,12" 
                                            Visibility="{Binding ShowOverviewSection, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <StackPanel Visibility="{Binding ShowNutritionalSub, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <Grid Margin="0,0,0,10">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="&#xF16A;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="{StaticResource PrimaryColor}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                    <TextBlock Text="Nutritional Status" Style="{StaticResource Header2}" VerticalAlignment="Center" Margin="0"/>
                                                </StackPanel>
                                            </Grid>
                                            <WrapPanel Orientation="Horizontal" Margin="0,0,0,10">
                                                <!-- Weight -->
                                                <StackPanel Margin="0,0,10,10" Width="100" Visibility="{Binding NutriShowWeight, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                    <TextBlock Text="Weight (kg)" FontSize="11" Foreground="{StaticResource SubtextColor}" Margin="0,0,0,4"/>
                                                    <TextBox Style="{StaticResource MaterialDesignOutlinedTextBox}" materialDesign:TextFieldAssist.TextFieldCornerRadius="8" materialDesign:HintAssist.Hint="e.g. 70" Text="{Binding NutritionalWeight, UpdateSourceTrigger=PropertyChanged}" VerticalContentAlignment="Center" Height="40"/>
                                                </StackPanel>
                                                <!-- Height -->
                                                <StackPanel Margin="0,0,10,10" Width="100" Visibility="{Binding NutriShowHeight, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                    <TextBlock Text="Height (cm)" FontSize="11" Foreground="{StaticResource SubtextColor}" Margin="0,0,0,4"/>
                                                    <TextBox Style="{StaticResource MaterialDesignOutlinedTextBox}" materialDesign:TextFieldAssist.TextFieldCornerRadius="8" materialDesign:HintAssist.Hint="e.g. 175" Text="{Binding NutritionalHeight, UpdateSourceTrigger=PropertyChanged}" VerticalContentAlignment="Center" Height="40"/>
                                                </StackPanel>
                                                <!-- BMI badge -->
                                                <StackPanel Margin="0,0,10,10" Width="180" VerticalAlignment="Bottom" Visibility="{Binding NutriShowBMI, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                    <Border Background="{Binding BMIColor}" CornerRadius="8" Padding="10,6" Height="40">
                                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                            <TextBlock Text="BMI: " FontWeight="Bold" Foreground="White" FontSize="11"/>
                                                            <TextBlock Text="{Binding NutritionalBMI, TargetNullValue='N/A'}" FontWeight="Bold" Foreground="White" FontSize="11"/>
                                                            <TextBlock Text=" (" Foreground="White" FontSize="10"/>
                                                            <TextBlock Text="{Binding BMICategory}" Foreground="White" FontSize="10" FontWeight="SemiBold"/>
                                                            <TextBlock Text=")" Foreground="White" FontSize="10"/>
                                                        </StackPanel>
                                                    </Border>
                                                </StackPanel>
                                            </WrapPanel>
                                            <StackPanel Visibility="{Binding NutriShowDietNotes, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                <TextBlock Text="Dietary / Nutrition Notes" FontSize="11" Foreground="{StaticResource SubtextColor}" Margin="0,0,0,4"/>
                                                <TextBox Style="{StaticResource MaterialDesignOutlinedTextBox}" materialDesign:TextFieldAssist.TextFieldCornerRadius="8" materialDesign:HintAssist.Hint="E.g. low-carb diet, high protein" Text="{Binding NutritionalDietNotes, UpdateSourceTrigger=PropertyChanged}" Height="45" AcceptsReturn="True" TextWrapping="Wrap" Padding="10,6" VerticalContentAlignment="Top"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                    <!-- Obstetrics Card -->
                                    <Border Style="{StaticResource CardBorder}" Margin="0,0,0,12" 
                                            Visibility="{Binding ShowObstetricsCard, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <StackPanel>
                                            <Grid Margin="0,0,0,10">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="{StaticResource PrimaryColor}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                    <TextBlock Text="Obstetrics / Gynae History" Style="{StaticResource Header2}" VerticalAlignment="Center" Margin="0"/>
                                                </StackPanel>
                                            </Grid>
                                            
                                            <!-- Obstetrics Info Header Block -->
                                                                                         <Border CornerRadius="6" Background="{DynamicResource InfoAlertBackground}" BorderThickness="1" BorderBrush="{DynamicResource InfoAlertBorder}" Padding="12" Margin="0,0,0,12"
                                                     Visibility="{Binding ObShowObstetricsInfo, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                 <StackPanel>
                                                     <TextBlock Text="Maternal Health Record Info" FontWeight="Bold" Foreground="{DynamicResource InfoAlertText}" FontSize="11" Margin="0,0,0,4"/>
                                                     <TextBlock Text="Use the settings switch in the sidebar to configure visible fields for obstetric tracking. All toggles update in real time." FontSize="10" Foreground="{DynamicResource InfoAlertSubtext}" TextWrapping="Wrap"/>
                                                 </StackPanel>
                                            </Border>

                                            <!-- WrapPanel of obstetric inputs -->
                                            <WrapPanel Orientation="Horizontal">
                                                <!-- LMP Date -->
                                                <StackPanel Margin="0,0,10,10" Width="120" Visibility="{Binding ObShowLMP, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                    <TextBlock Text="LMP Date" FontSize="11" Foreground="{StaticResource SubtextColor}" Margin="0,0,0,4"/>
                                                    <DatePicker Style="{StaticResource MaterialDesignOutlinedDatePicker}" materialDesign:TextFieldAssist.TextFieldCornerRadius="8" SelectedDate="{Binding ObLMP}" VerticalContentAlignment="Center" Height="40"/>
                                                </StackPanel>

                                                <!-- Last Ultrasound -->
                                                <StackPanel Margin="0,0,10,10" Width="120" Visibility="{Binding ObShowLastUltrasound, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                    <TextBlock Text="Last Ultrasound" FontSize="11" Foreground="{StaticResource SubtextColor}" Margin="0,0,0,4"/>
                                                    <DatePicker Style="{StaticResource MaterialDesignOutlinedDatePicker}" materialDesign:TextFieldAssist.TextFieldCornerRadius="8" SelectedDate="{Binding ObLastUltrasound}" VerticalContentAlignment="Center" Height="40"/>
                                                </StackPanel>

                                                <!-- Gravida -->
                                                <StackPanel Margin="0,0,10,10" Width="80" Visibility="{Binding ObShowGravidity, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                    <TextBlock Text="Gravida (G)" FontSize="11" Foreground="{StaticResource SubtextColor}" Margin="0,0,0,4"/>
                                                    <TextBox Style="{StaticResource MaterialDesignOutlinedTextBox}" materialDesign:TextFieldAssist.TextFieldCornerRadius="8" materialDesign:HintAssist.Hint="e.g. 1" Text="{Binding ObGravida, UpdateSourceTrigger=PropertyChanged}" VerticalContentAlignment="Center" Height="40"/>
                                                </StackPanel>

                                                <!-- EDD -->
                                                <StackPanel Margin="0,0,10,10" Width="120" Visibility="{Binding ObShowEDD, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                    <TextBlock Text="EDD" FontSize="11" Foreground="{StaticResource SubtextColor}" Margin="0,0,0,4"/>
                                                    <DatePicker Style="{StaticResource MaterialDesignOutlinedDatePicker}" materialDesign:TextFieldAssist.TextFieldCornerRadius="8" SelectedDate="{Binding ObEDD}" VerticalContentAlignment="Center" Height="40"/>
                                                </StackPanel>

                                                <!-- Para -->
                                                <StackPanel Margin="0,0,10,10" Width="80" Visibility="{Binding ObShowParity, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                    <TextBlock Text="Para (P)" FontSize="11" Foreground="{StaticResource SubtextColor}" Margin="0,0,0,4"/>
                                                    <TextBox Style="{StaticResource MaterialDesignOutlinedTextBox}" materialDesign:TextFieldAssist.TextFieldCornerRadius="8" materialDesign:HintAssist.Hint="e.g. 0" Text="{Binding ObPara, UpdateSourceTrigger=PropertyChanged}" VerticalContentAlignment="Center" Height="40"/>
                                                </StackPanel>

                                                <!-- Gestational Age -->
                                                <StackPanel Margin="0,0,10,10" Width="120" Visibility="{Binding ObShowGestationalAge, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                    <TextBlock Text="Gestational Age" FontSize="11" Foreground="{StaticResource SubtextColor}" Margin="0,0,0,4"/>
                                                    <TextBox Style="{StaticResource MaterialDesignOutlinedTextBox}" materialDesign:TextFieldAssist.TextFieldCornerRadius="8" materialDesign:HintAssist.Hint="e.g. 24 weeks" Text="{Binding ObGestationalAge, UpdateSourceTrigger=PropertyChanged}" VerticalContentAlignment="Center" Height="40"/>
                                                </StackPanel>

                                                <!-- Abortion -->
                                                <StackPanel Margin="0,0,10,10" Width="80" Visibility="{Binding ObShowAbortion, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                    <TextBlock Text="Abortion (A)" FontSize="11" Foreground="{StaticResource SubtextColor}" Margin="0,0,0,4"/>
                                                    <TextBox Style="{StaticResource MaterialDesignOutlinedTextBox}" materialDesign:TextFieldAssist.TextFieldCornerRadius="8" materialDesign:HintAssist.Hint="e.g. 0" Text="{Binding ObAbortion, UpdateSourceTrigger=PropertyChanged}" VerticalContentAlignment="Center" Height="40"/>
                                                </StackPanel>

                                                <!-- Abortion Note -->
                                                <StackPanel Margin="0,0,10,10" Width="200" Visibility="{Binding ObShowAbortionNote, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                    <TextBlock Text="Abortion Note" FontSize="11" Foreground="{StaticResource SubtextColor}" Margin="0,0,0,4"/>
                                                    <TextBox Style="{StaticResource MaterialDesignOutlinedTextBox}" materialDesign:TextFieldAssist.TextFieldCornerRadius="8" materialDesign:HintAssist.Hint="Details..." Text="{Binding ObAbortionNote, UpdateSourceTrigger=PropertyChanged}" VerticalContentAlignment="Center" Height="40"/>
                                                </StackPanel>

                                                <!-- Last Ultrasound Note -->
                                                <StackPanel Margin="0,0,10,10" Width="200" Visibility="{Binding ObShowLastUltrasoundNote, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                    <TextBlock Text="Last Ultrasound Note" FontSize="11" Foreground="{StaticResource SubtextColor}" Margin="0,0,0,4"/>
                                                    <TextBox Style="{StaticResource MaterialDesignOutlinedTextBox}" materialDesign:TextFieldAssist.TextFieldCornerRadius="8" materialDesign:HintAssist.Hint="Details..." Text="{Binding ObLastUltrasoundNote, UpdateSourceTrigger=PropertyChanged}" VerticalContentAlignment="Center" Height="40"/>
                                                </StackPanel>
                                            </WrapPanel>
                                        </StackPanel>
                                    </Border>

                                    <!-- Visit Summary Card -->
                                    <Border Style="{StaticResource CardBorder}" Margin="0,0,0,12" 
                                             Visibility="{Binding ShowOverviewSection, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <StackPanel Visibility="{Binding SummeryShowVisitSummary, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <TextBlock Text="Visit Summary" Style="{StaticResource Subheading}" Margin="0,0,0,5"/>
                                            <TextBox Style="{StaticResource MaterialDesignOutlinedTextBox}" materialDesign:TextFieldAssist.TextFieldCornerRadius="8" materialDesign:HintAssist.Hint="Enter a brief summary of the visit..." Text="{Binding VisitSummaryText, UpdateSourceTrigger=PropertyChanged}" Height="50" AcceptsReturn="True" TextWrapping="Wrap" Padding="10,6" VerticalContentAlignment="Top"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Custom Fields Card -->
                                    <Border Style="{StaticResource CardBorder}" Margin="0,0,0,12" 
                                            Visibility="{Binding ShowOverviewSection, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <StackPanel Visibility="{Binding ShowCustomFieldsSub, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <Grid Margin="0,0,0,8">
                                                <TextBlock Text="Custom Fields" Style="{StaticResource Subheading}" VerticalAlignment="Center"/>
                                                <Button Style="{StaticResource MaterialDesignFlatButton}" Content="+ Add Field" Command="{Binding AddCustomFieldCommand}" FontSize="11" Padding="8,2" Height="24" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                            </Grid>
                                            <ItemsControl ItemsSource="{Binding CustomFields}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Margin="0,0,0,6">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="1.2*"/>
                                                                <ColumnDefinition Width="1.8*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBox Grid.Column="0" Style="{StaticResource MaterialDesignOutlinedTextBox}" materialDesign:TextFieldAssist.TextFieldCornerRadius="8" materialDesign:HintAssist.Hint="Label" Text="{Binding Label, UpdateSourceTrigger=PropertyChanged}" Height="36" VerticalContentAlignment="Center" Margin="0,0,5,0" Padding="8,0"/>
                                                            <TextBox Grid.Column="1" Style="{StaticResource MaterialDesignOutlinedTextBox}" materialDesign:TextFieldAssist.TextFieldCornerRadius="8" materialDesign:HintAssist.Hint="Value" Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}" Height="36" VerticalContentAlignment="Center" Margin="5,0,5,0" Padding="8,0"/>
                                                            <Button Grid.Column="2" Width="28" Height="28" Padding="0" Style="{StaticResource MaterialDesignFlatButton}" Command="{Binding DataContext.RemoveCustomFieldCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}">
                                                                <TextBlock Text="&#xE10A;" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="Red" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Button>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>

                                    <!-- Reports Card -->
                                    <Border Style="{StaticResource CardBorder}" Margin="0,0,0,12" 
                                            Visibility="{Binding ShowReportsSection, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <StackPanel Visibility="{Binding ShowReportsSub, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <TextBlock Text="Attached Medical Reports" Style="{StaticResource Subheading}" Margin="0,0,0,5"/>
                                            <Border BorderThickness="1" BorderBrush="{StaticResource BorderColor}" CornerRadius="8" Background="#F8FAFC" Padding="15" HorizontalAlignment="Stretch">
                                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <TextBlock Text="&#xE105;" FontFamily="Segoe MDL2 Assets" FontSize="24" Foreground="{StaticResource SubtextColor}" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                                                    <TextBlock Text="Drag and drop reports here or click below" FontSize="11" Foreground="{StaticResource SubtextColor}" HorizontalAlignment="Center"/>
                                                    <Button Style="{StaticResource MaterialDesignOutlinedButton}" Content="Browse Files" Height="28" Margin="0,10,0,0" Padding="12,2" FontSize="11"/>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </Border>

                                    <!-- Dentist Notes Card -->
                                    <Border Style="{StaticResource CardBorder}" Margin="0,0,0,12" 
                                             Visibility="{Binding ShowDentistSection, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <StackPanel Visibility="{Binding DentistShowNotes, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <TextBlock Text="Dental Charting / Dentist Notes" Style="{StaticResource Subheading}" Margin="0,0,0,5"/>
                                            <TextBox Style="{StaticResource MaterialDesignOutlinedTextBox}" materialDesign:TextFieldAssist.TextFieldCornerRadius="8" materialDesign:HintAssist.Hint="Enter teeth numbers, planned fillings, or dental observations..." Text="{Binding DentalNotesText, UpdateSourceTrigger=PropertyChanged}" Height="60" AcceptsReturn="True" TextWrapping="Wrap" Padding="10,8" VerticalContentAlignment="Top"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- System Review Card -->
                                    <Border Style="{StaticResource CardBorder}" Margin="0,0,0,12" 
                                             Visibility="{Binding ShowSystemReviewSection, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <StackPanel>
                                            <TextBlock Text="Review of Systems" Style="{StaticResource Header2}" Margin="0,0,0,10"/>
                                            <Grid Margin="0,0,0,6" Visibility="{Binding SysShowCVS, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="100"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="Cardiovascular:" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                <TextBox Grid.Column="1" Style="{StaticResource MaterialDesignOutlinedTextBox}" materialDesign:TextFieldAssist.TextFieldCornerRadius="8" materialDesign:HintAssist.Hint="Heart sounds, rate, rhythm..." Text="{Binding SysReviewCVS, UpdateSourceTrigger=PropertyChanged}" Padding="8,4" Height="32" VerticalContentAlignment="Center"/>
                                            </Grid>
                                            <Grid Margin="0,0,0,6" Visibility="{Binding SysShowResp, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="100"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="Respiratory:" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                <TextBox Grid.Column="1" Style="{StaticResource MaterialDesignOutlinedTextBox}" materialDesign:TextFieldAssist.TextFieldCornerRadius="8" materialDesign:HintAssist.Hint="Breath sounds, equal entry..." Text="{Binding SysReviewResp, UpdateSourceTrigger=PropertyChanged}" Padding="8,4" Height="32" VerticalContentAlignment="Center"/>
                                            </Grid>
                                            <Grid Margin="0,0,0,6" Visibility="{Binding SysShowGI, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="100"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="Gastrointestinal:" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                <TextBox Grid.Column="1" Style="{StaticResource MaterialDesignOutlinedTextBox}" materialDesign:TextFieldAssist.TextFieldCornerRadius="8" materialDesign:HintAssist.Hint="Abdomen tenderness, bowel sounds..." Text="{Binding SysReviewGI, UpdateSourceTrigger=PropertyChanged}" Padding="8,4" Height="32" VerticalContentAlignment="Center"/>
                                            </Grid>
                                            <Grid Margin="0,0,0,6" Visibility="{Binding SysShowCNS, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="100"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="Neurological:" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                <TextBox Grid.Column="1" Style="{StaticResource MaterialDesignOutlinedTextBox}" materialDesign:TextFieldAssist.TextFieldCornerRadius="8" materialDesign:HintAssist.Hint="Cranial nerves, reflexes..." Text="{Binding SysReviewCNS, UpdateSourceTrigger=PropertyChanged}" Padding="8,4" Height="32" VerticalContentAlignment="Center"/>
                                            </Grid>
                                            <Grid Margin="0,0,0,6" Visibility="{Binding SysShowOther, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="100"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="Other Systems:" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                <TextBox Grid.Column="1" Style="{StaticResource MaterialDesignOutlinedTextBox}" materialDesign:TextFieldAssist.TextFieldCornerRadius="8" materialDesign:HintAssist.Hint="Musculoskeletal, skin, general..." Text="{Binding SysReviewOther, UpdateSourceTrigger=PropertyChanged}" Padding="8,4" Height="32" VerticalContentAlignment="Center"/>
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                    <!-- Physical Examination Details Card -->
                                    <Border Style="{StaticResource CardBorder}" Margin="0,0,0,12" 
                                            Visibility="{Binding ShowExaminationSection, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Margin="0,0,8,0" Visibility="{Binding ShowPositiveSignsSub, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                <TextBlock Text="Positive Signs (+ve)" FontSize="11" FontWeight="SemiBold" Foreground="#EF4444" Margin="0,0,0,4"/>
                                                <TextBox Style="{StaticResource MaterialDesignOutlinedTextBox}" materialDesign:TextFieldAssist.TextFieldCornerRadius="8" materialDesign:HintAssist.Hint="Abnormal findings..." Text="{Binding ExamPositiveSigns, UpdateSourceTrigger=PropertyChanged}" Height="60" AcceptsReturn="True" TextWrapping="Wrap" Padding="8,6" VerticalContentAlignment="Top"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Margin="4,0,4,0" Visibility="{Binding ShowExamNotesSub, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                <TextBlock Text="General Exam Notes" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource SubtextColor}" Margin="0,0,0,4"/>
                                                <TextBox Style="{StaticResource MaterialDesignOutlinedTextBox}" materialDesign:TextFieldAssist.TextFieldCornerRadius="8" materialDesign:HintAssist.Hint="Notes..." Text="{Binding ExamNotes, UpdateSourceTrigger=PropertyChanged}" Height="60" AcceptsReturn="True" TextWrapping="Wrap" Padding="8,6" VerticalContentAlignment="Top"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2" Margin="8,0,0,0" Visibility="{Binding ShowNegativeSignsSub, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                <TextBlock Text="Negative Signs (-ve)" FontSize="11" FontWeight="SemiBold" Foreground="#10B981" Margin="0,0,0,4"/>
                                                <TextBox Style="{StaticResource MaterialDesignOutlinedTextBox}" materialDesign:TextFieldAssist.TextFieldCornerRadius="8" materialDesign:HintAssist.Hint="Checked and absent..." Text="{Binding ExamNegativeSigns, UpdateSourceTrigger=PropertyChanged}" Height="60" AcceptsReturn="True" TextWrapping="Wrap" Padding="8,6" VerticalContentAlignment="Top"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <!-- Diagnosis Card -->
                                    <Border Style="{StaticResource CardBorder}" Margin="0,0,0,12" Visibility="{Binding ShowDiagnosis, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <StackPanel>
                                            <!-- Header -->
                                            <Grid Margin="0,0,0,8">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="&#xEA86;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="{StaticResource PrimaryColor}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                    <TextBlock Text="Diagnosis" Style="{StaticResource Subheading}" VerticalAlignment="Center"/>
                                                </StackPanel>
                                                <Button Style="{StaticResource NavButton}" Content="&#xE81C; History" FontSize="11" Padding="8,4" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                            </Grid>
                                            <!-- Dx, Return Date & Notes Fields -->
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- Diseases Lookup -->
                                                <StackPanel Margin="0,0,10,10" Visibility="{Binding DiagShowDiseases, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                    <TextBlock Text="Dx (Diseases)" FontSize="11" Foreground="{StaticResource SubtextColor}" Margin="0,0,0,4"/>
                                                    <TextBox Style="{StaticResource MaterialDesignOutlinedTextBox}" materialDesign:TextFieldAssist.TextFieldCornerRadius="8" materialDesign:HintAssist.Hint="Diseases" Text="{Binding Diagnosis, UpdateSourceTrigger=PropertyChanged}" VerticalContentAlignment="Center"/>
                                                </StackPanel>

                                                <!-- Return Date -->
                                                <StackPanel Grid.Column="1" Margin="10,0,0,10">
                                                    <TextBlock Text="Return date" FontSize="11" Foreground="{StaticResource SubtextColor}" Margin="0,0,0,4"/>
                                                    <DatePicker Style="{StaticResource MaterialDesignOutlinedDatePicker}" materialDesign:TextFieldAssist.TextFieldCornerRadius="8" SelectedDate="{Binding ReturnDate}" VerticalContentAlignment="Center"/>
                                                </StackPanel>

                                                <!-- Diagnosis Notes / Text -->
                                                <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Margin="0,0,0,0" Visibility="{Binding DiagShowNotes, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                    <TextBlock Text="Diagnosis Notes / Text" FontSize="11" Foreground="{StaticResource SubtextColor}" Margin="0,0,0,4"/>
                                                    <TextBox Style="{StaticResource MaterialDesignOutlinedTextBox}" materialDesign:TextFieldAssist.TextFieldCornerRadius="8" materialDesign:HintAssist.Hint="Clinical diagnosis details, stages, notes..." Text="{Binding DiagnosisNotes, UpdateSourceTrigger=PropertyChanged}" Height="60" AcceptsReturn="True" TextWrapping="Wrap" Padding="10,8" VerticalContentAlignment="Top"/>
                                                </StackPanel>
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>

                                <!-- Column 1: Vitals, Investigations & Drugs -->
                                <StackPanel Grid.Column="1">
                                                                        <!-- Vital Signs Card -->
                                    <Border Style="{StaticResource CardBorder}" Margin="0,0,0,12" Visibility="{Binding ShowVitals, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <StackPanel>
                                            <!-- Header with stable toggle -->
                                            <Grid Margin="0,0,0,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="&#xEC5A;" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="{StaticResource PrimaryColor}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                    <TextBlock Text="Vital Signs" Style="{StaticResource Subheading}" VerticalAlignment="Center"/>
                                                </StackPanel>
                                                <Button Grid.Column="1" Style="{StaticResource NavButton}" Content="&#xE81C; History" FontSize="11" Margin="0,0,15,0" Padding="8,4" VerticalAlignment="Center"/>
                                                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                                    <TextBlock Text="Vitally Stable" FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                    <CheckBox IsChecked="{Binding IsVitallyStable}" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Grid>
                                            
                                            <!-- Vitals Input WrapPanel -->
                                            <WrapPanel Orientation="Horizontal">
                                                <!-- SBP & DBP (Blood Pressure) -->
                                                <StackPanel Margin="0,0,10,10" Width="100" Visibility="{Binding VitalsShowBP, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                    <TextBlock Text="SBP (mmHg)" FontSize="11" Foreground="{StaticResource SubtextColor}" Margin="0,0,0,4"/>
                                                    <TextBox Style="{StaticResource MaterialDesignOutlinedTextBox}" materialDesign:TextFieldAssist.TextFieldCornerRadius="8" materialDesign:HintAssist.Hint="e.g. 120" Text="{Binding VitalSBP, UpdateSourceTrigger=PropertyChanged}" Height="40" VerticalContentAlignment="Center"/>
                                                </StackPanel>
                                                <StackPanel Margin="0,0,10,10" Width="100" Visibility="{Binding VitalsShowBP, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                    <TextBlock Text="DBP (mmHg)" FontSize="11" Foreground="{StaticResource SubtextColor}" Margin="0,0,0,4"/>
                                                    <TextBox Style="{StaticResource MaterialDesignOutlinedTextBox}" materialDesign:TextFieldAssist.TextFieldCornerRadius="8" materialDesign:HintAssist.Hint="e.g. 80" Text="{Binding VitalDBP, UpdateSourceTrigger=PropertyChanged}" Height="40" VerticalContentAlignment="Center"/>
                                                </StackPanel>

                                                <!-- Heart Rate (HR) -->
                                                <StackPanel Margin="0,0,10,10" Width="90" Visibility="{Binding VitalsShowHR, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                    <TextBlock Text="HR (bpm)" FontSize="11" Foreground="{StaticResource SubtextColor}" Margin="0,0,0,4"/>
                                                    <TextBox Style="{StaticResource MaterialDesignOutlinedTextBox}" materialDesign:TextFieldAssist.TextFieldCornerRadius="8" materialDesign:HintAssist.Hint="e.g. 75" Text="{Binding VitalHR, UpdateSourceTrigger=PropertyChanged}" Height="40" VerticalContentAlignment="Center"/>
                                                </StackPanel>

                                                <!-- Oxygen Saturation (SpO2) -->
                                                <StackPanel Margin="0,0,10,10" Width="90" Visibility="{Binding VitalsShowSpO2, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                    <TextBlock Text="SPO2 (%)" FontSize="11" Foreground="{StaticResource SubtextColor}" Margin="0,0,0,4"/>
                                                    <TextBox Style="{StaticResource MaterialDesignOutlinedTextBox}" materialDesign:TextFieldAssist.TextFieldCornerRadius="8" materialDesign:HintAssist.Hint="e.g. 98" Text="{Binding VitalSPO2, UpdateSourceTrigger=PropertyChanged}" Height="40" VerticalContentAlignment="Center"/>
                                                </StackPanel>

                                                <!-- Body Temperature (Temp) -->
                                                <StackPanel Margin="0,0,10,10" Width="90" Visibility="{Binding VitalsShowTemp, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                    <TextBlock Text="Temp (°C)" FontSize="11" Foreground="{StaticResource SubtextColor}" Margin="0,0,0,4"/>
                                                    <TextBox Style="{StaticResource MaterialDesignOutlinedTextBox}" materialDesign:TextFieldAssist.TextFieldCornerRadius="8" materialDesign:HintAssist.Hint="e.g. 37.0" Text="{Binding VitalTemp, UpdateSourceTrigger=PropertyChanged}" Height="40" VerticalContentAlignment="Center"/>
                                                </StackPanel>

                                                <!-- Blood Sugar (BS) -->
                                                <StackPanel Margin="0,0,10,10" Width="100" Visibility="{Binding VitalsShowBS, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                    <TextBlock Text="BS (mg/dL)" FontSize="11" Foreground="{StaticResource SubtextColor}" Margin="0,0,0,4"/>
                                                    <TextBox Style="{StaticResource MaterialDesignOutlinedTextBox}" materialDesign:TextFieldAssist.TextFieldCornerRadius="8" materialDesign:HintAssist.Hint="e.g. 100" Text="{Binding VitalBS, UpdateSourceTrigger=PropertyChanged}" Height="40" VerticalContentAlignment="Center"/>
                                                </StackPanel>

                                                <!-- RR (bpm) -->
                                                <StackPanel Margin="0,0,10,10" Width="90">
                                                    <TextBlock Text="RR (bpm)" FontSize="11" Foreground="{StaticResource SubtextColor}" Margin="0,0,0,4"/>
                                                    <TextBox Style="{StaticResource MaterialDesignOutlinedTextBox}" materialDesign:TextFieldAssist.TextFieldCornerRadius="8" materialDesign:HintAssist.Hint="e.g. 16" Text="{Binding VitalRR, UpdateSourceTrigger=PropertyChanged}" Height="40" VerticalContentAlignment="Center"/>
                                                </StackPanel>
                                            </WrapPanel>
                                        </StackPanel>
                                    </Border>

                                    <!-- Investigation & Imaging Card -->
                                    <Border Style="{StaticResource CardBorder}" Margin="0,0,0,12" Visibility="{Binding ShowInvestigation, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <StackPanel>
                                                                                         <StackPanel Margin="0,0,0,12" Visibility="{Binding LabsShowInvestigations, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                    <TextBlock Text="&#xE9F9;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="{StaticResource PrimaryColor}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                    <TextBlock Text="Investigations" Style="{StaticResource Subheading}" VerticalAlignment="Center"/>
                                                </StackPanel>
                                                <Grid Margin="0,0,0,10">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
