                                                                    <Button Grid.Column="0" Style="{StaticResource LinkButton}" Content="Attach File" Command="{Binding DataContext.UploadImagingFileCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Foreground="{StaticResource PrimaryColor}" FontSize="11" Margin="0,0,10,0"
                                                                            Visibility="{Binding AttachmentPath, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=inverse}"/>
                                                                    
                                                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Visibility="{Binding AttachmentPath, Converter={StaticResource NullToVisibilityConverter}}">
                                                                        <TextBlock Text="&#xE71B;" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center" Foreground="#0284C7" Margin="0,0,6,0" FontSize="11"/>
                                                                        <Button Content="{Binding AttachmentName}" Style="{StaticResource LinkButton}"
                                                                                Command="{Binding DataContext.OpenAttachmentCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding AttachmentPath}" MaxWidth="150" HorizontalAlignment="Left"/>
