                                                         <Grid>
                                                             <Grid.ColumnDefinitions>
                                                                 <ColumnDefinition Width="Auto"/>
                                                                 <ColumnDefinition Width="*"/>
                                                                 <ColumnDefinition Width="Auto"/>
                                                             </Grid.ColumnDefinitions>
                                                             <!-- Status dot / Time -->
                                                             <StackPanel Grid.Column="0" Width="60" Margin="0,0,10,0" VerticalAlignment="Center">
                                                                 <TextBlock Text="10:30 AM" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource InfoAlertText}"/>
                                                                 <TextBlock Text="Waitlist" FontSize="9" Foreground="{DynamicResource InfoAlertSubtext}"/>
                                                             </StackPanel>
                                                             <!-- Info -->
                                                             <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                                 <TextBlock Text="{Binding PatientName}" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource InfoAlertText}"/>
                                                                 <TextBlock Text="{Binding Patient.Gender}" FontSize="10" Foreground="{DynamicResource InfoAlertSubtext}"/>
                                                             </StackPanel>
                                                             <!-- Action -->
                                                             <Button Grid.Column="2" Style="{StaticResource ModernButton}" Content="Start" FontSize="11" Padding="12,5" Height="28" VerticalAlignment="Center"
                                                                     Command="{Binding DataContext.StartSessionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}"/>
                                                         </Grid>
                                                     </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        
                                        <!-- Empty state -->
                                        <TextBlock Text="No patients matching your search query." FontSize="12" Foreground="{StaticResource SubtextColor}" HorizontalAlignment="Center" Margin="0,40,0,0"
                                                   Visibility="{Binding HasNoFilteredWaitingPatients, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                    </Grid>
                    </ScrollViewer>

                    <!-- Row 2: Coming Soon / Features List (Visible when IsSoonTabActive is true) -->
                    <ScrollViewer Grid.Row="1" Visibility="{Binding IsSoonTabActive, Converter={StaticResource BooleanToVisibilityConverter}}" VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="0,0,0,10">
                            <TextBlock Text="Coming Soon" Style="{StaticResource Header2}" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                            
                            <!-- Feature 1: Visits Kanban Queue Board -->
                            <Border BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Background="#F8FAFC" Padding="12" Margin="0,0,0,10">
                                <StackPanel>
                                    <Grid Margin="0,0,0,6">
                                        <TextBlock Text="Visits Kanban Board" FontWeight="Bold" Foreground="{StaticResource TextColor}" FontSize="12"/>
                                        <Border Background="#FEE2E2" CornerRadius="4" Padding="6,2" HorizontalAlignment="Right" VerticalAlignment="Center">
                                            <TextBlock Text="Soon" FontSize="9" FontWeight="Bold" Foreground="#EF4444"/>
                                        </Border>
                                    </Grid>
                                    <TextBlock Text="Interactive drag-and-drop board to route patients through consultation rooms." FontSize="10" Foreground="{StaticResource SubtextColor}" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <!-- Feature 2: Procedures Ledger -->
                            <Border BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Background="#F8FAFC" Padding="12" Margin="0,0,0,10">
                                <StackPanel>
                                    <Grid Margin="0,0,0,6">
                                        <TextBlock Text="Procedures &amp; Splits" FontWeight="Bold" Foreground="{StaticResource TextColor}" FontSize="12"/>
                                        <Border Background="#FEE2E2" CornerRadius="4" Padding="6,2" HorizontalAlignment="Right" VerticalAlignment="Center">
                                            <TextBlock Text="Soon" FontSize="9" FontWeight="Bold" Foreground="#EF4444"/>
                                        </Border>
                                    </Grid>
                                    <TextBlock Text="Log minor surgical procedures, inventory usage, and doctor revenue splits." FontSize="10" Foreground="{StaticResource SubtextColor}" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <!-- Feature 3: Digital Note Board -->
                            <Border BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Background="#F8FAFC" Padding="12" Margin="0,0,0,10">
                                <StackPanel>
                                    <Grid Margin="0,0,0,6">
                                        <TextBlock Text="Digital Note Board" FontWeight="Bold" Foreground="{StaticResource TextColor}" FontSize="12"/>
                                        <Border Background="#FEE2E2" CornerRadius="4" Padding="6,2" HorizontalAlignment="Right" VerticalAlignment="Center">
                                            <TextBlock Text="Soon" FontSize="9" FontWeight="Bold" Foreground="#EF4444"/>
                                        </Border>
                                    </Grid>
                                    <TextBlock Text="Digital whiteboard drawing canvas supporting active pen inputs across multiple pages." FontSize="10" Foreground="{StaticResource SubtextColor}" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <!-- Feature 4: Surgery Tracker -->
                            <Border BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Background="#F8FAFC" Padding="12" Margin="0,0,0,10">
                                <StackPanel>
                                    <Grid Margin="0,0,0,6">
                                        <TextBlock Text="Surgery Tracker" FontWeight="Bold" Foreground="{StaticResource TextColor}" FontSize="12"/>
                                        <Border Background="#FEE2E2" CornerRadius="4" Padding="6,2" HorizontalAlignment="Right" VerticalAlignment="Center">
                                            <TextBlock Text="Soon" FontSize="9" FontWeight="Bold" Foreground="#EF4444"/>
                                        </Border>
                                    </Grid>
                                    <TextBlock Text="Record full surgical histories, anesthesia details, assistants, and scan attachments." FontSize="10" Foreground="{StaticResource SubtextColor}" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <!-- Feature 5: Collaboration Chat -->
                            <Border BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Background="#F8FAFC" Padding="12" Margin="0,0,0,10">
                                <StackPanel>
                                    <Grid Margin="0,0,0,6">
                                        <TextBlock Text="Collaboration Chat" FontWeight="Bold" Foreground="{StaticResource TextColor}" FontSize="12"/>
                                        <Border Background="#FEE2E2" CornerRadius="4" Padding="6,2" HorizontalAlignment="Right" VerticalAlignment="Center">
                                            <TextBlock Text="Soon" FontSize="9" FontWeight="Bold" Foreground="#EF4444"/>
                                        </Border>
                                    </Grid>
                                    <TextBlock Text="Real-time team group chat and private direct messaging overlay." FontSize="10" Foreground="{StaticResource SubtextColor}" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <!-- Feature 6: Medscape Drug Check -->
                            <Border BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Background="#F8FAFC" Padding="12" Margin="0,0,0,10">
                                <StackPanel>
                                    <Grid Margin="0,0,0,6">
                                        <TextBlock Text="Medscape Interactions" FontWeight="Bold" Foreground="{StaticResource TextColor}" FontSize="12"/>
                                        <Border Background="#FEE2E2" CornerRadius="4" Padding="6,2" HorizontalAlignment="Right" VerticalAlignment="Center">
                                            <TextBlock Text="Soon" FontSize="9" FontWeight="Bold" Foreground="#EF4444"/>
                                        </Border>
                                    </Grid>
                                    <TextBlock Text="Automatic warning flags for potential drug-drug interactions using Medscape references." FontSize="10" Foreground="{StaticResource SubtextColor}" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <!-- Feature 7: Desktop Helper App -->
                            <Border BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Background="#F8FAFC" Padding="12" Margin="0,0,0,10">
                                <StackPanel>
                                    <Grid Margin="0,0,0,6">
                                        <TextBlock Text="Clinic Desktop Helper" FontWeight="Bold" Foreground="{StaticResource TextColor}" FontSize="12"/>
                                        <Border Background="#FEE2E2" CornerRadius="4" Padding="6,2" HorizontalAlignment="Right" VerticalAlignment="Center">
                                            <TextBlock Text="Soon" FontSize="9" FontWeight="Bold" Foreground="#EF4444"/>
                                        </Border>
                                    </Grid>
                                    <TextBlock Text="Silent printing, physical scanner triggers, and RadiAnt DICOM medical imaging links." FontSize="10" Foreground="{StaticResource SubtextColor}" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>                        </Border>

                        <!-- Card 2: Pending Visits (On Hold / In Progress) -->
                        <Border x:Name="Card2Border" Grid.Column="1" Style="{StaticResource CardBorder}" Margin="10,0,10,0" Height="300">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0" Margin="0,0,0,12">
                                    <TextBlock Text="Pending Visits" Style="{StaticResource Subheading}" FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                                    <Border Background="{DynamicResource HighlightCardBackground}" CornerRadius="10" Padding="6,2" HorizontalAlignment="Right" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding NotFinishedPatients.Count, StringFormat='\{0\} active'}" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource HighlightCardText}"/>
                                    </Border>
                                </Grid>

                                <!-- Scrollable list of pending visits -->
                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Style="{StaticResource MaterialDesignScrollViewer}">
                                    <Grid>
                                        <!-- Real Queue items -->
                                        <ItemsControl ItemsSource="{Binding NotFinishedPatients}" 
                                                      Visibility="{Binding HasHoldPatients, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border BorderBrush="{DynamicResource HighlightCardBorder}" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,10" Background="{DynamicResource HighlightCardBackground}">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding PatientName}" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource HighlightCardText}"/>
                                                                <TextBlock Text="Active Consultation session" FontSize="10" Foreground="{DynamicResource HighlightCardSubtext}" Margin="0,2,0,0"/>
                                                            </StackPanel>
                                                            <Button Grid.Column="1" Style="{StaticResource WarningButton}" Content="Resume" 
                                                                    Command="{Binding DataContext.StartSessionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                                    CommandParameter="{Binding}" Padding="12,5" Height="28" FontSize="11" VerticalAlignment="Center"/>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <!-- Empty state: Caught up! -->
                                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,15,0,0"
                                                    Visibility="{Binding HasNoHoldPatients, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <Border Width="50" Height="50" CornerRadius="25" Background="{DynamicResource SuccessBadgeBackground}" HorizontalAlignment="Center" Margin="0,0,0,10">
                                                <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="20" Foreground="{DynamicResource SuccessBadgeText}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <TextBlock Text="You're all caught up!" FontSize="15" FontWeight="Bold" Foreground="{StaticResource TextColor}" HorizontalAlignment="Center"/>
                                            <TextBlock Text="No pending visits." FontSize="11" Foreground="{StaticResource SubtextColor}" HorizontalAlignment="Center" Margin="0,2,0,15"/>
                                            <Button Style="{StaticResource SecondaryButton}" Content="View Pending" Height="30" FontSize="11" Padding="12,0"/>
                                        </StackPanel>
                                    </Grid>
                                </ScrollViewer>
                            </Grid>
                        </Border>

                        <!-- Card 3: Alerts & Reminders -->
                        <Border Grid.Column="2" Style="{StaticResource CardBorder}" Margin="10,0,0,0" Height="300" Padding="15">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="Alerts &amp; Tasks" Style="{StaticResource Subheading}" FontSize="14" FontWeight="Bold" Margin="0,0,0,12"/>
                                
                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Style="{StaticResource MaterialDesignScrollViewer}">
                                    <StackPanel>
                                        <!-- Alert 1 -->
                                        <Border Background="{DynamicResource InfoAlertBackground}" BorderBrush="{DynamicResource InfoAlertBorder}" BorderThickness="1" CornerRadius="8" Padding="10" Margin="0,0,0,8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="&#xE715;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{DynamicResource InfoAlertIcon}" Margin="0,2,8,0" VerticalAlignment="Top"/>
                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Text="All pending tasks completed." FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource InfoAlertText}"/>
                                                    <TextBlock Text="5 min ago" FontSize="9" Foreground="{DynamicResource InfoAlertSubtext}" Margin="0,2,0,0"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>

                                        <!-- Alert 2 -->
                                        <Border Background="{DynamicResource BackgroundColor}" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" CornerRadius="8" Padding="10" Margin="0,0,0,8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="&#xE787;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{StaticResource SubtextColor}" Margin="0,2,8,0" VerticalAlignment="Top"/>
                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Text="Dr. Yaser scheduled follow-up" FontSize="11" Foreground="{StaticResource TextColor}" TextWrapping="Wrap"/>
                                                    <TextBlock Text="Today, 12:00 PM" FontSize="9" Foreground="{StaticResource SubtextColor}" Margin="0,2,0,0"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>

                                        <!-- Alert 3 -->
                                        <Border Background="{DynamicResource BackgroundColor}" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" CornerRadius="8" Padding="10">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{StaticResource SubtextColor}" Margin="0,2,8,0" VerticalAlignment="Top"/>
                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Text="Referral for Lisa Chen updated" FontSize="11" Foreground="{StaticResource TextColor}" TextWrapping="Wrap"/>
                                                    <TextBlock Text="1 hour ago" FontSize="9" Foreground="{StaticResource SubtextColor}" Margin="0,2,0,0"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </StackPanel>
                                </ScrollViewer>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- Bottom Row: 2-column Layout (Key Metrics & Recent Patients) -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.2*"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Key Metrics Card (Bar Chart & Donut Chart) -->
                        <Border Grid.Column="0" Style="{StaticResource CardBorder}" Margin="0,0,10,0" Height="260">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0" Margin="0,0,0,15">
                                    <TextBlock Text="Key Metrics" Style="{StaticResource Subheading}" FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                                    <Border Background="#F1F5F9" CornerRadius="6" Padding="8,4" HorizontalAlignment="Right" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="Trend" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextColor}"/>
                                            <TextBlock Text="&#xE70D;" FontFamily="Segoe MDL2 Assets" FontSize="8" Foreground="{StaticResource SubtextColor}" VerticalAlignment="Center" Margin="6,2,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <Grid Grid.Row="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1.2*"/> <!-- Bar Chart -->
                                        <ColumnDefinition Width="1*"/>   <!-- Donut Chart -->
                                    </Grid.ColumnDefinitions>

                                    <!-- Bar Chart: Patients Seen This Week -->
                                    <Grid Grid.Column="0" Margin="0,0,20,0">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Text="Patients Seen This Week" FontSize="11" Foreground="{StaticResource SubtextColor}" Margin="0,0,0,10"/>
                                        
                                        <!-- Vertical Bars Container -->
                                        <Grid Grid.Row="1" VerticalAlignment="Bottom" Height="110">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <!-- Mon -->
                                            <Border Grid.Column="0" Background="{DynamicResource SubtextColor}" CornerRadius="4,4,0,0" Height="50" VerticalAlignment="Bottom" Margin="4,0" ToolTip="Monday: 10"/>
                                            <!-- Tue -->
                                            <Border Grid.Column="1" Background="{DynamicResource PrimaryColor}" CornerRadius="4,4,0,0" Height="80" VerticalAlignment="Bottom" Margin="4,0" ToolTip="Tuesday: 16"/>
                                            <!-- Wed -->
                                            <Border Grid.Column="2" Background="{DynamicResource PrimaryColor}" CornerRadius="4,4,0,0" Height="100" VerticalAlignment="Bottom" Margin="4,0" ToolTip="Wednesday: 20"/>
                                            <!-- Thu -->
                                            <Border Grid.Column="3" Background="{DynamicResource SubtextColor}" CornerRadius="4,4,0,0" Height="40" VerticalAlignment="Bottom" Margin="4,0" ToolTip="Thursday: 8"/>
                                            <!-- Fri -->
                                            <Border Grid.Column="4" Background="{DynamicResource PrimaryColor}" CornerRadius="4,4,0,0" Height="70" VerticalAlignment="Bottom" Margin="4,0" ToolTip="Friday: 14"/>
                                            <!-- Sat -->
                                            <Border Grid.Column="5" Background="{DynamicResource PrimaryColor}" CornerRadius="4,4,0,0" Height="90" VerticalAlignment="Bottom" Margin="4,0" ToolTip="Saturday: 18"/>
                                            <!-- Sun -->
                                            <Border Grid.Column="6" Background="{DynamicResource SubtextColor}" CornerRadius="4,4,0,0" Height="30" VerticalAlignment="Bottom" Margin="4,0" ToolTip="Sunday: 6"/>                                        </Grid>

                                        <!-- Days labels -->
                                        <Grid Grid.Row="2" Margin="0,6,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="M" FontSize="10" Foreground="{StaticResource SubtextColor}" HorizontalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" Text="T" FontSize="10" Foreground="{StaticResource SubtextColor}" HorizontalAlignment="Center"/>
                                            <TextBlock Grid.Column="2" Text="W" FontSize="10" Foreground="{StaticResource SubtextColor}" HorizontalAlignment="Center"/>
                                            <TextBlock Grid.Column="3" Text="T" FontSize="10" Foreground="{StaticResource SubtextColor}" HorizontalAlignment="Center"/>
                                            <TextBlock Grid.Column="4" Text="F" FontSize="10" Foreground="{StaticResource SubtextColor}" HorizontalAlignment="Center"/>
                                            <TextBlock Grid.Column="5" Text="S" FontSize="10" Foreground="{StaticResource SubtextColor}" HorizontalAlignment="Center"/>
                                            <TextBlock Grid.Column="6" Text="S" FontSize="10" Foreground="{StaticResource SubtextColor}" HorizontalAlignment="Center"/>
                                        </Grid>
                                    </Grid>

                                    <!-- Donut Chart: Scheduled Today breakdown -->
                                    <Grid Grid.Column="1">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Text="Scheduled Today" FontSize="11" Foreground="{StaticResource SubtextColor}" Margin="0,0,0,10"/>
                                        
                                        <Grid Grid.Row="1">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/> <!-- Donut -->
                                                <ColumnDefinition Width="*"/>    <!-- Legend -->
                                            </Grid.ColumnDefinitions>

                                            <!-- Donut circle using WPF Ellipse overlays -->
                                            <Grid Grid.Column="0" Width="90" Height="90" Margin="0,0,10,0">
                                                <!-- Base Background Ring -->
                                                <Ellipse Stroke="#E2E8F0" StrokeThickness="12" Width="80" Height="80"/>
                                                <!-- Simulated Segments using styled arcs or concentric colorful rings -->
                                                <Ellipse Stroke="{StaticResource PrimaryColor}" StrokeThickness="12" StrokeDashArray="3,1" Width="80" Height="80"/>
                                                <Ellipse Stroke="#0EA5E9" StrokeThickness="12" StrokeDashArray="1,4" Width="80" Height="80"/>
                                                <Ellipse Stroke="#EF4444" StrokeThickness="12" StrokeDashArray="0.5,8" Width="80" Height="80"/>
                                                
                                                <TextBlock Text="26" FontSize="15" FontWeight="Bold" Foreground="{StaticResource TextColor}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Grid>

                                            <!-- Chart Legend -->
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <!-- Routine -->
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                                    <Border Width="8" Height="8" CornerRadius="4" Background="{StaticResource PrimaryColor}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                    <TextBlock Text="Routine" FontSize="11" Foreground="{StaticResource TextColor}"/>
                                                </StackPanel>
                                                <!-- Follow-up -->
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                                    <Border Width="8" Height="8" CornerRadius="4" Background="#0EA5E9" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                    <TextBlock Text="Follow-up" FontSize="11" Foreground="{StaticResource TextColor}"/>
                                                </StackPanel>
                                                <!-- Urgent -->
                                                <StackPanel Orientation="Horizontal">
                                                    <Border Width="8" Height="8" CornerRadius="4" Background="#EF4444" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                    <TextBlock Text="Urgent" FontSize="11" Foreground="{StaticResource TextColor}"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Grid>
                                    </Grid>
                                </Grid>
                            </Grid>
                        </Border>

                        <!-- Recent Patients Card -->
                        <Border Grid.Column="1" Style="{StaticResource CardBorder}" Margin="10,0,0,0" Height="260" Padding="15">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0" Margin="0,0,0,15">
                                    <TextBlock Text="Recent Patients" Style="{StaticResource Subheading}" FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                                    <Border Background="#F1F5F9" CornerRadius="6" Padding="8,4" HorizontalAlignment="Right" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="Recent" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextColor}"/>
                                            <TextBlock Text="&#xE70D;" FontFamily="Segoe MDL2 Assets" FontSize="8" Foreground="{StaticResource SubtextColor}" VerticalAlignment="Center" Margin="6,2,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Style="{StaticResource MaterialDesignScrollViewer}">
                                    <ItemsControl ItemsSource="{Binding RecentDoctorPatients}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,0,1" Padding="0" Margin="0,0,0,4">
                                                    <Button Style="{StaticResource NavButton}" Padding="0,8" Height="Auto" HorizontalContentAlignment="Stretch"
                                                            Command="{Binding DataContext.SelectRecentPatientCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                 <ColumnDefinition Width="Auto"/> <!-- Avatar -->
                                                                 <ColumnDefinition Width="*"/>    <!-- Details -->
                                                                 <ColumnDefinition Width="Auto"/> <!-- Action chevron -->
                                                             </Grid.ColumnDefinitions>
    
                                                                                                                         <!-- Circle Avatar -->
                                                             <Border Grid.Column="0" Width="32" Height="32" CornerRadius="16" Background="{DynamicResource InfoBadgeBackground}" VerticalAlignment="Center" Margin="0,0,12,0">
                                                                <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{StaticResource PrimaryColor}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
    
                                                            <!-- Details -->
                                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding Name}" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextColor}"/>
                                                                <TextBlock Text="{Binding Phone, StringFormat='#\{0\}'}" FontSize="10" Foreground="{StaticResource SubtextColor}"/>
                                                            </StackPanel>
    
                                                            <!-- Chevron -->
                                                            <TextBlock Grid.Column="2" Text="&#xE76C;" FontFamily="Segoe MDL2 Assets" FontSize="10" Foreground="{StaticResource SubtextColor}" VerticalAlignment="Center"/>
                                                        </Grid>
                                                    </Button>
                                                </Border>                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Grid>
                        </Border>
                    </Grid>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- 2. Active Exam Room Layout (Visible when CurrentPatient is NOT null) -->
        <Grid Visibility="{Binding CurrentPatient, Converter={StaticResource NullToVisibilityConverter}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240"/> <!-- Waitlist Queue Sidebar -->
                <ColumnDefinition Width="*"/>   <!-- Active Exam Form (Grid) -->
                <ColumnDefinition Width="290"/> <!-- Patient Info & Timeline Sidebar -->
            </Grid.ColumnDefinitions>

            <!-- Column 0: Left Sidebar (Queue / Sections / Features) -->
            <Border Grid.Column="0" Style="{StaticResource CardBorder}" Margin="0,0,15,0" VerticalAlignment="Stretch">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/> <!-- Back Button -->
                        <RowDefinition Height="Auto"/> <!-- Tab Selector -->
                        <RowDefinition Height="*"/>    <!-- Content Area -->
                    </Grid.RowDefinitions>

                    <!-- Back Button Header -->
                    <Button Grid.Row="0" HorizontalAlignment="Stretch" Margin="0,0,0,10"
                            Style="{StaticResource NavButton}" Padding="12,7" 
                            Tag="&#xE72B;" Content="Back to Dashboard"
                            Command="{Binding ExitToDashboardCommand}"/>

                    <!-- Tab Selector Segmented Control -->
                    <Border Grid.Row="1" Background="{DynamicResource BackgroundColor}" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" CornerRadius="8" Padding="2" Margin="0,0,0,15">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <!-- Queue Tab Button -->
                            <RadioButton Grid.Column="0" Content="Queue" GroupName="SidebarTabs"
                                         Style="{StaticResource SidebarTabRadioButton}"
                                         IsChecked="{Binding IsQueueTabActive, Mode=TwoWay}"/>
                            <!-- Sections Tab Button -->
                            <RadioButton Grid.Column="1" Content="Sections" GroupName="SidebarTabs"
                                         Style="{StaticResource SidebarTabRadioButton}"
                                         IsChecked="{Binding IsSectionsTabActive, Mode=TwoWay}"/>
                            <!-- Features Tab Button -->
                            <RadioButton Grid.Column="2" Content="Features" GroupName="SidebarTabs"
                                         Style="{StaticResource SidebarTabRadioButton}"
                                         IsChecked="{Binding IsSoonTabActive, Mode=TwoWay}"/>
                        </Grid>
                    </Border>

                    <!-- Scrollable Content Frame -->
                    <Grid Grid.Row="2">
                        <!-- 1. Queue Panel (Visible when IsQueueTabActive is True) -->
                        <Grid Visibility="{Binding IsQueueTabActive, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/> <!-- Quick Lookup -->
                                <RowDefinition Height="*"/> <!-- Waiting Patients -->
                                <RowDefinition Height="Auto"/> <!-- Divider -->
                                <RowDefinition Height="*"/> <!-- Not Finished Patients -->
                            </Grid.RowDefinitions>

                            <!-- Section 0: Quick Lookup -->
                            <Grid Grid.Row="0" Margin="0,0,0,15">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid Grid.Row="0" Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0" Foreground="{DynamicResource TextColor}" Style="{StaticResource MaterialDesignOutlinedTextBox}" materialDesign:TextFieldAssist.TextFieldCornerRadius="8" materialDesign:HintAssist.Hint="Search patient..." Text="{Binding SearchTerm, UpdateSourceTrigger=PropertyChanged}" Height="40" FontSize="11" Margin="0,0,5,0" VerticalContentAlignment="Center" Padding="10,0"/>
                                    <Button Grid.Column="1" Style="{StaticResource ModernButton}" Content="Search" Command="{Binding SearchPatientsCommand}" Height="40" Padding="12,0" FontSize="11"/>
                                </Grid>
                                <ComboBox Foreground="{DynamicResource TextColor}" Grid.Row="1" Style="{StaticResource MaterialDesignOutlinedComboBox}" materialDesign:TextFieldAssist.TextFieldCornerRadius="8" ItemsSource="{Binding Patients}" SelectedItem="{Binding SelectedPatientLookup}" DisplayMemberPath="Name" SelectedValuePath="PatientId" FontSize="11" VerticalContentAlignment="Center" Background="{DynamicResource CardBackgroundColor}">
                                    <ComboBox.ItemContainerStyle>
                                        <Style TargetType="ComboBoxItem" BasedOn="{StaticResource {x:Type ComboBoxItem}}">
                                            <Setter Property="Padding" Value="16,8"/>
                                        </Style>
                                    </ComboBox.ItemContainerStyle>
                                </ComboBox>
                            </Grid>
                            <!-- Section 1: Waiting Patients -->
                            <Grid Grid.Row="1" Margin="0,0,0,10">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                
                                <StackPanel Grid.Row="0" Margin="0,0,0,10">
                                    <TextBlock Text="Waiting Patients" Style="{StaticResource Header2}"/>
                                    <TextBlock Text="Live queue updates (Pending)" Style="{StaticResource Subheading}"/>
                                </StackPanel>
                        <ListBox x:Name="WaitingPatientsListBox" Grid.Row="1" ItemsSource="{Binding WaitingPatients}" Style="{StaticResource QueueListBoxStyle}" HorizontalContentAlignment="Stretch" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{StaticResource BorderColor}" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,0,0,8" Background="{DynamicResource CardBackgroundColor}">
                                        <Grid>                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                
                                                <!-- Patient Info -->
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="{Binding Patient.Name}" FontWeight="Bold" FontSize="12" Foreground="{DynamicResource HighlightCardText}" TextWrapping="Wrap"/>
                                                    <TextBlock FontSize="11" Foreground="{DynamicResource HighlightCardSubtext}" Margin="0,2,0,0">
                                                        <Run Text="{Binding Patient.Age, Mode=OneWay}"/> <Run Text="yrs |"/> <Run Text="{Binding Patient.Gender, Mode=OneWay}"/>
                                                    </TextBlock>                                                    </StackPanel>

                                                    <!-- Start Action Button -->
                                                    <Button Grid.Column="1" Style="{StaticResource ModernButton}" Content="Start" VerticalAlignment="Center" Padding="10,4" FontSize="11"
                                                            Command="{Binding DataContext.StartSessionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>

                            <!-- Divider -->
                            <Separator Grid.Row="2" Background="{DynamicResource BorderColor}" Height="1.5" Margin="0,5,0,15"/>

                            <!-- Section 2: Not Finished Patients -->
                            <Grid Grid.Row="3">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                
                                <StackPanel Grid.Row="0" Margin="0,0,0,10">
                                    <TextBlock Text="Not Finished Queue" Style="{StaticResource Header2}"/>
                                    <TextBlock Text="Patients currently in exam (In Progress)" Style="{StaticResource Subheading}"/>
                                </StackPanel>
                        <ListBox x:Name="NotFinishedPatientsListBox" Grid.Row="1" ItemsSource="{Binding NotFinishedPatients}" Style="{StaticResource QueueListBoxStyle}" HorizontalContentAlignment="Stretch" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{DynamicResource HighlightCardBorder}" BorderThickness="1.5" CornerRadius="6" Padding="10" Margin="0,0,0,8" Background="{DynamicResource HighlightCardBackground}">
                                        <Grid>                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    
                                                    <!-- Patient Info -->
                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="{Binding Patient.Name}" FontWeight="Bold" FontSize="12" Foreground="{DynamicResource TextColor}" TextWrapping="Wrap"/>
                                                        <TextBlock FontSize="11" Foreground="{DynamicResource SubtextColor}" Margin="0,2,0,0">
                                                            <Run Text="{Binding Patient.Age}"/> <Run Text="yrs |"/> <Run Text="{Binding Patient.Gender}"/>
                                                        </TextBlock>
                                                    </StackPanel>

                                                    <!-- Resume Action Button -->
                                                    <Button Grid.Column="1" Style="{StaticResource ModernButton}" Content="Resume" Background="#D97706" BorderBrush="#D97706" VerticalAlignment="Center" Padding="10,4" FontSize="11"
                                                            Command="{Binding DataContext.StartSessionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Grid>

                        <!-- 2. Sections Panel (Visible when IsSectionsTabActive is True) -->
                        <Grid Visibility="{Binding IsSectionsTabActive, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <!-- Main Sections Configuration List -->
                            <ScrollViewer VerticalScrollBarVisibility="Auto" Style="{StaticResource MaterialDesignScrollViewer}">
                                <StackPanel Margin="0,0,0,10">
                                    <TextBlock Text="Main Sections" Style="{StaticResource Header2}" HorizontalAlignment="Center" Margin="0,0,0,15"/>

                                    <!-- Overview Section Card -->
                                    <Border BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,10" Background="{DynamicResource CardBackgroundColor}">
                                        <StackPanel>
                                            <Grid Margin="0,0,0,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="Overview Section" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource PrimaryColor}" VerticalAlignment="Center"/>
                                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                    <ToggleButton Style="{StaticResource ModernSwitchToggleButton}" IsChecked="{Binding ShowOverviewSection, Mode=TwoWay}"/>
                                                    <TextBlock Text="Show" FontSize="9" Foreground="{DynamicResource SubtextColor}" Margin="5,0,0,0" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Grid>

                                            <!-- Subsections -->
                                            <WrapPanel>
                                                <!-- Complaints -->
                                                <Border BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" CornerRadius="6" Padding="4" Margin="0,0,4,4" Width="98" Background="{DynamicResource BackgroundColor}">
                                                    <StackPanel HorizontalAlignment="Center">
                                                        <TextBlock Text="Complaints" FontSize="9" HorizontalAlignment="Center" Margin="0,0,0,4" Foreground="{DynamicResource TextColor}"/>
                                                        <Button Style="{StaticResource MiniSettingsToggleButton}" Command="{Binding OpenSectionSettingsCommand}" CommandParameter="Complaints"/>
                                                    </StackPanel>
                                                </Border>
                                                <!-- Nutritional -->
                                                <Border BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" CornerRadius="6" Padding="4" Margin="0,0,4,4" Width="98" Background="{DynamicResource BackgroundColor}">
                                                    <StackPanel HorizontalAlignment="Center">
                                                        <TextBlock Text="Nutritional" FontSize="9" HorizontalAlignment="Center" Margin="0,0,0,4" Foreground="{DynamicResource TextColor}"/>
                                                        <Button Style="{StaticResource MiniSettingsToggleButton}" Command="{Binding OpenSectionSettingsCommand}" CommandParameter="Nutritional"/>
                                                    </StackPanel>
                                                </Border>
                                                <!-- Obstetrics -->
                                                <Border BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" CornerRadius="6" Padding="4" Margin="0,0,4,4" Width="98" Background="{DynamicResource BackgroundColor}">
                                                    <StackPanel HorizontalAlignment="Center">
                                                        <TextBlock Text="Obstetrics" FontSize="9" HorizontalAlignment="Center" Margin="0,0,0,4" Foreground="{DynamicResource TextColor}"/>
                                                        <Button Style="{StaticResource MiniSettingsToggleButton}" Command="{Binding OpenSectionSettingsCommand}" CommandParameter="Obstetrics"/>
                                                    </StackPanel>
                                                </Border>
                                                <!-- Summary -->
                                                <Border BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" CornerRadius="6" Padding="4" Margin="0,0,4,4" Width="98" Background="{DynamicResource BackgroundColor}">
                                                    <StackPanel HorizontalAlignment="Center">
                                                        <TextBlock Text="Summery" FontSize="9" HorizontalAlignment="Center" Margin="0,0,0,4" Foreground="{DynamicResource TextColor}"/>
                                                        <Button Style="{StaticResource MiniSettingsToggleButton}" Command="{Binding OpenSectionSettingsCommand}" CommandParameter="Summary"/>
                                                    </StackPanel>
                                                </Border>
                                                <!-- Custom Fields -->
                                                <Border BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" CornerRadius="6" Padding="4" Margin="0,0,4,4" Width="98" Background="{DynamicResource BackgroundColor}">
                                                    <StackPanel HorizontalAlignment="Center">
                                                        <TextBlock Text="Custom Fields" FontSize="9" HorizontalAlignment="Center" Margin="0,0,0,4" Foreground="{DynamicResource TextColor}"/>
                                                        <Button Style="{StaticResource MiniSettingsToggleButton}" Command="{Binding OpenSectionSettingsCommand}" CommandParameter="Custom Fields"/>
                                                    </StackPanel>
                                                </Border>
                                            </WrapPanel>
                                        </StackPanel>
                                    </Border>

                                    <!-- Reports Card -->
                                    <Border BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,10" Background="{DynamicResource CardBackgroundColor}">
                                        <StackPanel>
                                            <Grid Margin="0,0,0,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="Reports" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource PrimaryColor}" VerticalAlignment="Center"/>
                                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                    <ToggleButton Style="{StaticResource ModernSwitchToggleButton}" IsChecked="{Binding ShowReportsSection, Mode=TwoWay}"/>
                                                    <TextBlock Text="Show" FontSize="9" Foreground="{DynamicResource SubtextColor}" Margin="5,0,0,0" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Grid>
                                            <WrapPanel>
                                                <Border BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" CornerRadius="6" Padding="4" Margin="0,0,4,4" Width="98" Background="{DynamicResource BackgroundColor}">
                                                    <StackPanel HorizontalAlignment="Center">
                                                        <TextBlock Text="Reports" FontSize="9" HorizontalAlignment="Center" Margin="0,0,0,4" Foreground="{DynamicResource TextColor}"/>
                                                        <Button Style="{StaticResource MiniSettingsToggleButton}" Command="{Binding OpenSectionSettingsCommand}" CommandParameter="Reports"/>
                                                    </StackPanel>
                                                </Border>
                                            </WrapPanel>
                                        </StackPanel>
                                    </Border>

                                    <!-- Dentist Card -->
                                    <Border BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,10" Background="{DynamicResource CardBackgroundColor}">
                                        <StackPanel>
                                            <Grid Margin="0,0,0,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="Dentist" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource PrimaryColor}" VerticalAlignment="Center"/>
                                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                    <ToggleButton Style="{StaticResource ModernSwitchToggleButton}" IsChecked="{Binding ShowDentistSection, Mode=TwoWay}"/>
                                                    <TextBlock Text="Show" FontSize="9" Foreground="{DynamicResource SubtextColor}" Margin="5,0,0,0" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Grid>
                                            <WrapPanel>
                                                <Border BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" CornerRadius="6" Padding="4" Margin="0,0,4,4" Width="98" Background="{DynamicResource BackgroundColor}">
                                                    <StackPanel HorizontalAlignment="Center">
                                                        <TextBlock Text="Dentist" FontSize="9" HorizontalAlignment="Center" Margin="0,0,0,4" Foreground="{DynamicResource TextColor}"/>
                                                        <Button Style="{StaticResource MiniSettingsToggleButton}" Command="{Binding OpenSectionSettingsCommand}" CommandParameter="Dentist"/>
                                                    </StackPanel>
                                                </Border>
                                            </WrapPanel>
                                        </StackPanel>
                                    </Border>

                                    <!-- Vital Signs Card -->
                                    <Border BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,10" Background="{DynamicResource CardBackgroundColor}">
                                        <StackPanel>
                                            <Grid Margin="0,0,0,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="Vital Signs" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource PrimaryColor}" VerticalAlignment="Center"/>
                                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                    <ToggleButton Style="{StaticResource ModernSwitchToggleButton}" IsChecked="{Binding ShowVitalsSection, Mode=TwoWay}"/>
                                                    <TextBlock Text="Show" FontSize="9" Foreground="{DynamicResource SubtextColor}" Margin="5,0,0,0" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Grid>
                                            <WrapPanel>
                                                <Border BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" CornerRadius="6" Padding="4" Margin="0,0,4,4" Width="98" Background="{DynamicResource BackgroundColor}">
                                                    <StackPanel HorizontalAlignment="Center">
                                                        <TextBlock Text="Vital Signs" FontSize="9" HorizontalAlignment="Center" Margin="0,0,0,4" Foreground="{DynamicResource TextColor}"/>
                                                        <Button Style="{StaticResource MiniSettingsToggleButton}" Command="{Binding OpenSectionSettingsCommand}" CommandParameter="Vital Signs"/>
                                                    </StackPanel>
                                                </Border>
                                            </WrapPanel>
                                        </StackPanel>
                                    </Border>

                                    <!-- System Review Card -->
                                    <Border BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,10" Background="{DynamicResource CardBackgroundColor}">
                                        <StackPanel>
                                            <Grid Margin="0,0,0,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="System Review" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource PrimaryColor}" VerticalAlignment="Center"/>
                                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                    <ToggleButton Style="{StaticResource ModernSwitchToggleButton}" IsChecked="{Binding ShowSystemReviewSection, Mode=TwoWay}"/>
                                                    <TextBlock Text="Show" FontSize="9" Foreground="{DynamicResource SubtextColor}" Margin="5,0,0,0" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Grid>
                                            <WrapPanel>
                                                <Border BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" CornerRadius="6" Padding="4" Margin="0,0,4,4" Width="98" Background="{DynamicResource BackgroundColor}">
                                                    <StackPanel HorizontalAlignment="Center">
                                                        <TextBlock Text="System Review" FontSize="9" HorizontalAlignment="Center" Margin="0,0,0,4" Foreground="{DynamicResource TextColor}"/>
                                                        <Button Style="{StaticResource MiniSettingsToggleButton}" Command="{Binding OpenSectionSettingsCommand}" CommandParameter="System Review"/>
                                                    </StackPanel>
                                                </Border>
                                            </WrapPanel>
                                        </StackPanel>
                                    </Border>

                                    <!-- Examination Card -->
                                    <Border BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,10" Background="{DynamicResource CardBackgroundColor}">
                                        <StackPanel>
                                            <Grid Margin="0,0,0,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="Examination" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource PrimaryColor}" VerticalAlignment="Center"/>
                                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                    <ToggleButton Style="{StaticResource ModernSwitchToggleButton}" IsChecked="{Binding ShowExaminationSection, Mode=TwoWay}"/>
                                                    <TextBlock Text="Show" FontSize="9" Foreground="{DynamicResource SubtextColor}" Margin="5,0,0,0" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Grid>
                                            <WrapPanel>
                                                <Border BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" CornerRadius="6" Padding="4" Margin="0,0,4,4" Width="98" Background="{DynamicResource BackgroundColor}">
                                                    <StackPanel HorizontalAlignment="Center">
                                                        <TextBlock Text="Positive Signs" FontSize="9" HorizontalAlignment="Center" Margin="0,0,0,4" Foreground="{DynamicResource TextColor}"/>
                                                        <Button Style="{StaticResource MiniSettingsToggleButton}" Command="{Binding OpenSectionSettingsCommand}" CommandParameter="Examination"/>
                                                    </StackPanel>
                                                </Border>
                                                <Border BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" CornerRadius="6" Padding="4" Margin="0,0,4,4" Width="98" Background="{DynamicResource BackgroundColor}">
                                                    <StackPanel HorizontalAlignment="Center">
                                                        <TextBlock Text="Notes" FontSize="9" HorizontalAlignment="Center" Margin="0,0,0,4" Foreground="{DynamicResource TextColor}"/>
                                                        <Button Style="{StaticResource MiniSettingsToggleButton}" Command="{Binding OpenSectionSettingsCommand}" CommandParameter="Examination"/>
                                                    </StackPanel>
                                                </Border>
                                                <Border BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" CornerRadius="6" Padding="4" Margin="0,0,4,4" Width="98" Background="{DynamicResource BackgroundColor}">
                                                    <StackPanel HorizontalAlignment="Center">
                                                        <TextBlock Text="Negative Signs" FontSize="9" HorizontalAlignment="Center" Margin="0,0,0,4" Foreground="{DynamicResource TextColor}"/>
                                                        <Button Style="{StaticResource MiniSettingsToggleButton}" Command="{Binding OpenSectionSettingsCommand}" CommandParameter="Examination"/>
                                                    </StackPanel>
                                                </Border>
                                            </WrapPanel>
                                        </StackPanel>
                                    </Border>

                                    <!-- Labs Section Card -->
                                    <Border BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,10" Background="{DynamicResource CardBackgroundColor}">
                                        <StackPanel>
                                            <Grid Margin="0,0,0,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="Labs Section" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource PrimaryColor}" VerticalAlignment="Center"/>
                                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                    <ToggleButton Style="{StaticResource ModernSwitchToggleButton}" IsChecked="{Binding ShowLabsSection, Mode=TwoWay}"/>
                                                    <TextBlock Text="Show" FontSize="9" Foreground="{DynamicResource SubtextColor}" Margin="5,0,0,0" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Grid>
                                            <WrapPanel>
                                                <Border BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" CornerRadius="6" Padding="4" Margin="0,0,4,4" Width="98" Background="{DynamicResource BackgroundColor}">
                                                    <StackPanel HorizontalAlignment="Center">
                                                        <TextBlock Text="Investigation" FontSize="9" HorizontalAlignment="Center" Margin="0,0,0,4" Foreground="{DynamicResource TextColor}"/>
                                                        <Button Style="{StaticResource MiniSettingsToggleButton}" Command="{Binding OpenSectionSettingsCommand}" CommandParameter="Labs Section"/>
                                                    </StackPanel>
                                                </Border>
                                                <Border BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" CornerRadius="6" Padding="4" Margin="0,0,4,4" Width="98" Background="{DynamicResource BackgroundColor}">
                                                    <StackPanel HorizontalAlignment="Center">
                                                        <TextBlock Text="Imaging" FontSize="9" HorizontalAlignment="Center" Margin="0,0,0,4" Foreground="{DynamicResource TextColor}"/>
                                                        <Button Style="{StaticResource MiniSettingsToggleButton}" Command="{Binding OpenSectionSettingsCommand}" CommandParameter="Labs Section"/>
                                                    </StackPanel>
                                                </Border>
                                                <Border BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" CornerRadius="6" Padding="4" Margin="0,0,4,4" Width="98" Background="{DynamicResource BackgroundColor}">
                                                    <StackPanel HorizontalAlignment="Center">
                                                        <TextBlock Text="Intervention" FontSize="9" HorizontalAlignment="Center" Margin="0,0,0,4" Foreground="{DynamicResource TextColor}"/>
                                                        <Button Style="{StaticResource MiniSettingsToggleButton}" Command="{Binding OpenSectionSettingsCommand}" CommandParameter="Labs Section"/>
                                                    </StackPanel>
                                                </Border>
                                            </WrapPanel>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>

                            <!-- POPUP OVERLAY (Visible when a subsection's settings is clicked, i.e., ActiveSettingsTitle is not empty) -->
                            <Border BorderBrush="{DynamicResource BorderColor}" BorderThickness="1.5" CornerRadius="8" Background="{DynamicResource CardBackgroundColor}" Padding="12" Margin="0" VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ActiveSettingsTitle}" Value="">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding ActiveSettingsTitle, Converter={StaticResource NullToBoolConverter}}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/> <!-- Title Header -->
                                        <RowDefinition Height="*"/>    <!-- Scrollable Toggle Switches -->
                                        <RowDefinition Height="Auto"/> <!-- Close Button -->
                                    </Grid.RowDefinitions>

                                    <!-- Popover Header -->
                                    <TextBlock Grid.Row="0" Text="{Binding ActiveSettingsTitle}" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource PrimaryColor}" HorizontalAlignment="Center" Margin="0,0,0,15"/>

                                    <!-- Scrollable Toggle Switches List -->
                                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Style="{StaticResource MaterialDesignScrollViewer}">
                                        <StackPanel Margin="0,0,0,10">
                                            
                                            <!-- IF OBSTETRICS -->
                                            <StackPanel>
                                                <StackPanel.Style>
                                                    <Style TargetType="StackPanel">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsObstetricsSettingsActive}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </StackPanel.Style>
                                                <Grid Margin="0,0,0,8">
                                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                    <TextBlock Text="Show Obstetrics Info" Foreground="{DynamicResource TextColor}" FontSize="11" VerticalAlignment="Center"/>
                                                    <ToggleButton Grid.Column="1" Style="{StaticResource ModernSwitchToggleButton}" IsChecked="{Binding ObShowObstetricsInfo, Mode=TwoWay}"/>
                                                </Grid>
                                                <Grid Margin="0,0,0,8">
                                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                    <TextBlock Text="Last Menstrual Period" Foreground="{DynamicResource TextColor}" FontSize="11" VerticalAlignment="Center"/>
                                                    <ToggleButton Grid.Column="1" Style="{StaticResource ModernSwitchToggleButton}" IsChecked="{Binding ObShowLMP, Mode=TwoWay}"/>
                                                </Grid>
                                                <Grid Margin="0,0,0,8">
                                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                    <TextBlock Text="Last Ultrasound" Foreground="{DynamicResource TextColor}" FontSize="11" VerticalAlignment="Center"/>
                                                    <ToggleButton Grid.Column="1" Style="{StaticResource ModernSwitchToggleButton}" IsChecked="{Binding ObShowLastUltrasound, Mode=TwoWay}"/>
                                                </Grid>
                                                <Grid Margin="0,0,0,8">
                                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
