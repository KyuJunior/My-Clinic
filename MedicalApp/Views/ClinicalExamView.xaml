                                                                     <ComboBoxItem Content="Capsule"/>
                                                                     <ComboBoxItem Content="Syrup"/>
                                                                     <ComboBoxItem Content="Injection"/>
                                                                     <ComboBoxItem Content="Drop"/>
                                                                     <ComboBoxItem Content="Ointment"/>
                                                                 </ComboBox>

                                                                 <!-- Time Dropdown -->
                                                                 <ComboBox Foreground="{DynamicResource TextColor}" Grid.Column="4" Style="{StaticResource MaterialDesignOutlinedComboBox}" materialDesign:TextFieldAssist.TextFieldCornerRadius="4" Height="40" Padding="10,8" Margin="0,0,5,0" SelectedValue="{Binding Time}" SelectedValuePath="Content" VerticalContentAlignment="Center" Background="{DynamicResource CardBackgroundColor}">
                                                                     <ComboBox.ItemContainerStyle>
                                                                         <Style TargetType="ComboBoxItem" BasedOn="{StaticResource {x:Type ComboBoxItem}}">
                                                                             <Setter Property="Padding" Value="10,6"/>
                                                                         </Style>
                                                                     </ComboBox.ItemContainerStyle>
                                                                     <ComboBoxItem Content="Select..."/>
