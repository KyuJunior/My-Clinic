<UserControl x:Class="MedicalApp.Views.ClinicalExamView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:converters="clr-namespace:MedicalApp.Converters"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1100"
             Background="Transparent">
    
    <UserControl.Resources>
        <converters:NullToBoolConverter x:Key="NullToBoolConverter"/>
        <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid Margin="10,5,10,10">
        <!-- Main Workspace (Waitlist Queue + Form + Patient Info Sidebar) -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240"/> <!-- Waitlist Queue Sidebar -->
                <ColumnDefinition Width="*"/>   <!-- Active Exam Form (Grid) -->
                <ColumnDefinition Width="290"/> <!-- Patient Info & Timeline Sidebar -->
            </Grid.ColumnDefinitions>

            <!-- Column 0: Active Waitlist Queue -->
            <Border Grid.Column="0" Style="{StaticResource CardBorder}" Margin="0,0,15,0" VerticalAlignment="Stretch">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/> <!-- Back Button -->
                        <RowDefinition Height="Auto"/> <!-- Quick Lookup -->
                        <RowDefinition Height="*"/> <!-- Waiting Patients -->
                        <RowDefinition Height="Auto"/> <!-- Divider -->
                        <RowDefinition Height="*"/> <!-- Not Finished Patients -->
                    </Grid.RowDefinitions>

                    <!-- Back Button Header -->
                    <Button Grid.Row="0" HorizontalAlignment="Stretch" Margin="0,0,0,15"
                            Style="{StaticResource NavButton}" Padding="12,7" 
                            Tag="&#xE72B;" Content="Back to Dashboard"
                            Command="{Binding DataContext.NavigateToHomeCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>

                    <!-- Section 0: Quick Lookup -->
                    <Grid Grid.Row="1" Margin="0,0,0,15">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0" Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Style="{StaticResource MaterialDesignOutlinedTextBox}" materialDesign:TextFieldAssist.TextFieldCornerRadius="8" materialDesign:HintAssist.Hint="Search patient..." Text="{Binding SearchTerm, UpdateSourceTrigger=PropertyChanged}" Height="40" FontSize="11" Margin="0,0,5,0" VerticalContentAlignment="Center" Padding="10,0"/>
                            <Button Grid.Column="1" Style="{StaticResource ModernButton}" Content="Search" Command="{Binding SearchPatientsCommand}" Height="40" Padding="12,0" FontSize="11"/>
                        </Grid>
                        <ComboBox Grid.Row="1" Style="{StaticResource MaterialDesignOutlinedComboBox}" materialDesign:TextFieldAssist.TextFieldCornerRadius="8" ItemsSource="{Binding Patients}" SelectedItem="{Binding SelectedPatientLookup}" DisplayMemberPath="Name" SelectedValuePath="PatientId" Height="40" FontSize="11" VerticalContentAlignment="Center" Background="White">
                            <ComboBox.ItemContainerStyle>
                                <Style TargetType="ComboBoxItem" BasedOn="{StaticResource {x:Type ComboBoxItem}}">
                                    <Setter Property="Padding" Value="16,8"/>
                                </Style>
                            </ComboBox.ItemContainerStyle>
                        </ComboBox>
                    </Grid>

                    <!-- Section 1: Waiting Patients -->
                    <Grid Grid.Row="2" Margin="0,0,0,10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <StackPanel Grid.Row="0" Margin="0,0,0,10">
                            <TextBlock Text="Waiting Patients" Style="{StaticResource Header2}"/>
                            <TextBlock Text="Live queue updates (Pending)" Style="{StaticResource Subheading}"/>
                        </StackPanel>

                        <ListBox Grid.Row="1" ItemsSource="{Binding WaitingPatients}" BorderThickness="0" Background="Transparent" HorizontalContentAlignment="Stretch" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{StaticResource BorderColor}" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,0,0,8" Background="White">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            
                                            <!-- Patient Info -->
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="{Binding Patient.Name}" FontWeight="Bold" FontSize="12" Foreground="{StaticResource TextColor}" TextWrapping="Wrap"/>
                                                <TextBlock FontSize="11" Foreground="{StaticResource SubtextColor}" Margin="0,2,0,0">
                                                    <Run Text="{Binding Patient.Age}"/> <Run Text="yrs |"/> <Run Text="{Binding Patient.Gender}"/>
                                                </TextBlock>
                                            </StackPanel>

                                            <!-- Start Action Button -->
                                            <Button Grid.Column="1" Style="{StaticResource ModernButton}" Content="Start" VerticalAlignment="Center" Padding="10,4" FontSize="11"
                                                    Command="{Binding DataContext.StartSessionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>

                    <!-- Divider -->
                    <Separator Grid.Row="3" Background="{StaticResource BorderColor}" Height="1.5" Margin="0,5,0,15"/>

                    <!-- Section 2: Not Finished Patients -->
                    <Grid Grid.Row="4">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <StackPanel Grid.Row="0" Margin="0,0,0,10">
                            <TextBlock Text="Not Finished Queue" Style="{StaticResource Header2}"/>
                            <TextBlock Text="Patients currently in exam (In Progress)" Style="{StaticResource Subheading}"/>
                        </StackPanel>

                        <ListBox Grid.Row="1" ItemsSource="{Binding NotFinishedPatients}" BorderThickness="0" Background="Transparent" HorizontalContentAlignment="Stretch" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#FCD34D" BorderThickness="1.5" CornerRadius="6" Padding="10" Margin="0,0,0,8" Background="#FFFBEB">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            
                                            <!-- Patient Info -->
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="{Binding Patient.Name}" FontWeight="Bold" FontSize="12" Foreground="{StaticResource TextColor}" TextWrapping="Wrap"/>
                                                <TextBlock FontSize="11" Foreground="{StaticResource SubtextColor}" Margin="0,2,0,0">
                                                    <Run Text="{Binding Patient.Age}"/> <Run Text="yrs |"/> <Run Text="{Binding Patient.Gender}"/>
                                                </TextBlock>
                                            </StackPanel>

                                            <!-- Resume Action Button -->
                                            <Button Grid.Column="1" Style="{StaticResource ModernButton}" Content="Resume" Background="#D97706" BorderBrush="#D97706" VerticalAlignment="Center" Padding="10,4" FontSize="11"
                                                    Command="{Binding DataContext.StartSessionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Grid>
            </Border>

            <!-- Column 1: Active Examination Form (Gear toggleable sections) -->
            <Border Grid.Column="1" Style="{StaticResource CardBorder}" Margin="0,0,15,0" VerticalAlignment="Stretch">
                <Grid>
                    <!-- Form layout (visible when patient is selected) -->
                    <Grid Visibility="{Binding CurrentPatient, Converter={StaticResource NullToVisibilityConverter}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/> <!-- Title Header + Gear -->
                            <RowDefinition Height="*"/>    <!-- Scrollable Cards content -->
                            <RowDefinition Height="Auto"/> <!-- Bottom Actions panel -->
                            <RowDefinition Height="Auto"/> <!-- Status Messages -->
                        </Grid.RowDefinitions>

                        <!-- Header Grid with gear setting -->
                        <Grid Grid.Row="0" Margin="5,0,5,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="New Visit Examination" Style="{StaticResource Header2}"/>
                                <TextBlock Text="Log examination findings, vitals, and plan for the active patient." Style="{StaticResource Subheading}"/>
                            </StackPanel>
                            
                            <!-- Toggle visibility settings gear -->
                            <Button Grid.Column="1" Width="36" Height="36" Padding="0" Tag="&#xE713;" ToolTip="Show/Hide Sections">
                                <Button.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="Chief Complaint &amp; HPI" IsCheckable="True" IsChecked="{Binding ShowComplaint}"/>
                                        <MenuItem Header="Physical Examination" IsCheckable="True" IsChecked="{Binding ShowPhysicalExam}"/>
                                        <MenuItem Header="Vital Signs" IsCheckable="True" IsChecked="{Binding ShowVitals}"/>
                                        <MenuItem Header="Investigation &amp; Imaging" IsCheckable="True" IsChecked="{Binding ShowInvestigation}"/>
                                        <MenuItem Header="Diagnosis" IsCheckable="True" IsChecked="{Binding ShowDiagnosis}"/>
                                        <MenuItem Header="Medication (Rx)" IsCheckable="True" IsChecked="{Binding ShowDrugs}"/>
                                    </ContextMenu>
                                </Button.ContextMenu>
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource NavButton}">
                                        <EventSetter Event="Click" Handler="GearButton_Click"/>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </Grid>

                        <!-- Scrollable Cards content -->
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Style="{StaticResource MaterialDesignScrollViewer}">
                            <Grid Margin="5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.2*"/> <!-- Column 0: Clinical Notes & Diagnosis -->
                                    <ColumnDefinition Width="1*"/>   <!-- Column 1: Vitals, Labs & Drugs -->
                                </Grid.ColumnDefinitions>

                                <!-- Column 0: Clinical Notes & Diagnosis -->
                                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                    <!-- Chief Complaint & HPI Card -->
                                    <Border Style="{StaticResource CardBorder}" Margin="0,0,0,12" Visibility="{Binding ShowComplaint, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <StackPanel>
                                            <!-- Chief Complaint -->
                                            <StackPanel Margin="0,0,0,10">
                                                <TextBlock Text="Chief Complaint" Style="{StaticResource Subheading}" Margin="0,0,0,5"/>
                                                <Grid>
                                                    <TextBox Style="{StaticResource MaterialDesignOutlinedTextBox}" materialDesign:TextFieldAssist.TextFieldCornerRadius="8" materialDesign:HintAssist.Hint="Type details here..." Text="{Binding ChiefComplaint, UpdateSourceTrigger=PropertyChanged}" Height="60" AcceptsReturn="True" TextWrapping="Wrap" Padding="10,8,30,8" VerticalContentAlignment="Top"/>
                                                    <Button Style="{StaticResource IconButton}" Tag="&#xE720;" ToolTip="Simulate voice input" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,8,8,0" Width="24" Height="24" Padding="0" FontSize="14" Foreground="{StaticResource SubtextColor}"
                                                            Command="{Binding SimulateVoiceInputCommand}" CommandParameter="Complaint"/>
                                                </Grid>
                                            </StackPanel>

                                            <!-- History of Present Illness (HPI) -->
                                            <StackPanel>
                                                <TextBlock Text="History of Present Illness (HPI)" Style="{StaticResource Subheading}" Margin="0,0,0,5"/>
                                                <Grid>
                                                    <TextBox Style="{StaticResource MaterialDesignOutlinedTextBox}" materialDesign:TextFieldAssist.TextFieldCornerRadius="8" materialDesign:HintAssist.Hint="Type details here..." Text="{Binding HistoryOfPresentIllness, UpdateSourceTrigger=PropertyChanged}" Height="60" AcceptsReturn="True" TextWrapping="Wrap" Padding="10,8,30,8" VerticalContentAlignment="Top"/>
                                                    <Button Style="{StaticResource IconButton}" Tag="&#xE720;" ToolTip="Simulate voice input" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,8,8,0" Width="24" Height="24" Padding="0" FontSize="14" Foreground="{StaticResource SubtextColor}"
                                                            Command="{Binding SimulateVoiceInputCommand}" CommandParameter="HPI"/>
                                                </Grid>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>

                                    <!-- Physical Examination & Notes Card -->
                                    <Border Style="{StaticResource CardBorder}" Margin="0,0,0,12" Visibility="{Binding ShowPhysicalExam, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <StackPanel>
                                            <!-- Physical Examination -->
                                            <StackPanel Margin="0,0,0,10">
                                                <TextBlock Text="Physical Examination Findings" Style="{StaticResource Subheading}" Margin="0,0,0,5"/>
                                                <Grid>
                                                    <TextBox Style="{StaticResource MaterialDesignOutlinedTextBox}" materialDesign:TextFieldAssist.TextFieldCornerRadius="8" materialDesign:HintAssist.Hint="Type details here..." Text="{Binding PhysicalExamination, UpdateSourceTrigger=PropertyChanged}" Height="60" AcceptsReturn="True" TextWrapping="Wrap" Padding="10,8,30,8" VerticalContentAlignment="Top"/>
                                                    <Button Style="{StaticResource IconButton}" Tag="&#xE720;" ToolTip="Simulate voice input" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,8,8,0" Width="24" Height="24" Padding="0" FontSize="14" Foreground="{StaticResource SubtextColor}"
                                                            Command="{Binding SimulateVoiceInputCommand}" CommandParameter="Exam"/>
                                                </Grid>
                                            </StackPanel>

                                            <!-- Treatment Plan -->
                                            <StackPanel>
                                                <TextBlock Text="Treatment Plan / Notes" Style="{StaticResource Subheading}" Margin="0,0,0,5"/>
                                                <Grid>
                                                    <TextBox Style="{StaticResource MaterialDesignOutlinedTextBox}" materialDesign:TextFieldAssist.TextFieldCornerRadius="8" materialDesign:HintAssist.Hint="Type details here..." Text="{Binding TreatmentPlan, UpdateSourceTrigger=PropertyChanged}" Height="60" AcceptsReturn="True" TextWrapping="Wrap" Padding="10,8,30,8" VerticalContentAlignment="Top"/>
                                                    <Button Style="{StaticResource IconButton}" Tag="&#xE720;" ToolTip="Simulate voice input" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,8,8,0" Width="24" Height="24" Padding="0" FontSize="14" Foreground="{StaticResource SubtextColor}"
                                                            Command="{Binding SimulateVoiceInputCommand}" CommandParameter="Plan"/>
                                                </Grid>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>

                                    <!-- Diagnosis Card -->
                                    <Border Style="{StaticResource CardBorder}" Margin="0,0,0,12" Visibility="{Binding ShowDiagnosis, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <StackPanel>
                                            <!-- Header -->
                                            <Grid Margin="0,0,0,8">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="&#xEA86;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="{StaticResource PrimaryColor}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                    <TextBlock Text="Diagnosis" Style="{StaticResource Subheading}" VerticalAlignment="Center"/>
                                                </StackPanel>
                                                <Button Style="{StaticResource NavButton}" Content="&#xE81C; History" FontSize="11" Padding="8,4" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                            </Grid>
                                            
                                            <!-- Dx & Return Date Fields -->
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <StackPanel Margin="0,0,10,0">
                                                    <TextBlock Text="Dx (Diseases)" FontSize="11" Foreground="{StaticResource SubtextColor}" Margin="0,0,0,4"/>
                                                    <TextBox Style="{StaticResource MaterialDesignOutlinedTextBox}" materialDesign:TextFieldAssist.TextFieldCornerRadius="8" materialDesign:HintAssist.Hint="Diseases" Text="{Binding Diagnosis, UpdateSourceTrigger=PropertyChanged}" VerticalContentAlignment="Center"/>
                                                </StackPanel>

                                                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                                    <TextBlock Text="Return date" FontSize="11" Foreground="{StaticResource SubtextColor}" Margin="0,0,0,4"/>
                                                    <DatePicker Style="{StaticResource MaterialDesignOutlinedDatePicker}" materialDesign:TextFieldAssist.TextFieldCornerRadius="8" SelectedDate="{Binding ReturnDate}" VerticalContentAlignment="Center"/>
                                                </StackPanel>
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>

                                <!-- Column 1: Vitals, Investigations & Drugs -->
                                <StackPanel Grid.Column="1">
                                    <!-- Vital Signs Card -->
                                    <Border Style="{StaticResource CardBorder}" Margin="0,0,0,12" Visibility="{Binding ShowVitals, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <StackPanel>
                                            <!-- Header with stable toggle -->
                                            <Grid Margin="0,0,0,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="&#xEC5A;" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="{StaticResource PrimaryColor}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                    <TextBlock Text="Vital Signs" Style="{StaticResource Subheading}" VerticalAlignment="Center"/>
                                                </StackPanel>
                                                <Button Grid.Column="1" Style="{StaticResource NavButton}" Content="&#xE81C; History" FontSize="11" Margin="0,0,15,0" Padding="8,4" VerticalAlignment="Center"/>
                                                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                                    <TextBlock Text="Vitally Stable" FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                    <CheckBox IsChecked="{Binding IsVitallyStable}" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Grid>
                                            
                                            <!-- Vitals Input Grid -->
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- Row 0 -->
                                                <StackPanel Margin="0,0,10,10">
                                                    <TextBlock Text="HR (bpm)" FontSize="11" Foreground="{StaticResource SubtextColor}" Margin="0,0,0,4"/>
                                                    <TextBox Style="{StaticResource MaterialDesignOutlinedTextBox}" materialDesign:TextFieldAssist.TextFieldCornerRadius="8" materialDesign:HintAssist.Hint="e.g. 75" Text="{Binding VitalHR, UpdateSourceTrigger=PropertyChanged}" Height="40" VerticalContentAlignment="Center"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="1" Margin="5,0,5,10">
                                                    <TextBlock Text="SBP (mmHg)" FontSize="11" Foreground="{StaticResource SubtextColor}" Margin="0,0,0,4"/>
                                                    <TextBox Style="{StaticResource MaterialDesignOutlinedTextBox}" materialDesign:TextFieldAssist.TextFieldCornerRadius="8" materialDesign:HintAssist.Hint="e.g. 120" Text="{Binding VitalSBP, UpdateSourceTrigger=PropertyChanged}" Height="40" VerticalContentAlignment="Center"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="2" Margin="10,0,0,10">
                                                    <TextBlock Text="DBP (mmHg)" FontSize="11" Foreground="{StaticResource SubtextColor}" Margin="0,0,0,4"/>
                                                    <TextBox Style="{StaticResource MaterialDesignOutlinedTextBox}" materialDesign:TextFieldAssist.TextFieldCornerRadius="8" materialDesign:HintAssist.Hint="e.g. 80" Text="{Binding VitalDBP, UpdateSourceTrigger=PropertyChanged}" Height="40" VerticalContentAlignment="Center"/>
                                                </StackPanel>

                                                <!-- Row 1 -->
                                                <StackPanel Grid.Row="1" Margin="0,0,10,0">
                                                    <TextBlock Text="RR (bpm)" FontSize="11" Foreground="{StaticResource SubtextColor}" Margin="0,0,0,4"/>
                                                    <TextBox Style="{StaticResource MaterialDesignOutlinedTextBox}" materialDesign:TextFieldAssist.TextFieldCornerRadius="8" materialDesign:HintAssist.Hint="e.g. 16" Text="{Binding VitalRR, UpdateSourceTrigger=PropertyChanged}" Height="40" VerticalContentAlignment="Center"/>
                                                </StackPanel>
                                                <StackPanel Grid.Row="1" Grid.Column="1" Margin="5,0,5,0">
                                                    <TextBlock Text="SPO2 (%)" FontSize="11" Foreground="{StaticResource SubtextColor}" Margin="0,0,0,4"/>
                                                    <TextBox Style="{StaticResource MaterialDesignOutlinedTextBox}" materialDesign:TextFieldAssist.TextFieldCornerRadius="8" materialDesign:HintAssist.Hint="e.g. 98" Text="{Binding VitalSPO2, UpdateSourceTrigger=PropertyChanged}" Height="40" VerticalContentAlignment="Center"/>
                                                </StackPanel>
                                                <StackPanel Grid.Row="1" Grid.Column="2" Margin="10,0,0,0">
                                                    <TextBlock Text="Temp (°C)" FontSize="11" Foreground="{StaticResource SubtextColor}" Margin="0,0,0,4"/>
                                                    <TextBox Style="{StaticResource MaterialDesignOutlinedTextBox}" materialDesign:TextFieldAssist.TextFieldCornerRadius="8" materialDesign:HintAssist.Hint="e.g. 37.0" Text="{Binding VitalTemp, UpdateSourceTrigger=PropertyChanged}" Height="40" VerticalContentAlignment="Center"/>
                                                </StackPanel>
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                    <!-- Investigation & Imaging Card -->
                                    <Border Style="{StaticResource CardBorder}" Margin="0,0,0,12" Visibility="{Binding ShowInvestigation, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <StackPanel>
                                            <StackPanel Margin="0,0,0,12">
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                    <TextBlock Text="&#xE9F9;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="{StaticResource PrimaryColor}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                    <TextBlock Text="Investigations" Style="{StaticResource Subheading}" VerticalAlignment="Center"/>
                                                </StackPanel>
                                                <Grid Margin="0,0,0,10">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <ComboBox Grid.Column="0" Style="{StaticResource MaterialDesignOutlinedComboBox}" materialDesign:TextFieldAssist.TextFieldCornerRadius="8" ItemsSource="{Binding InvestigationsList}" SelectedItem="{Binding SelectedInvestigation}" Height="40" VerticalContentAlignment="Center" Margin="0,0,6,0" Background="White">
                                                        <ComboBox.ItemContainerStyle>
                                                            <Style TargetType="ComboBoxItem" BasedOn="{StaticResource {x:Type ComboBoxItem}}">
                                                                <Setter Property="Padding" Value="16,8"/>
                                                            </Style>
                                                        </ComboBox.ItemContainerStyle>
                                                    </ComboBox>
                                                    <Button Grid.Column="1" Style="{StaticResource SecondaryButton}" Content="Add" Command="{Binding AddInvestigationCommand}" Height="40" Padding="15,0"/>
                                                </Grid>

                                                <!-- Investigation items list -->
                                                <ItemsControl ItemsSource="{Binding AddedInvestigations}">
                                                    <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border BorderBrush="{StaticResource BorderColor}" BorderThickness="1" CornerRadius="6" Padding="8,12" Margin="0,0,0,8" Background="#F8FAFC">
                                                            <Grid>
                                                                <Grid.RowDefinitions>
                                                                    <RowDefinition Height="Auto"/>
                                                                    <RowDefinition Height="Auto"/>
                                                                </Grid.RowDefinitions>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>
                                                                
                                                                <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding Name}" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="{StaticResource TextColor}"/>
                                                                <Button Grid.Row="0" Grid.Column="1" Width="22" Height="22" Command="{Binding DataContext.RemoveInvestigationCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" ToolTip="Remove investigation">
                                                                    <Button.Style>
                                                                        <Style TargetType="Button" BasedOn="{StaticResource IconButton}">
                                                                            <Setter Property="Foreground" Value="#94A3B8"/>
                                                                            <Setter Property="Content">
                                                                                <Setter.Value>
                                                                                    <materialDesign:PackIcon Kind="TrashOutline" Width="14" Height="14"/>
                                                                                </Setter.Value>
                                                                            </Setter>
                                                                            <Style.Triggers>
                                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                                    <Setter Property="Foreground" Value="#EF4444"/>
                                                                                </Trigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Button.Style>
                                                                </Button>

                                                                <Grid Grid.Row="1" Grid.ColumnSpan="2" Margin="0,8,0,0">
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                        <ColumnDefinition Width="*"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    
                                                                    <Button Grid.Column="0" Style="{StaticResource LinkButton}" Content="Attach File" Command="{Binding DataContext.UploadInvestigationFileCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Foreground="{StaticResource PrimaryColor}" FontSize="11" Margin="0,0,10,0"
                                                                            Visibility="{Binding AttachmentPath, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=inverse}"/>
                                                                    
                                                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Visibility="{Binding AttachmentPath, Converter={StaticResource NullToVisibilityConverter}}">
                                                                        <TextBlock Text="&#xE71B;" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center" Foreground="#0284C7" Margin="0,0,6,0" FontSize="11"/>
                                                                        <Button Content="{Binding AttachmentName}" Style="{StaticResource LinkButton}"
                                                                                Command="{Binding DataContext.OpenAttachmentCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding AttachmentPath}" MaxWidth="150" HorizontalAlignment="Left"/>
                                                                        <Button Width="20" Height="20" Margin="6,0,0,0" Command="{Binding DataContext.RemoveInvestigationFileCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" ToolTip="Remove attachment">
                                                                            <Button.Style>
                                                                                <Style TargetType="Button" BasedOn="{StaticResource IconButton}">
                                                                                    <Setter Property="Foreground" Value="#94A3B8"/>
                                                                                    <Setter Property="Content">
                                                                                        <Setter.Value>
                                                                                            <materialDesign:PackIcon Kind="TrashOutline" Width="12" Height="12"/>
                                                                                        </Setter.Value>
                                                                                    </Setter>
                                                                                    <Style.Triggers>
                                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                                            <Setter Property="Foreground" Value="#EF4444"/>
                                                                                        </Trigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </Button.Style>
                                                                        </Button>
                                                                    </StackPanel>
                                                                </Grid>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>

                                        <Separator Margin="0,0,0,12"/>

                                        <!-- Imaging -->
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                <TextBlock Text="&#xEC7C;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="{StaticResource PrimaryColor}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                <TextBlock Text="Imaging" Style="{StaticResource Subheading}" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <Grid Margin="0,0,0,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <ComboBox Grid.Column="0" Style="{StaticResource MaterialDesignOutlinedComboBox}" materialDesign:TextFieldAssist.TextFieldCornerRadius="8" ItemsSource="{Binding ImagingList}" SelectedItem="{Binding SelectedImaging}" Height="40" VerticalContentAlignment="Center" Margin="0,0,6,0" Background="White">
                                                    <ComboBox.ItemContainerStyle>
                                                        <Style TargetType="ComboBoxItem" BasedOn="{StaticResource {x:Type ComboBoxItem}}">
                                                            <Setter Property="Padding" Value="16,8"/>
                                                        </Style>
                                                    </ComboBox.ItemContainerStyle>
                                                </ComboBox>
                                                <Button Grid.Column="1" Style="{StaticResource SecondaryButton}" Content="Add" Command="{Binding AddImagingCommand}" Height="40" Padding="15,0"/>
                                            </Grid>

                                            <!-- Imaging items list -->
                                            <ItemsControl ItemsSource="{Binding AddedImagings}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border BorderBrush="{StaticResource BorderColor}" BorderThickness="1" CornerRadius="6" Padding="8,12" Margin="0,0,0,8" Background="#F8FAFC">
                                                            <Grid>
                                                                <Grid.RowDefinitions>
                                                                    <RowDefinition Height="Auto"/>
                                                                    <RowDefinition Height="Auto"/>
                                                                </Grid.RowDefinitions>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>
                                                                
                                                                <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding Name}" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="{StaticResource TextColor}"/>
                                                                <Button Grid.Row="0" Grid.Column="1" Width="22" Height="22" Command="{Binding DataContext.RemoveImagingCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" ToolTip="Remove imaging">
                                                                    <Button.Style>
                                                                        <Style TargetType="Button" BasedOn="{StaticResource IconButton}">
                                                                            <Setter Property="Foreground" Value="#94A3B8"/>
                                                                            <Setter Property="Content">
                                                                                <Setter.Value>
                                                                                    <materialDesign:PackIcon Kind="TrashOutline" Width="14" Height="14"/>
                                                                                </Setter.Value>
                                                                            </Setter>
                                                                            <Style.Triggers>
                                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                                    <Setter Property="Foreground" Value="#EF4444"/>
                                                                                </Trigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Button.Style>
                                                                </Button>

                                                                <Grid Grid.Row="1" Grid.ColumnSpan="2" Margin="0,8,0,0">
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                        <ColumnDefinition Width="*"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    
                                                                    <Button Grid.Column="0" Style="{StaticResource LinkButton}" Content="Attach File" Command="{Binding DataContext.UploadImagingFileCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Foreground="{StaticResource PrimaryColor}" FontSize="11" Margin="0,0,10,0"
                                                                            Visibility="{Binding AttachmentPath, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=inverse}"/>
                                                                    
                                                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Visibility="{Binding AttachmentPath, Converter={StaticResource NullToVisibilityConverter}}">
                                                                        <TextBlock Text="&#xE71B;" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center" Foreground="#0284C7" Margin="0,0,6,0" FontSize="11"/>
                                                                        <Button Content="{Binding AttachmentName}" Style="{StaticResource LinkButton}"
                                                                                Command="{Binding DataContext.OpenAttachmentCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding AttachmentPath}" MaxWidth="150" HorizontalAlignment="Left"/>
                                                                        <Button Width="20" Height="20" Margin="6,0,0,0" Command="{Binding DataContext.RemoveImagingFileCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" ToolTip="Remove attachment">
                                                                            <Button.Style>
                                                                                <Style TargetType="Button" BasedOn="{StaticResource IconButton}">
                                                                                    <Setter Property="Foreground" Value="#94A3B8"/>
                                                                                    <Setter Property="Content">
                                                                                        <Setter.Value>
                                                                                            <materialDesign:PackIcon Kind="TrashOutline" Width="12" Height="12"/>
                                                                                        </Setter.Value>
                                                                                    </Setter>
                                                                                    <Style.Triggers>
                                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                                            <Setter Property="Foreground" Value="#EF4444"/>
                                                                                        </Trigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </Button.Style>
                                                                        </Button>
                                                                    </StackPanel>
                                                                </Grid>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                    <Border Style="{StaticResource CardBorder}" Margin="0,0,0,12" Visibility="{Binding ShowDrugs, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <StackPanel>
                                            <!-- Title & History button -->
                                            <Grid Margin="0,0,0,8">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="&#xE964;" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="{StaticResource PrimaryColor}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                    <TextBlock Text="Drugs" Style="{StaticResource Subheading}" VerticalAlignment="Center"/>
                                                </StackPanel>
                                                <Button Style="{StaticResource NavButton}" Content="&#xE81C; History" FontSize="11" Padding="8,4" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                            </Grid>

                                            <!-- Prescription Selector / Buttons -->
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                                <Button Style="{StaticResource ModernButton}" Content="Rx #1" FontSize="11" Padding="12,6" Margin="0,0,8,0"/>
                                                <Button Style="{StaticResource SecondaryButton}" Content="+ New Rx" FontSize="11" Padding="12,6"/>
                                            </StackPanel>

                                            <!-- Presaved / Trade Dropdowns -->
                                            <Grid Margin="0,0,0,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <TextBlock Text="Presaved Drugs" FontSize="11" Foreground="{StaticResource SubtextColor}" Margin="0,0,0,4"/>
                                                    <ComboBox Style="{StaticResource MaterialDesignOutlinedComboBox}" materialDesign:TextFieldAssist.TextFieldCornerRadius="8" Height="40" Margin="0,0,0,10" VerticalContentAlignment="Center" Background="White">
                                                        <ComboBox.ItemContainerStyle>
                                                            <Style TargetType="ComboBoxItem" BasedOn="{StaticResource {x:Type ComboBoxItem}}">
                                                                <Setter Property="Padding" Value="16,8"/>
                                                            </Style>
                                                        </ComboBox.ItemContainerStyle>
                                                    </ComboBox>
                                                    
                                                    <TextBlock Text="Trade Drugs" FontSize="11" Foreground="{StaticResource SubtextColor}" Margin="0,0,0,4"/>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBox x:Name="DrugInput" Style="{StaticResource MaterialDesignOutlinedTextBox}" materialDesign:TextFieldAssist.TextFieldCornerRadius="8" materialDesign:HintAssist.Hint="Search or type drug name..."
                                                                 Text="{Binding DrugSearchText, UpdateSourceTrigger=PropertyChanged}" Height="40" VerticalContentAlignment="Center">
                                                            <TextBox.InputBindings>
                                                                <KeyBinding Key="Enter" Command="{Binding AddDrugCommand}"/>
                                                            </TextBox.InputBindings>
                                                        </TextBox>
                                                        <Button Grid.Column="1" Style="{StaticResource ModernButton}" Content="Add" 
                                                                Command="{Binding AddDrugCommand}" Margin="10,0,0,0" Padding="15,0" Height="40"/>
                                                        <Popup IsOpen="{Binding IsDrugSuggestionsOpen, Mode=TwoWay}" PlacementTarget="{Binding ElementName=DrugInput}" Placement="Bottom" StaysOpen="False" AllowsTransparency="True" PopupAnimation="Slide">
                                                            <Border Background="White" BorderBrush="{StaticResource BorderColor}" BorderThickness="1.5" CornerRadius="8" Width="220" MaxHeight="160" Padding="5">
                                                                <Border.Effect>
                                                                    <DropShadowEffect BlurRadius="10" Color="Black" Opacity="0.15" ShadowDepth="3"/>
                                                                </Border.Effect>
                                                                <ListBox ItemsSource="{Binding DrugSuggestions}" BorderThickness="0" Background="Transparent" HorizontalContentAlignment="Stretch">
                                                                    <ListBox.ItemTemplate>
                                                                        <DataTemplate>
                                                                            <Button Style="{StaticResource NavButton}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Padding="8,6" Content="{Binding}"
                                                                                    Command="{Binding DataContext.SelectSuggestedDrugCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}"/>
                                                                        </DataTemplate>
                                                                    </ListBox.ItemTemplate>
                                                                </ListBox>
                                                            </Border>
                                                        </Popup>
                                                    </Grid>
                                                </StackPanel>
                                            </Grid>

                                            <!-- Table Header -->
                                            <Grid Margin="0,5,0,5">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="30"/> <!-- Delete btn -->
                                                    <ColumnDefinition Width="2*"/> <!-- Name -->
                                                    <ColumnDefinition Width="*"/>  <!-- Dose -->
                                                    <ColumnDefinition Width="*"/>  <!-- Type -->
                                                    <ColumnDefinition Width="*"/>  <!-- Time -->
                                                    <ColumnDefinition Width="1.5*"/><!-- Note -->
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="1" Text="Name" FontWeight="Bold" FontSize="11" Foreground="{StaticResource SubtextColor}"/>
                                                <TextBlock Grid.Column="2" Text="Dose" FontWeight="Bold" FontSize="11" Foreground="{StaticResource SubtextColor}"/>
                                                <TextBlock Grid.Column="3" Text="Type" FontWeight="Bold" FontSize="11" Foreground="{StaticResource SubtextColor}"/>
                                                <TextBlock Grid.Column="4" Text="Time" FontWeight="Bold" FontSize="11" Foreground="{StaticResource SubtextColor}"/>
                                                <TextBlock Grid.Column="5" Text="Note" FontWeight="Bold" FontSize="11" Foreground="{StaticResource SubtextColor}"/>
                                            </Grid>
                                            
                                            <!-- Prescribed Drugs Table Rows -->
                                            <ItemsControl ItemsSource="{Binding PrescribedDrugs}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,0,1" Padding="0,5" Margin="0,0,0,2">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="30"/> <!-- Delete btn -->
                                                                    <ColumnDefinition Width="2*"/> <!-- Name -->
                                                                    <ColumnDefinition Width="*"/>  <!-- Dose -->
                                                                    <ColumnDefinition Width="*"/>  <!-- Type -->
                                                                    <ColumnDefinition Width="*"/>  <!-- Time -->
                                                                    <ColumnDefinition Width="1.5*"/><!-- Note -->
                                                                </Grid.ColumnDefinitions>

                                                                <!-- Delete button -->
                                                                <Button Grid.Column="0" Style="{StaticResource NavButton}" Width="24" Height="24" Tag="&#xE711;" ToolTip="Remove" Padding="0" Foreground="#EF4444" FontSize="9"
                                                                        Command="{Binding DataContext.RemoveDrugCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}"/>

                                                                <!-- Name -->
                                                                <TextBlock Grid.Column="1" Text="{Binding Name}" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" TextWrapping="Wrap" Margin="0,0,10,0"/>

                                                                <!-- Dose -->
                                                                <TextBox Grid.Column="2" Style="{StaticResource MaterialDesignOutlinedTextBox}" materialDesign:TextFieldAssist.TextFieldCornerRadius="4" Text="{Binding Dose, UpdateSourceTrigger=PropertyChanged}" Height="40" Padding="10,8" Margin="0,0,5,0" VerticalContentAlignment="Center"/>

                                                                <!-- Type Dropdown -->
                                                                <ComboBox Grid.Column="3" Style="{StaticResource MaterialDesignOutlinedComboBox}" materialDesign:TextFieldAssist.TextFieldCornerRadius="4" Height="40" Padding="10,8" Margin="0,0,5,0" SelectedValue="{Binding Type}" SelectedValuePath="Content" VerticalContentAlignment="Center" Background="White">
                                                                    <ComboBox.ItemContainerStyle>
                                                                        <Style TargetType="ComboBoxItem" BasedOn="{StaticResource {x:Type ComboBoxItem}}">
                                                                            <Setter Property="Padding" Value="10,6"/>
                                                                        </Style>
                                                                    </ComboBox.ItemContainerStyle>
                                                                    <ComboBoxItem Content="Select..."/>
                                                                    <ComboBoxItem Content="Tablet"/>
                                                                    <ComboBoxItem Content="Capsule"/>
                                                                    <ComboBoxItem Content="Syrup"/>
                                                                    <ComboBoxItem Content="Injection"/>
                                                                    <ComboBoxItem Content="Drop"/>
                                                                    <ComboBoxItem Content="Ointment"/>
                                                                </ComboBox>

                                                                <!-- Time Dropdown -->
                                                                <ComboBox Grid.Column="4" Style="{StaticResource MaterialDesignOutlinedComboBox}" materialDesign:TextFieldAssist.TextFieldCornerRadius="4" Height="40" Padding="10,8" Margin="0,0,5,0" SelectedValue="{Binding Time}" SelectedValuePath="Content" VerticalContentAlignment="Center" Background="White">
                                                                    <ComboBox.ItemContainerStyle>
                                                                        <Style TargetType="ComboBoxItem" BasedOn="{StaticResource {x:Type ComboBoxItem}}">
                                                                            <Setter Property="Padding" Value="10,6"/>
                                                                        </Style>
                                                                    </ComboBox.ItemContainerStyle>
                                                                    <ComboBoxItem Content="Select..."/>
                                                                    <ComboBoxItem Content="Once daily"/>
                                                                    <ComboBoxItem Content="Twice daily"/>
                                                                    <ComboBoxItem Content="3 times daily"/>
                                                                    <ComboBoxItem Content="4 times daily"/>
                                                                    <ComboBoxItem Content="Before meals"/>
                                                                    <ComboBoxItem Content="After meals"/>
                                                                    <ComboBoxItem Content="At bedtime"/>
                                                                </ComboBox>

                                                                <!-- Note -->
                                                                <TextBox Grid.Column="5" Style="{StaticResource MaterialDesignOutlinedTextBox}" materialDesign:TextFieldAssist.TextFieldCornerRadius="4" Text="{Binding Note, UpdateSourceTrigger=PropertyChanged}" Height="40" Padding="10,8" VerticalContentAlignment="Center"/>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </ScrollViewer>

                        <!-- Bottom Action Buttons -->
                        <Grid Grid.Row="2" Margin="5,10,5,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/> <!-- Complete Visit -->
                                <ColumnDefinition Width="Auto"/> <!-- Hold (Not Finished) -->
                                <ColumnDefinition Width="*"/>    <!-- Spacer -->
                                <ColumnDefinition Width="Auto"/> <!-- Print Rx (A5) -->
                                <ColumnDefinition Width="Auto"/> <!-- Print Summary (A4) -->
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Style="{StaticResource ModernButton}" Content="Complete Visit" Command="{Binding CompleteSessionDoneCommand}" Height="40" Padding="18,10" Margin="0,0,10,0"/>
                            <Button Grid.Column="1" Style="{StaticResource WarningButton}" Content="Hold (Not Finished)" Command="{Binding HoldSessionCommand}" Height="40" Padding="18,10"/>
                            <Button Grid.Column="3" Style="{StaticResource SecondaryButton}" Foreground="{StaticResource PrimaryColor}" BorderBrush="{StaticResource PrimaryColor}" Content="Print Rx (A5)" Command="{Binding PrintActiveRxCommand}" Height="40" Padding="18,10" Margin="0,0,10,0"/>
                            <Button Grid.Column="4" Style="{StaticResource SecondaryButton}" Foreground="{StaticResource PrimaryColor}" BorderBrush="{StaticResource PrimaryColor}" Content="Print Summary (A4)" Command="{Binding PrintActiveVisitReportCommand}" Height="40" Padding="18,10"/>
                        </Grid>

                        <!-- Status Messages -->
                        <TextBlock Grid.Row="3" Text="{Binding StatusMessage}" Foreground="{StaticResource PrimaryColor}" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,15,0,0" HorizontalAlignment="Center"/>
                    </Grid>

                    <!-- Placeholder (visible when no patient is selected) -->
                    <Border Visibility="{Binding CurrentPatient, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=Inverse}" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="20">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="No Active Exam Session" FontSize="16" FontWeight="Bold" Foreground="{StaticResource SubtextColor}" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                            <TextBlock Text="Select a patient from the waitlist on the left to start a clinical examination session." FontSize="12" Foreground="{StaticResource SubtextColor}" TextAlignment="Center" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- Column 2: Patient Context & Accordion Sidebar (visible only when patient selected) -->
            <Border Grid.Column="2" Style="{StaticResource CardBorder}" Background="#F8FAFC" VerticalAlignment="Stretch"
                    Visibility="{Binding CurrentPatient, Converter={StaticResource NullToVisibilityConverter}}">
                <Grid Margin="5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/> <!-- Profile block -->
                        <RowDefinition Height="*"/>    <!-- Scrollable accordion & Info -->
                    </Grid.RowDefinitions>

                    <!-- Profile block -->
                    <Border Grid.Row="0" Background="White" BorderBrush="{StaticResource BorderColor}" BorderThickness="1.5" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                        <StackPanel>
                            <!-- Avatar circle -->
                            <Border Width="60" Height="60" CornerRadius="30" Background="{StaticResource PrimaryColor}" HorizontalAlignment="Center" Margin="0,0,0,10">
                                <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="26" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="{Binding CurrentPatient.Name}" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextColor}" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding CurrentPatient.Gender}" FontSize="12" Foreground="{StaticResource SubtextColor}" HorizontalAlignment="Center" Margin="0,2,0,5"/>
                            <TextBlock Text="{Binding CurrentPatient.Phone}" FontSize="11" Foreground="{StaticResource SubtextColor}" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Scrollable Sidebar Content -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Style="{StaticResource MaterialDesignScrollViewer}">
                        <StackPanel>
                            <!-- General Patient Info Expander -->
                            <Expander IsExpanded="True" Background="White" BorderBrush="{StaticResource BorderColor}" BorderThickness="1" 
                                      Margin="0,0,0,15" Padding="10" ExpandDirection="Down">
                                <Expander.Header>
                                    <StackPanel Orientation="Vertical" HorizontalAlignment="Left">
                                        <TextBlock Text="General Medical Info" FontWeight="Bold" Foreground="{StaticResource TextColor}" FontSize="12" Margin="0,0,0,2"/>
                                        <TextBlock Text="الملف الطبي العام" FontSize="11" Foreground="{StaticResource SubtextColor}" Margin="0"/>
                                    </StackPanel>
                                </Expander.Header>
                                <StackPanel Margin="5" Grid.IsSharedSizeScope="True">
                                    <!-- Blood Group -->
                                    <Grid Margin="0,0,0,10" FlowDirection="RightToLeft">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" SharedSizeGroup="LabelColumn"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="فصيلة الدم:" FontSize="11" Foreground="{StaticResource SubtextColor}" HorizontalAlignment="Right" Margin="0,0,10,0"/>
                                        <TextBlock Grid.Column="1" Text="{Binding CurrentPatient.BloodGroup, TargetNullValue='غير محدد'}" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextColor}" HorizontalAlignment="Left" TextWrapping="Wrap"/>
                                    </Grid>

                                    <!-- Allergy -->
                                    <Grid Margin="0,0,0,10" FlowDirection="RightToLeft">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" SharedSizeGroup="LabelColumn"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="الحساسية:" FontSize="11" Foreground="{StaticResource SubtextColor}" HorizontalAlignment="Right" Margin="0,0,10,0"/>
                                        <TextBlock Grid.Column="1" Text="{Binding CurrentPatient.Allergy, TargetNullValue='لا يوجد'}" FontSize="12" FontWeight="Bold" Foreground="#EF4444" HorizontalAlignment="Left" TextWrapping="Wrap"/>
                                    </Grid>

                                    <!-- Weight -->
                                    <Grid Margin="0,0,0,10" FlowDirection="RightToLeft">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" SharedSizeGroup="LabelColumn"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="الوزن:" FontSize="11" Foreground="{StaticResource SubtextColor}" HorizontalAlignment="Right" Margin="0,0,10,0"/>
                                        <TextBlock Grid.Column="1" Text="{Binding CurrentPatient.Weight, TargetNullValue='غير محدد'}" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextColor}" HorizontalAlignment="Left" TextWrapping="Wrap"/>
                                    </Grid>

                                    <!-- Height -->
                                    <Grid Margin="0,0,0,10" FlowDirection="RightToLeft">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" SharedSizeGroup="LabelColumn"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="الطول:" FontSize="11" Foreground="{StaticResource SubtextColor}" HorizontalAlignment="Right" Margin="0,0,10,0"/>
                                        <TextBlock Grid.Column="1" Text="{Binding CurrentPatient.Height, TargetNullValue='غير محدد'}" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextColor}" HorizontalAlignment="Left" TextWrapping="Wrap"/>
                                    </Grid>

                                    <!-- Smoking -->
                                    <Grid Margin="0,0,0,10" FlowDirection="RightToLeft">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" SharedSizeGroup="LabelColumn"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="التدخين:" FontSize="11" Foreground="{StaticResource SubtextColor}" HorizontalAlignment="Right" Margin="0,0,10,0"/>
                                        <TextBlock Grid.Column="1" Text="{Binding CurrentPatient.Smoking, TargetNullValue='غير محدد'}" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextColor}" HorizontalAlignment="Left" TextWrapping="Wrap"/>
                                    </Grid>

                                    <!-- Alcohol -->
                                    <Grid Margin="0,0,0,10" FlowDirection="RightToLeft">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" SharedSizeGroup="LabelColumn"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="الكحول:" FontSize="11" Foreground="{StaticResource SubtextColor}" HorizontalAlignment="Right" Margin="0,0,10,0"/>
                                        <TextBlock Grid.Column="1" Text="{Binding CurrentPatient.Alcohol, TargetNullValue='غير محدد'}" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextColor}" HorizontalAlignment="Left" TextWrapping="Wrap"/>
                                    </Grid>

                                    <!-- Referred By -->
                                    <Grid Margin="0,0,0,10" FlowDirection="RightToLeft">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" SharedSizeGroup="LabelColumn"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="من طرف:" FontSize="11" Foreground="{StaticResource SubtextColor}" HorizontalAlignment="Right" Margin="0,0,10,0"/>
                                        <TextBlock Grid.Column="1" Text="{Binding CurrentPatient.ReferredBy, TargetNullValue='غير محدد'}" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextColor}" HorizontalAlignment="Left" TextWrapping="Wrap"/>
                                    </Grid>

                                    <!-- Marital Status -->
                                    <Grid Margin="0,0,0,10" FlowDirection="RightToLeft">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" SharedSizeGroup="LabelColumn"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="الحالة الزوجية:" FontSize="11" Foreground="{StaticResource SubtextColor}" HorizontalAlignment="Right" Margin="0,0,10,0"/>
                                        <TextBlock Grid.Column="1" Text="{Binding CurrentPatient.MaritalStatus, TargetNullValue='غير محدد'}" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextColor}" HorizontalAlignment="Left" TextWrapping="Wrap"/>
                                    </Grid>

                                    <!-- General Notes -->
                                    <StackPanel Margin="0,5,0,0" FlowDirection="RightToLeft">
                                        <TextBlock Text="ملاحظات عامة:" FontSize="11" Foreground="{StaticResource SubtextColor}" HorizontalAlignment="Right" Margin="0,0,0,4"/>
                                        <TextBlock Text="{Binding CurrentPatient.Notes, TargetNullValue='لا يوجد ملاحظات'}" FontSize="12" TextWrapping="Wrap" Foreground="{StaticResource TextColor}" TextAlignment="Right" HorizontalAlignment="Right"/>
                                    </StackPanel>
                                </StackPanel>
                            </Expander>

                            <!-- Expandable Visits Timeline -->
                            <TextBlock Text="Visits History" FontWeight="Bold" Foreground="{StaticResource TextColor}" Margin="0,0,0,8"/>
                            <ItemsControl ItemsSource="{Binding VisitHistory}" Margin="0,0,0,15">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Expander Header="{Binding VisitDate, StringFormat=\{0:dd/MM/yyyy\}}" 
                                                  Background="White" BorderBrush="{StaticResource BorderColor}" BorderThickness="1" 
                                                  Margin="0,0,0,6" Padding="5" ExpandDirection="Down">
                                            <StackPanel Margin="5">
                                                <TextBlock Text="Diagnosis:" FontWeight="Bold" FontSize="11" Foreground="{StaticResource SubtextColor}"/>
                                                <TextBlock Text="{Binding Diagnosis, TargetNullValue='No diagnosis'}" FontSize="11" TextWrapping="Wrap" Margin="0,2,0,6"/>
                                                
                                                <TextBlock Text="Chief Complaint:" FontWeight="Bold" FontSize="11" Foreground="{StaticResource SubtextColor}"/>
                                                <TextBlock Text="{Binding ChiefComplaint}" FontSize="11" TextWrapping="Wrap" Margin="0,2,0,6"/>

                                                <!-- Vitals details if populated -->
                                                <TextBlock Text="Vitals (HR/BP/Temp):" FontWeight="Bold" FontSize="11" Foreground="{StaticResource SubtextColor}"/>
                                                <TextBlock FontSize="11" Margin="0,2,0,6">
                                                    <Run Text="HR: "/><Run Text="{Binding VitalsHR}" FontWeight="SemiBold"/>
                                                    <Run Text=" | BP: "/><Run Text="{Binding VitalsSBP}" FontWeight="SemiBold"/><Run Text="/"/><Run Text="{Binding VitalsDBP}" FontWeight="SemiBold"/>
                                                    <Run Text=" | Temp: "/><Run Text="{Binding VitalsTemp}" FontWeight="SemiBold"/><Run Text="°C"/>
                                                </TextBlock>

                                                <!-- Investigation / Imaging if populated -->
                                                <TextBlock Text="Investigation / Imaging:" FontWeight="Bold" FontSize="11" Foreground="{StaticResource SubtextColor}"/>
                                                <TextBlock FontSize="11" Margin="0,2,0,4">
                                                    <Run Text="Lab: "/><Run Text="{Binding Investigation}" FontWeight="SemiBold"/>
                                                    <Run Text=" | Imaging: "/><Run Text="{Binding Imaging}" FontWeight="SemiBold"/>
                                                </TextBlock>

                                                <!-- Attachments in History if present -->
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6"
                                                            Visibility="{Binding InvestigationAttachmentPath, Converter={StaticResource NullToVisibilityConverter}}">
                                                    <TextBlock Text="📎 " FontSize="11" VerticalAlignment="Center" Foreground="#0284C7"/>
                                                    <Button Content="Open Lab File" Style="{StaticResource NavButton}" Padding="0" HorizontalContentAlignment="Left" Foreground="#0284C7" FontSize="10" FontWeight="SemiBold"
                                                            Command="{Binding DataContext.OpenAttachmentCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding InvestigationAttachmentPath}"/>
                                                </StackPanel>
                                                
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6"
                                                            Visibility="{Binding ImagingAttachmentPath, Converter={StaticResource NullToVisibilityConverter}}">
                                                    <TextBlock Text="📎 " FontSize="11" VerticalAlignment="Center" Foreground="#0284C7"/>
                                                    <Button Content="Open Imaging File" Style="{StaticResource NavButton}" Padding="0" HorizontalContentAlignment="Left" Foreground="#0284C7" FontSize="10" FontWeight="SemiBold"
                                                            Command="{Binding DataContext.OpenAttachmentCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding ImagingAttachmentPath}"/>
                                                </StackPanel>
                                                
                                                <TextBlock Text="Rx Prescribed:" FontWeight="Bold" FontSize="11" Foreground="{StaticResource SubtextColor}"/>
                                                <TextBlock Text="{Binding Prescription, TargetNullValue='No drugs'}" FontSize="11" TextWrapping="Wrap" Margin="0,2,0,8" FontWeight="SemiBold"/>
                                                
                                                <!-- Action Buttons inside Expander -->
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Button Grid.Column="0" Content="Print Pad" FontSize="9" Padding="2" Margin="0,0,3,0"
                                                            Command="{Binding DataContext.PrintVisitRxCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}"
                                                            Visibility="{Binding Prescription, Converter={StaticResource NullToVisibilityConverter}}"/>
                                                    <Button Grid.Column="1" Content="Print Report" FontSize="9" Padding="2" Margin="3,0,0,0"
                                                            Command="{Binding DataContext.PrintVisitReportCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}"/>
                                                </Grid>
                                            </StackPanel>
                                        </Expander>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- General Info Table -->
                            <TextBlock Text="General Info" FontWeight="Bold" Foreground="{StaticResource TextColor}" Margin="0,0,0,8"/>
                            <Border Background="White" BorderBrush="{StaticResource BorderColor}" BorderThickness="1.5" CornerRadius="8" Padding="12">
                                <StackPanel>
                                    <!-- Age -->
                                    <Grid Margin="0,0,0,8">
                                        <TextBlock Text="Age:" Foreground="{StaticResource SubtextColor}" FontSize="12"/>
                                        <TextBlock Text="{Binding CurrentPatient.Age, StringFormat='\{0\} years'}" Foreground="{StaticResource TextColor}" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                                    </Grid>
                                    <Border Height="1" Background="{StaticResource BorderColor}" Margin="0,0,0,8"/>
                                    <!-- Phone -->
                                    <Grid Margin="0,0,0,8">
                                        <TextBlock Text="Phone:" Foreground="{StaticResource SubtextColor}" FontSize="12"/>
                                        <TextBlock Text="{Binding CurrentPatient.Phone}" Foreground="{StaticResource TextColor}" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                                    </Grid>
                                    <Border Height="1" Background="{StaticResource BorderColor}" Margin="0,0,0,8"/>
                                    <!-- Registered -->
                                    <Grid>
                                        <TextBlock Text="Registered:" Foreground="{StaticResource SubtextColor}" FontSize="12"/>
                                        <TextBlock Text="{Binding CurrentPatient.CreatedAt, StringFormat='\{0:dd/MM/yyyy\}'}" Foreground="{StaticResource TextColor}" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
