                                            <StackPanel Margin="5">
                                                <TextBlock Text="Diagnosis:" FontWeight="Bold" FontSize="11" Foreground="{StaticResource SubtextColor}"/>
                                                <TextBlock Text="{Binding Diagnosis, TargetNullValue='No diagnosis'}" FontSize="11" TextWrapping="Wrap" Margin="0,2,0,6"/>
                                                
                                                <TextBlock Text="Chief Complaint:" FontWeight="Bold" FontSize="11" Foreground="{StaticResource SubtextColor}"/>
                                                <TextBlock Text="{Binding ChiefComplaint}" FontSize="11" TextWrapping="Wrap" Margin="0,2,0,6"/>

                                                <!-- Vitals details if populated -->
                                                <TextBlock Text="Vitals (HR/BP/Temp):" FontWeight="Bold" FontSize="11" Foreground="{StaticResource SubtextColor}"/>
                                                <TextBlock FontSize="11" Margin="0,2,0,6">
                                                    <Run Text="HR: "/><Run Text="{Binding VitalsHR}" FontWeight="SemiBold"/>
                                                    <Run Text=" | BP: "/><Run Text="{Binding VitalsSBP}" FontWeight="SemiBold"/><Run Text="/"/><Run Text="{Binding VitalsDBP}" FontWeight="SemiBold"/>
                                                    <Run Text=" | Temp: "/><Run Text="{Binding VitalsTemp}" FontWeight="SemiBold"/><Run Text="°C"/>
                                                </TextBlock>

                                                <!-- Investigation / Imaging if populated -->
                                                <TextBlock Text="Investigation / Imaging:" FontWeight="Bold" FontSize="11" Foreground="{StaticResource SubtextColor}"/>
                                                <TextBlock FontSize="11" Margin="0,2,0,4">
                                                    <Run Text="Lab: "/><Run Text="{Binding Investigation}" FontWeight="SemiBold"/>
                                                    <Run Text=" | Imaging: "/><Run Text="{Binding Imaging}" FontWeight="SemiBold"/>
                                                </TextBlock>

                                                <!-- Attachments in History if present -->
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6"
                                                            Visibility="{Binding InvestigationAttachmentPath, Converter={StaticResource NullToVisibilityConverter}}">
                                                    <TextBlock Text="📎 " FontSize="11" VerticalAlignment="Center" Foreground="#0284C7"/>
                                                    <Button Content="Open Lab File" Style="{StaticResource NavButton}" Padding="0" HorizontalContentAlignment="Left" Foreground="#0284C7" FontSize="10" FontWeight="SemiBold"
                                                            Command="{Binding DataContext.OpenAttachmentCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding InvestigationAttachmentPath}"/>
                                                </StackPanel>
                                                
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6"
                                                            Visibility="{Binding ImagingAttachmentPath, Converter={StaticResource NullToVisibilityConverter}}">
                                                    <TextBlock Text="📎 " FontSize="11" VerticalAlignment="Center" Foreground="#0284C7"/>
                                                    <Button Content="Open Imaging File" Style="{StaticResource NavButton}" Padding="0" HorizontalContentAlignment="Left" Foreground="#0284C7" FontSize="10" FontWeight="SemiBold"
                                                            Command="{Binding DataContext.OpenAttachmentCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding ImagingAttachmentPath}"/>
                                                </StackPanel>
                                                
                                                <TextBlock Text="Rx Prescribed:" FontWeight="Bold" FontSize="11" Foreground="{StaticResource SubtextColor}"/>
                                                <TextBlock Text="{Binding Prescription, TargetNullValue='No drugs'}" FontSize="11" TextWrapping="Wrap" Margin="0,2,0,8" FontWeight="SemiBold"/>
                                                
                                                <!-- Action Buttons inside Expander -->
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Button Grid.Column="0" Content="Print Rx" FontSize="9" Padding="2" Margin="0,0,3,0"
                                                            Command="{Binding DataContext.PrintVisitRxCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}"
                                                            Visibility="{Binding Prescription, Converter={StaticResource NullToVisibilityConverter}}"/>
                                                    <Button Grid.Column="1" Content="Print Report" FontSize="9" Padding="2" Margin="3,0,0,0"
                                                            Command="{Binding DataContext.PrintVisitReportCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}"/>
                                                </Grid>
                                            </StackPanel>
                                        </Expander>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <Border Height="1" Background="{StaticResource BorderColor}" Margin="0,0,0,8"/>
                            <!-- Registered -->
                            <Grid>
                                <TextBlock Text="Registered:" Foreground="{StaticResource SubtextColor}" FontSize="12"/>
                                <TextBlock Text="{Binding CurrentPatient.CreatedAt, StringFormat='\{0:dd/MM/yyyy\}'}" Foreground="{StaticResource TextColor}" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
    </materialDesign:DialogHost>

        <!-- Custom visual drag-drop preview canvas -->
        <Canvas x:Name="DragPreviewCanvas" IsHitTestVisible="False" Background="Transparent" Visibility="Collapsed">
            <Border x:Name="DragPreviewBorder" BorderBrush="{DynamicResource PrimaryColor}" BorderThickness="1.5" CornerRadius="8" Opacity="0.95" Background="{DynamicResource CardBackgroundColor}" IsHitTestVisible="False" RenderTransformOrigin="0.5,0.5">
                <Border.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform ScaleX="1.02" ScaleY="1.02"/>
                    </TransformGroup>
                </Border.RenderTransform>
                <Border.Effect>
                    <DropShadowEffect Color="#0F172A" BlurRadius="16" ShadowDepth="5" Opacity="0.3"/>
                </Border.Effect>
                <Rectangle x:Name="DragPreviewRect">
                    <Rectangle.Fill>
                        <VisualBrush x:Name="DragPreviewBrush" Stretch="None" AlignmentX="Left" AlignmentY="Top"/>
                    </Rectangle.Fill>
                </Rectangle>
            </Border>
        </Canvas>

        <!-- Overlay Modal Dialog: Switch Doctor Profile Verification -->
        <Grid Background="#80000000" Visibility="{Binding ShowSwitchDoctorPasswordModal, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Border Background="{DynamicResource CardBackgroundColor}" BorderBrush="{StaticResource BorderColor}" BorderThickness="1.5" CornerRadius="12" Width="380" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="25">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" Color="Black" Opacity="0.3" ShadowDepth="5"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/> <!-- Header -->
                        <RowDefinition Height="*"/>    <!-- Input -->
                        <RowDefinition Height="Auto"/> <!-- Buttons -->
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="التحقق من هوية الطبيب (Doctor Profile Switch)" FontSize="15" FontWeight="Bold" Foreground="{StaticResource PrimaryColor}" HorizontalAlignment="Right" Margin="0,0,0,15"/>

                    <StackPanel Grid.Row="1" Margin="0,0,0,20">
                        <!-- Target Doctor Info -->
                        <TextBlock Text="اسم الطبيب" FontSize="11" Foreground="{StaticResource SubtextColor}" HorizontalAlignment="Right" Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding SelectedSwitchDoctor.Name}" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource TextColor}" HorizontalAlignment="Right" Margin="0,0,0,12"/>

                        <TextBlock Text="أدخل رمز التحقق الخاص بك (Enter Password)" FontSize="11" Foreground="{StaticResource SubtextColor}" HorizontalAlignment="Right" Margin="0,0,0,4"/>
                        <TextBox Style="{StaticResource ModernTextBox}" Text="{Binding SwitchDoctorPasswordAttempt, UpdateSourceTrigger=PropertyChanged}" Tag="رمز الطبيب" Margin="0,0,0,10" HorizontalContentAlignment="Right"/>
                        <TextBlock Text="{Binding SwitchDoctorErrorMessage}" Foreground="#EF4444" FontSize="11" TextAlignment="Right"/>
                    </StackPanel>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Style="{StaticResource ModernButton}" Content="إلغاء" Command="{Binding CancelSwitchDoctorPasswordCommand}" Background="#EF4444" BorderBrush="#EF4444" Height="36" Margin="0,0,5,0"/>
                        <Button Grid.Column="1" Style="{StaticResource ModernButton}" Content="تحقق" Command="{Binding ConfirmSwitchDoctorPasswordCommand}" Height="36" Margin="5,0,0,0"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- Overlay Modal Dialog: Doctor-Side Add Patient -->
        <Grid Background="#80000000" Visibility="{Binding ShowAddPatientModal, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Border Background="{DynamicResource CardBackgroundColor}" BorderBrush="{StaticResource BorderColor}" BorderThickness="1.5" CornerRadius="12" Width="720" MaxHeight="620" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="25">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" Color="Black" Opacity="0.3" ShadowDepth="5"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/> <!-- Header -->
                        <RowDefinition Height="*"/>    <!-- Scrollable Form Fields -->
                        <RowDefinition Height="Auto"/> <!-- Action Buttons -->
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <TextBlock Grid.Row="0" Text="اضافة مريض جديد وتسجيل زيارة (Add Patient &amp; Check-In)" FontSize="20" FontWeight="Bold" Foreground="{StaticResource PrimaryColor}" HorizontalAlignment="Right" Margin="0,0,0,15"/>

                    <!-- Scrollable Form -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,20">
                        <Grid Margin="5,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Left Column -->
                            <StackPanel Grid.Column="0" Margin="0,0,12,0" FlowDirection="RightToLeft">
                                <!-- Governorate -->
                                <TextBlock Text="المحافظة" FontSize="11" Foreground="{StaticResource SubtextColor}" HorizontalAlignment="Right" Margin="0,0,0,4"/>
                                <ComboBox SelectedValuePath="Content" SelectedValue="{Binding NewPatientGovernorate}" Height="36" Margin="0,0,0,12">
                                    <ComboBoxItem Content="بغداد"/>
                                    <ComboBoxItem Content="البصرة"/>
                                    <ComboBoxItem Content="نينوى"/>
                                    <ComboBoxItem Content="اربيل"/>
                                    <ComboBoxItem Content="النجف"/>
                                    <ComboBoxItem Content="كربلاء"/>
                                    <ComboBoxItem Content="بابل"/>
                                    <ComboBoxItem Content="الأنبار"/>
                                    <ComboBoxItem Content="ديالى"/>
                                    <ComboBoxItem Content="كركوك"/>
                                    <ComboBoxItem Content="صلاح الدين"/>
                                    <ComboBoxItem Content="المثنى"/>
                                    <ComboBoxItem Content="ميسان"/>
                                    <ComboBoxItem Content="ذي قار"/>
                                    <ComboBoxItem Content="السليمانية"/>
                                    <ComboBoxItem Content="دهوك"/>
                                    <ComboBoxItem Content="واسط"/>
                                    <ComboBoxItem Content="القادسية"/>
                                </ComboBox>

                                <!-- Gender -->
                                <TextBlock Text="* الجنس" FontSize="11" Foreground="{StaticResource SubtextColor}" HorizontalAlignment="Right" Margin="0,0,0,4"/>
                                <ComboBox SelectedValuePath="Content" SelectedValue="{Binding NewPatientGender}" Height="36" Margin="0,0,0,12">
                                    <ComboBoxItem Content="ذكر"/>
                                    <ComboBoxItem Content="أنثى"/>
                                </ComboBox>

                                <!-- Visit Type Choice -->
                                <TextBlock Text="نوع الزيارة" FontSize="11" Foreground="{StaticResource SubtextColor}" HorizontalAlignment="Right" Margin="0,0,0,4"/>
                                <Grid Margin="0,0,0,12" FlowDirection="RightToLeft">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <RadioButton Grid.Column="0" Content="زيارة مدفوعة" IsChecked="{Binding NewPatientIsPaidVisit}" GroupName="DocVisitType" HorizontalAlignment="Left"/>
                                    <RadioButton Grid.Column="1" Content="مراجعة مجانية" IsChecked="{Binding NewPatientIsFreeVisit}" GroupName="DocVisitType" HorizontalAlignment="Left"/>
                                </Grid>

                                <!-- Price input (only enabled/visible if paid) -->
                                <StackPanel Visibility="{Binding NewPatientIsPaidVisit, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <TextBlock Text="سعر الزيارة" FontSize="11" Foreground="{StaticResource SubtextColor}" HorizontalAlignment="Right" Margin="0,0,0,4"/>
                                    <TextBox Style="{StaticResource ModernTextBox}" Text="{Binding NewPatientVisitPrice, UpdateSourceTrigger=PropertyChanged}" Tag="25000" Margin="0,0,0,12" HorizontalContentAlignment="Right"/>
                                </StackPanel>

                                <!-- Patient Files -->
                                <TextBlock Text="الملفات" FontSize="11" Foreground="{StaticResource SubtextColor}" HorizontalAlignment="Right" Margin="0,0,0,4"/>
                                <Grid Margin="0,0,0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="1" Style="{StaticResource ModernButton}" Content="رفع ملف" Command="{Binding UploadNewPatientFileCommand}" Background="#0EA5E9" BorderBrush="#0EA5E9" Padding="12,5" FontSize="11" Margin="5,0,0,0"/>
                                    <TextBox Grid.Column="0" Style="{StaticResource ModernTextBox}" Text="{Binding NewPatientFileName, Mode=OneWay}" IsReadOnly="True" Background="#F1F5F9" HorizontalContentAlignment="Right"/>
                                </Grid>
                                <!-- File link & Remove -->
                                <Border Background="#F0F9FF" BorderBrush="#BAE6FD" BorderThickness="1" CornerRadius="4" Padding="8,4" Margin="0,0,0,10"
                                        Visibility="{Binding NewPatientFiles, Converter={StaticResource NullToVisibilityConverter}}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="&#xE71B;" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center" Foreground="#0284C7" Margin="0,0,6,0"/>
                                        <Button Grid.Column="1" Content="{Binding NewPatientFileName}" Style="{StaticResource NavButton}" Padding="0" HorizontalContentAlignment="Left" Foreground="#0284C7" FontSize="11" FontWeight="SemiBold"
                                                Command="{Binding OpenNewPatientFileCommand}" CommandParameter="{Binding NewPatientFiles}"/>
                                        <Button Grid.Column="2" Style="{StaticResource NavButton}" Width="16" Height="16" Tag="&#xE711;" ToolTip="حذف الملف" Padding="0" Foreground="#EF4444" FontSize="8"
                                                Command="{Binding RemoveNewPatientFileCommand}"/>
                                    </Grid>
                                </Border>
                            </StackPanel>

                            <!-- Right Column -->
                            <StackPanel Grid.Column="1" Margin="12,0,0,0" FlowDirection="RightToLeft">
                                <!-- Name -->
                                <TextBlock Text="* الاسم" FontSize="11" Foreground="{StaticResource SubtextColor}" HorizontalAlignment="Right" Margin="0,0,0,4"/>
                                <TextBox Style="{StaticResource ModernTextBox}" Text="{Binding NewPatientName, UpdateSourceTrigger=PropertyChanged}" Tag="اسم المريض الثلاثي" Margin="0,0,0,12" HorizontalContentAlignment="Right"/>

                                <!-- Age (Years) -->
                                <TextBlock Text="* العمر (سنوات)" FontSize="11" Foreground="{StaticResource SubtextColor}" HorizontalAlignment="Right" Margin="0,0,0,4"/>
                                <TextBox Style="{StaticResource ModernTextBox}" Text="{Binding NewPatientAge, UpdateSourceTrigger=PropertyChanged}" Tag="العمر بالسنوات" Margin="0,0,0,12" HorizontalContentAlignment="Right"/>

                                <!-- Age (Months) -->
                                <TextBlock Text="العمر (أشهر)" FontSize="11" Foreground="{StaticResource SubtextColor}" HorizontalAlignment="Right" Margin="0,0,0,4"/>
                                <TextBox Style="{StaticResource ModernTextBox}" Text="{Binding NewPatientAgeMonths, UpdateSourceTrigger=PropertyChanged}" Tag="أشهر" Margin="0,0,0,12" HorizontalContentAlignment="Right"/>

                                <!-- Birth Date -->
                                <TextBlock Text="تاريخ الولادة" FontSize="11" Foreground="{StaticResource SubtextColor}" HorizontalAlignment="Right" Margin="0,0,0,4"/>
                                <DatePicker SelectedDate="{Binding NewPatientBirthDate}" Height="36" Margin="0,0,0,12" FlowDirection="RightToLeft"/>

                                <!-- Phone -->
                                <TextBlock Text="رقم الهاتف" FontSize="11" Foreground="{StaticResource SubtextColor}" HorizontalAlignment="Right" Margin="0,0,0,4"/>
                                <TextBox Style="{StaticResource ModernTextBox}" Text="{Binding NewPatientPhone, UpdateSourceTrigger=PropertyChanged}" Tag="رقم الهاتف" Margin="0,0,0,12" HorizontalContentAlignment="Right"/>
                            </StackPanel>
                        </Grid>
                    </ScrollViewer>

                    <!-- Buttons and Message -->
                    <StackPanel Grid.Row="2">
                        <TextBlock Text="{Binding AddPatientValidationMessage}" Foreground="#EF4444" FontSize="12" HorizontalAlignment="Right" Margin="0,0,0,10"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Style="{StaticResource ModernButton}" Content="إلغاء" Command="{Binding CancelAddPatientCommand}" Background="#EF4444" BorderBrush="#EF4444" Height="38" Margin="0,0,5,0"/>
                            <Button Grid.Column="1" Style="{StaticResource ModernButton}" Content="حفظ وتأكيد الدخول" Command="{Binding SaveAddPatientAsyncCommand}" Height="38" Margin="5,0,0,0"/>
                        </Grid>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
