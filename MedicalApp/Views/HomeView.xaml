<UserControl x:Class="MedicalApp.Views.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="1000"
             Background="Transparent">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Welcome Header -->
            <RowDefinition Height="*"/>    <!-- Cards Grid -->
        </Grid.RowDefinitions>

        <!-- Welcome Banner Header -->
        <Grid Grid.Row="0" Margin="0,30,0,10">
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="Welcome back, Dr. Yaser" Style="{StaticResource Header1}" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                <TextBlock Text="Select a clinical room or registry desk below to manage clinic sessions and patient workflow." Style="{StaticResource Subheading}" FontSize="14" HorizontalAlignment="Center"/>
            </StackPanel>
            
            <Button HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,10,20,0"
                    Style="{StaticResource NavButton}" Padding="10" Width="40" Height="40"
                    Tag="&#xE713;" ToolTip="Print &amp; Calibration Settings"
                    Command="{Binding DataContext.NavigateToPrintSettingsCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
        </Grid>

        <!-- Selection Cards Grid -->
        <Grid Grid.Row="1" MaxWidth="760" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,40">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="300" MaxWidth="360"/>
                <ColumnDefinition Width="*" MinWidth="300" MaxWidth="360"/>
            </Grid.ColumnDefinitions>

            <!-- Card 1: Patient Registry -->
            <Border Grid.Column="0" Style="{StaticResource CardBorder}" Margin="15">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/> <!-- Icon -->
                        <RowDefinition Height="Auto"/> <!-- Title -->
                        <RowDefinition Height="*"/>    <!-- Description -->
                        <RowDefinition Height="Auto"/> <!-- Enter Button -->
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" Text="&#xE716;" FontFamily="Segoe MDL2 Assets" FontSize="48" Foreground="{StaticResource PrimaryColor}" HorizontalAlignment="Center" Margin="0,20,0,25"/>
                    <TextBlock Grid.Row="1" Text="Secretary" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextColor}" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                    <TextBlock Grid.Row="2" Text="Enroll new patients, look up existing patient files with autocomplete search-as-you-type, and send patients to today's active waitlist queue." 
                               FontSize="12" Foreground="{StaticResource SubtextColor}" TextWrapping="Wrap" TextAlignment="Center" LineHeight="18" Margin="0,0,0,25"/>
                    
                    <Button Grid.Row="3" Style="{StaticResource ModernButton}" Content="Enter Secretary Room" Command="{Binding NavigateToRegistryCommand}" Height="40" HorizontalAlignment="Stretch"/>
                </Grid>
            </Border>

            <!-- Card 2: Doctor -->
            <Border Grid.Column="1" Style="{StaticResource CardBorder}" Margin="15">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/> <!-- Icon -->
                        <RowDefinition Height="Auto"/> <!-- Title -->
                        <RowDefinition Height="*"/>    <!-- Description -->
                        <RowDefinition Height="Auto"/> <!-- Enter Button -->
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" Text="&#xE1E2;" FontFamily="Segoe MDL2 Assets" FontSize="48" Foreground="{StaticResource PrimaryColor}" HorizontalAlignment="Center" Margin="0,20,0,25"/>
                    <TextBlock Grid.Row="1" Text="Doctor" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextColor}" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                    <TextBlock Grid.Row="2" Text="Manage queued patients in real-time, view full clinical exam timeline logs, write notes, and direct patients to completion." 
                               FontSize="12" Foreground="{StaticResource SubtextColor}" TextWrapping="Wrap" TextAlignment="Center" LineHeight="18" Margin="0,0,0,25"/>
                    
                    <Button Grid.Row="3" Style="{StaticResource ModernButton}" Content="Enter Doctor Room" Command="{Binding NavigateToExamCommand}" Height="40" HorizontalAlignment="Stretch"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
