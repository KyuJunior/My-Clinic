<Window x:Class="MedicalApp.Views.HomeLauncherWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="CardioCenter 360 - Launcher Portal" Height="520" Width="1020"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundColor}">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>  <!-- Top Banner -->
            <RowDefinition Height="*"/>   <!-- Room Selection Cards Grid -->
            <RowDefinition Height="32"/>  <!-- Status Footer -->
        </Grid.RowDefinitions>

        <!-- Top Pink/Teal Header Banner -->
        <Border Grid.Row="0" Background="White" BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,0,1">
            <Grid Margin="25,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Cardio" FontSize="20" FontWeight="Bold" Foreground="{StaticResource PrimaryColor}"/>
                    <TextBlock Text="Center" FontSize="20" FontWeight="Light" Foreground="{StaticResource PrimaryColor}"/>
                    <Border Background="{StaticResource SelectedTabBrush}" CornerRadius="4" Padding="6,2" Margin="8,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="Launcher Portal 360" FontSize="10" FontWeight="Bold" Foreground="{StaticResource SelectedTabTextBrush}"/>
                    </Border>
                </StackPanel>

                <Border Grid.Column="1" VerticalAlignment="Center" Background="#D1FAE5" Padding="10,5" CornerRadius="6">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="6" Height="6" Fill="#059669" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Database Connected" FontSize="11" FontWeight="SemiBold" Foreground="#065F46" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Room Selection Cards Grid -->
        <Grid Grid.Row="1" Margin="15,20,15,10" MaxWidth="960" HorizontalAlignment="Center">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="280" MaxWidth="310"/>
                <ColumnDefinition Width="*" MinWidth="280" MaxWidth="310"/>
                <ColumnDefinition Width="*" MinWidth="280" MaxWidth="310"/>
            </Grid.ColumnDefinitions>

            <!-- Card 1: Patient Registry -->
            <Border Grid.Column="0" Style="{StaticResource CardBorder}" Margin="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/> <!-- Icon -->
                        <RowDefinition Height="Auto"/> <!-- Title -->
                        <RowDefinition Height="*"/>    <!-- Description -->
                        <RowDefinition Height="Auto"/> <!-- Enter Button -->
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" Text="&#xE716;" FontFamily="Segoe MDL2 Assets" FontSize="44" Foreground="{StaticResource PrimaryColor}" HorizontalAlignment="Center" Margin="0,15,0,20"/>
                    <TextBlock Grid.Row="1" Text="Patient Registry" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextColor}" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    <TextBlock Grid.Row="2" Text="Enroll new patients, search existing records using autocomplete lookup, and queue them to today's active waitlist." 
                               FontSize="12" Foreground="{StaticResource SubtextColor}" TextWrapping="Wrap" TextAlignment="Center" LineHeight="16" Margin="0,0,0,20"/>
                    
                    <Button Grid.Row="3" Style="{StaticResource ModernButton}" Content="Open Registry Window" Command="{Binding LaunchRegistryCommand}" Height="38" HorizontalAlignment="Stretch"/>
                </Grid>
            </Border>

            <!-- Card 2: Clinical Examination -->
            <Border Grid.Column="1" Style="{StaticResource CardBorder}" Margin="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/> <!-- Icon -->
                        <RowDefinition Height="Auto"/> <!-- Title -->
                        <RowDefinition Height="*"/>    <!-- Description -->
                        <RowDefinition Height="Auto"/> <!-- Enter Button -->
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" Text="&#xE1E2;" FontFamily="Segoe MDL2 Assets" FontSize="44" Foreground="{StaticResource PrimaryColor}" HorizontalAlignment="Center" Margin="0,15,0,20"/>
                    <TextBlock Grid.Row="1" Text="Clinical Examination" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextColor}" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    <TextBlock Grid.Row="2" Text="Manage waitlisted patients in real-time, record complaints/diagnoses, and direct patients to completed status or to echo lab." 
                               FontSize="12" Foreground="{StaticResource SubtextColor}" TextWrapping="Wrap" TextAlignment="Center" LineHeight="16" Margin="0,0,0,20"/>
                    
                    <Button Grid.Row="3" Style="{StaticResource ModernButton}" Content="Open Exam Room" Command="{Binding LaunchExamCommand}" Height="38" HorizontalAlignment="Stretch"/>
                </Grid>
            </Border>

            <!-- Card 3: Echocardiogram Hub -->
            <Border Grid.Column="2" Style="{StaticResource CardBorder}" Margin="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/> <!-- Icon -->
                        <RowDefinition Height="Auto"/> <!-- Title -->
                        <RowDefinition Height="*"/>    <!-- Description -->
                        <RowDefinition Height="Auto"/> <!-- Enter Button -->
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" Text="&#xE722;" FontFamily="Segoe MDL2 Assets" FontSize="44" Foreground="{StaticResource PrimaryColor}" HorizontalAlignment="Center" Margin="0,15,0,20"/>
                    <TextBlock Grid.Row="1" Text="Echocardiogram Hub" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextColor}" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    <TextBlock Grid.Row="2" Text="Select waitlist queue entries, upload cardiac clips directly to the local LAN storage share, and view previous echo reports." 
                               FontSize="12" Foreground="{StaticResource SubtextColor}" TextWrapping="Wrap" TextAlignment="Center" LineHeight="16" Margin="0,0,0,20"/>
                    
                    <Button Grid.Row="3" Style="{StaticResource ModernButton}" Content="Open Echo Lab" Command="{Binding LaunchEchoCommand}" Height="38" HorizontalAlignment="Stretch"/>
                </Grid>
            </Border>
        </Grid>

        <!-- Status Footer -->
        <Border Grid.Row="2" Background="White" BorderBrush="{StaticResource BorderColor}" BorderThickness="0,1,0,0" Padding="15,0">
            <Grid VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="CardioCenter Clinic Launcher Portal" FontSize="10" Foreground="{StaticResource SubtextColor}"/>
                <TextBlock Grid.Column="1" Text="{Binding ConnectionInfo, StringFormat='Active Node: \{0\}'}" FontSize="10" Foreground="{StaticResource SubtextColor}" FontWeight="SemiBold"/>
            </Grid>
        </Border>
    </Grid>
</Window>
